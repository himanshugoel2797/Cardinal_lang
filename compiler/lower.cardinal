module lower

# Lowering pass: typed AST -> target-independent IR (ir.cardinal).
#
# Port of bootstrap/lower.py, adapted to "Option B": instead of reading a
# `.ctype` annotation off each AST node (our AST is immutable), the lowerer
# holds a checker Ctx plus a parallel `{str Binding}` type-scope and calls
# `checker::check_expr` to learn each expression's Type on demand. The checker
# is the SOLE type oracle — the lowerer never invents a type; an unknown or
# uninferable type is a `panic`, never a silent default.
#
# STAGE 0 (this cut): sized ints/floats/bool/char, enums, functions + recursion,
# cross-module calls, all control flow, casts, `panic`, and io::print/println of
# scalars. Aggregates (structs/arrays/vecs/maps/strings), sum types/match, and
# closures raise a clean panic until their stage.

import strings
import convert
import parser
import checker
import ir

# --------------------------------------------------------------------------- #
# Mutable lowering state. All mutated state is behind reference vecs/maps (cells
# and the builder's block/temp lists), so passing LX by value still threads the
# mutations through deep helpers. `b`, `ret`, `callmap`, and `uq[0]` are reset
# per function in lower_func.
# --------------------------------------------------------------------------- #

struct LX
    ctx Ctx
    irm IRModule
    b FuncBuilder
    chk {bool}          # `checked`-block flag (cell)
    brk {str}           # break-target label stack
    cont {str}          # continue-target label stack
    uq {i64}            # uniquifier counter (cell)
    callmap {str str}   # local/imported function name -> mangled symbol
    ret Type            # current function's return type
    captured {str bool} # names captured by a direct lambda (=> boxed); per-function
    lamn {i64}          # lifted-lambda counter (cell), module-global monotonic
end

# --------------------------------------------------------------------------- #
# Small helpers
# --------------------------------------------------------------------------- #

func mangle (m str) (n str) -> str
    return (strings::concat "cl_" (strings::concat m (strings::concat "__" n)))
end

func irt (t Type) -> IRType
    return (TyOf t: t)
end

func qual (m str) (n str) -> str
    return (strings::concat m (strings::concat "::" n))
end

func t_struct_name (t Type) -> str
    match t
        case (TStruct n)
            return n
        else
            return ""
    end
    return ""
end

func unit_ty () -> Type
    return (TPrim name: "unit")
end
func bool_ty () -> Type
    return (TPrim name: "bool")
end
func str_ty () -> Type
    return (TPrim name: "str")
end
func u64_ty () -> Type
    return (TInt name: "u64")
end

# A resolved assignment place plus its (checker) type.
struct PlaceR
    place IPlace
    ty Type
end

func copy_iv (m {str IVal}) -> {str IVal}
    let out {str IVal} = (map str IVal)
    for k in (map_keys m)
        set out[k] = m[k]
    end
    return out
end

func copy_bind (m {str Binding}) -> {str Binding}
    let out {str Binding} = (map str Binding)
    for k in (map_keys m)
        set out[k] = m[k]
    end
    return out
end

func uniq (lx LX) (base str) -> str
    set lx.uq[0] = (+ lx.uq[0] 1)
    return (strings::concat base (strings::concat "_" (convert::int_to_str lx.uq[0])))
end

func ival_name (v IVal) -> str
    match v
        case (Local name ty)
            return name
        else
            return ""
    end
    return ""
end

func index_of (v {str}) (s str) -> i64
    let i = 0u64
    while (< i (len v))
        if (strings::eq v[i] s)
            return (as i i64)
        end
        set i = (+ i 1)
    end
    return 0i64
end

# --- local Type predicates / accessors (Type variants are exported, so we match
# directly rather than export a pile of checker predicates) --- #

func t_is_int (t Type) -> bool
    match t
        case (TInt n)
            return true
        else
            return false
    end
    return false
end
func t_is_float (t Type) -> bool
    match t
        case (TFloat n)
            return true
        else
            return false
    end
    return false
end
func t_is_uint (t Type) -> bool
    match t
        case TUInt
            return true
        else
            return false
    end
    return false
end
func t_is_ufloat (t Type) -> bool
    match t
        case TUFloat
            return true
        else
            return false
    end
    return false
end
func t_is_unit (t Type) -> bool
    match t
        case (TPrim n)
            return (strings::eq n "unit")
        else
            return false
    end
    return false
end
func t_is_func (t Type) -> bool
    match t
        case (TFunc p r)
            return true
        else
            return false
    end
    return false
end
func t_func_params (t Type) -> {Type}
    match t
        case (TFunc p r)
            return p
        else
            return (vec Type)
    end
    return (vec Type)
end
func t_func_ret (t Type) -> Type
    match t
        case (TFunc p r)
            return r
        else
            return (unit_ty)
    end
    return (unit_ty)
end
func t_is_array (t Type) -> bool
    match t
        case (TArray e)
            return true
        else
            return false
    end
    return false
end
func t_is_str (t Type) -> bool
    match t
        case (TPrim n)
            return (strings::eq n "str")
        else
            return false
    end
    return false
end
func t_is_vec (t Type) -> bool
    match t
        case (TVec e)
            return true
        else
            return false
    end
    return false
end
func t_is_map (t Type) -> bool
    match t
        case (TMap k v)
            return true
        else
            return false
    end
    return false
end
func t_is_struct (t Type) -> bool
    match t
        case (TStruct n)
            return true
        else
            return false
    end
    return false
end
func t_is_sum (t Type) -> bool
    match t
        case (TSum n)
            return true
        else
            return false
    end
    return false
end
func t_sum_name (t Type) -> str
    match t
        case (TSum n)
            return n
        else
            return ""
    end
    return ""
end
func t_elem (t Type) -> Type
    match t
        case (TArray e)
            return e
        case (TVec e)
            return e
        else
            do (panic "lower: element type of a non-array/vector")
    end
    return (unit_ty)
end
func t_map_key (t Type) -> Type
    match t
        case (TMap k v)
            return k
        else
            do (panic "lower: key type of a non-map")
    end
    return (unit_ty)
end
func t_map_val (t Type) -> Type
    match t
        case (TMap k v)
            return v
        else
            do (panic "lower: value type of a non-map")
    end
    return (unit_ty)
end

# The struct/variant head name of a construction-literal target (EName or EPath).
func head_name (typ Expr) -> str
    match typ
        case (EName id)
            return id
        case (EPath parts)
            return parts[(- (len parts) 1u64)]
        else
            return ""
    end
    return ""
end

func pick_int (ts {Type}) -> Type
    let i = 0u64
    while (< i (len ts))
        if (t_is_int ts[i])
            return ts[i]
        end
        set i = (+ i 1)
    end
    return (TInt name: "i32")
end

# The type the checker assigns to `e` in context `expected`. For untyped numeric
# literals it falls back to the (concrete) context type — that is the language's
# context-typing rule, not a guess. Anything still uninferable is a hard error.
func result_ty (lx LX) (ts {str Binding}) (e Expr) (expected Type) -> Type
    let t = (checker::check_expr lx.ctx e ts expected)
    if (or (t_is_uint t) (t_is_ufloat t))
        if (or (t_is_int expected) (t_is_float expected))
            return expected
        end
        do (panic "lower: uninferable numeric result type")
    end
    return t
end

func concrete_ty (lx LX) (ts {str Binding}) (e Expr) -> Type
    let t = (checker::check_expr lx.ctx e ts TNone)
    if (or (t_is_uint t) (t_is_ufloat t))
        do (panic "lower: cannot infer type of let binding (annotate it)")
    end
    return t
end

func int_lit_ty (suffix str) (expected Type) -> Type
    if (not (strings::eq suffix ""))
        return (TInt name: suffix)
    end
    if (t_is_int expected)
        return expected
    end
    do (panic "lower: uninferable integer literal")
    return (TInt name: "i32")
end

func float_lit_ty (suffix str) (expected Type) -> Type
    if (not (strings::eq suffix ""))
        return (TFloat name: suffix)
    end
    if (t_is_float expected)
        return expected
    end
    do (panic "lower: uninferable float literal")
    return (TFloat name: "f64")
end

func is_cmp (op str) -> bool
    let v {str} = (vec str)
    do (push v "<")
    do (push v "<=")
    do (push v ">")
    do (push v ">=")
    do (push v "==")
    do (push v "!=")
    let i = 0u64
    while (< i (len v))
        if (strings::eq v[i] op)
            return true
        end
        set i = (+ i 1)
    end
    return false
end

# --------------------------------------------------------------------------- #
# Closure support: pointer-typed IR values, boxing, free-variable analysis.
#
# A captured local is BOXED: its `vs` entry is a Ptr-typed IVal (a cl_handle to a
# 1-slot heap cell). Reads deref it, writes store through it, and a closure
# captures the cell (not a copy) so mutations are shared (DESIGN §9.2 "by
# reference"). A variable is boxed iff its `vs` IVal has IRType `Ptr` — so no
# separate per-scope marker is needed (source types are never Ptr).
# --------------------------------------------------------------------------- #

# Pointer-to-void IR type used for environments and box handles (both compile to
# cl_handle, both managed => GC-rooted).
func env_ty () -> IRType
    return (Ptr p: VoidPtr)
end

func irt_is_ptr (t IRType) -> bool
    match t
        case (Ptr p)
            return true
        else
            return false
    end
    return false
end

func irt_ptr_inner (t IRType) -> IRType
    match t
        case (Ptr p)
            return p
        else
            return VoidPtr
    end
    return VoidPtr
end

# The IRType carried by an IVal (operands always carry one once lowered).
func iv_irtype (v IVal) -> IRType
    match v
        case (Temp id ty)
            return ty
        case (Local name ty)
            return ty
        case (ImmInt vv ty)
            return ty
        case (ImmFloat text ty)
            return ty
        case (ImmNull ty)
            return ty
        case (ImmBool b)
            return (irt (bool_ty))
        case (ImmChar cp)
            return (irt (TPrim name: "char"))
        case (ImmStr s)
            return (irt (str_ty))
        case ImmUnit
            return (irt (unit_ty))
    end
    return (irt (unit_ty))
end

func iv_is_boxed (v IVal) -> bool
    return (irt_is_ptr (iv_irtype v))
end

# Allocate a 1-slot heap box holding a value of `vty`; store `init` into it (when
# has_init). Returns the box handle (a Ptr-typed temp).
func make_box (lx LX) (vty IRType) (init IVal) (has_init bool) -> IVal
    let ptr = (ir::fresh_temp lx.b (Ptr p: vty))
    do (ir::emit lx.b (IAlloc dst: ptr ty: vty))
    if has_init
        do (ir::emit lx.b (IAssign place: (PDeref ptr: ptr ty: vty) src: init))
    end
    return ptr
end

# --- free-variable analysis (for closure conversion) --- #

func copy_set (m {str bool}) -> {str bool}
    let out {str bool} = (map str bool)
    for k in (map_keys m)
        set out[k] = true
    end
    return out
end

func fv_stmts (stmts {Stmt}) (bound {str bool}) (out {str bool}) -> unit
    let b = (copy_set bound)
    for s in stmts
        do (fv_stmt s b out)
    end
end

func fv_stmt (s Stmt) (bound {str bool}) (out {str bool}) -> unit
    match s
        case (SLet name ty has_ty expr mutable)
            do (fv_expr expr bound out)
            set bound[name] = true
        case (SSet target expr)
            do (fv_expr target bound out)
            do (fv_expr expr bound out)
        case (SDo call)
            do (fv_expr call bound out)
        case (SIf branches orelse has_else)
            let i = 0u64
            while (< i (len branches))
                do (fv_expr branches[i].cond bound out)
                do (fv_stmts branches[i].body bound out)
                set i = (+ i 1)
            end
            if has_else
                do (fv_stmts orelse bound out)
            end
        case (SWhile cond body)
            do (fv_expr cond bound out)
            do (fv_stmts body bound out)
        case (SForNum var start stop stride has_step body)
            do (fv_expr start bound out)
            do (fv_expr stop bound out)
            if has_step
                do (fv_expr stride bound out)
            end
            let b2 = (copy_set bound)
            set b2[var] = true
            do (fv_stmts body b2 out)
        case (SForIn var iter body)
            do (fv_expr iter bound out)
            let b2 = (copy_set bound)
            set b2[var] = true
            do (fv_stmts body b2 out)
        case (SLoop body)
            do (fv_stmts body bound out)
        case (SReturn expr has_expr)
            if has_expr
                do (fv_expr expr bound out)
            end
        case (SChecked body)
            do (fv_stmts body bound out)
        case (SAsm template outs ins clobbers)
            for op in outs
                if (not (map_has bound op.var))
                    set out[op.var] = true
                end
            end
            for op in ins
                if (not (map_has bound op.var))
                    set out[op.var] = true
                end
            end
        case (SMatch scrut arms orelse has_else)
            do (fv_expr scrut bound out)
            let i = 0u64
            while (< i (len arms))
                let b2 = (copy_set bound)
                let j = 0u64
                while (< j (len arms[i].bindings))
                    set b2[arms[i].bindings[j]] = true
                    set j = (+ j 1)
                end
                do (fv_stmts arms[i].body b2 out)
                set i = (+ i 1)
            end
            if has_else
                do (fv_stmts orelse bound out)
            end
        else
            pass
    end
end

func fv_expr (e Expr) (bound {str bool}) (out {str bool}) -> unit
    match e
        case (EName ident)
            if (not (map_has bound ident))
                set out[ident] = true
            end
        case (EOp op args)
            let i = 0u64
            while (< i (len args))
                do (fv_expr args[i] bound out)
                set i = (+ i 1)
            end
        case (ECall callee args)
            do (fv_expr callee bound out)
            let i = 0u64
            while (< i (len args))
                do (fv_expr args[i] bound out)
                set i = (+ i 1)
            end
        case (EField obj field)
            do (fv_expr obj bound out)
        case (EIndex obj index)
            do (fv_expr obj bound out)
            do (fv_expr index bound out)
        case (EStruct typ fields)
            let i = 0u64
            while (< i (len fields))
                do (fv_expr fields[i].value bound out)
                set i = (+ i 1)
            end
        case (EArr elems)
            let i = 0u64
            while (< i (len elems))
                do (fv_expr elems[i] bound out)
                set i = (+ i 1)
            end
        case (EVec elems)
            let i = 0u64
            while (< i (len elems))
                do (fv_expr elems[i] bound out)
                set i = (+ i 1)
            end
        case (EArrNew elem count)
            do (fv_expr count bound out)
        case (ECast ex ty)
            do (fv_expr ex bound out)
        case (ERef place)
            do (fv_expr place bound out)
        case (EFunc params ret has_ret body)
            let inner = (lambda_free e)
            for nm in (map_keys inner)
                if (not (map_has bound nm))
                    set out[nm] = true
                end
            end
        else
            pass
    end
end

# Names referenced in a funclit but bound outside it (its captures).
func lambda_free (fl Expr) -> {str bool}
    let out {str bool} = (map str bool)
    match fl
        case (EFunc params ret has_ret body)
            let bound {str bool} = (map str bool)
            let i = 0u64
            while (< i (len params))
                set bound[params[i].name] = true
                set i = (+ i 1)
            end
            do (fv_stmts body bound out)
        else
            pass
    end
    return out
end

# FuncLits lexically inside these statements but not nested in another FuncLit
# (the direct lambda children of the current function).
func collect_funclits_stmts (stmts {Stmt}) (out {Expr}) -> unit
    let i = 0u64
    while (< i (len stmts))
        do (collect_funclits_stmt stmts[i] out)
        set i = (+ i 1)
    end
end

func collect_funclits_stmt (s Stmt) (out {Expr}) -> unit
    match s
        case (SLet name ty has_ty expr mutable)
            do (collect_funclits_expr expr out)
        case (SSet target expr)
            do (collect_funclits_expr target out)
            do (collect_funclits_expr expr out)
        case (SDo call)
            do (collect_funclits_expr call out)
        case (SIf branches orelse has_else)
            let i = 0u64
            while (< i (len branches))
                do (collect_funclits_expr branches[i].cond out)
                do (collect_funclits_stmts branches[i].body out)
                set i = (+ i 1)
            end
            if has_else
                do (collect_funclits_stmts orelse out)
            end
        case (SWhile cond body)
            do (collect_funclits_expr cond out)
            do (collect_funclits_stmts body out)
        case (SForNum var start stop stride has_step body)
            do (collect_funclits_expr start out)
            do (collect_funclits_expr stop out)
            if has_step
                do (collect_funclits_expr stride out)
            end
            do (collect_funclits_stmts body out)
        case (SForIn var iter body)
            do (collect_funclits_expr iter out)
            do (collect_funclits_stmts body out)
        case (SLoop body)
            do (collect_funclits_stmts body out)
        case (SReturn expr has_expr)
            if has_expr
                do (collect_funclits_expr expr out)
            end
        case (SChecked body)
            do (collect_funclits_stmts body out)
        case (SMatch scrut arms orelse has_else)
            do (collect_funclits_expr scrut out)
            let i = 0u64
            while (< i (len arms))
                do (collect_funclits_stmts arms[i].body out)
                set i = (+ i 1)
            end
            if has_else
                do (collect_funclits_stmts orelse out)
            end
        else
            pass
    end
end

func collect_funclits_expr (e Expr) (out {Expr}) -> unit
    match e
        case (EFunc params ret has_ret body)
            do (push out e)
        case (EOp op args)
            let i = 0u64
            while (< i (len args))
                do (collect_funclits_expr args[i] out)
                set i = (+ i 1)
            end
        case (ECall callee args)
            do (collect_funclits_expr callee out)
            let i = 0u64
            while (< i (len args))
                do (collect_funclits_expr args[i] out)
                set i = (+ i 1)
            end
        case (EField obj field)
            do (collect_funclits_expr obj out)
        case (EIndex obj index)
            do (collect_funclits_expr obj out)
            do (collect_funclits_expr index out)
        case (EStruct typ fields)
            let i = 0u64
            while (< i (len fields))
                do (collect_funclits_expr fields[i].value out)
                set i = (+ i 1)
            end
        case (EArr elems)
            let i = 0u64
            while (< i (len elems))
                do (collect_funclits_expr elems[i] out)
                set i = (+ i 1)
            end
        case (EVec elems)
            let i = 0u64
            while (< i (len elems))
                do (collect_funclits_expr elems[i] out)
                set i = (+ i 1)
            end
        case (EArrNew elem count)
            do (collect_funclits_expr count out)
        case (ECast ex ty)
            do (collect_funclits_expr ex out)
        case (ERef place)
            do (collect_funclits_expr place out)
        else
            pass
    end
end

# The captured-name set for a function body = union of free vars of its direct
# (non-nested) lambdas. Reset per function/lambda in lower_func/lower_lambda_body.
func compute_captured (body {Stmt}) -> {str bool}
    let fls {Expr} = (vec Expr)
    do (collect_funclits_stmts body fls)
    let cap {str bool} = (map str bool)
    let i = 0u64
    while (< i (len fls))
        let fr = (lambda_free fls[i])
        for nm in (map_keys fr)
            set cap[nm] = true
        end
        set i = (+ i 1)
    end
    return cap
end

# --------------------------------------------------------------------------- #
# Expressions
# --------------------------------------------------------------------------- #

func lower_expr (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (expected Type) -> IVal
    match e
        case (EInt value suffix)
            return (ImmInt val: value ty: (irt (int_lit_ty suffix expected)))
        case (EFloat text suffix)
            return (ImmFloat text: text ty: (irt (float_lit_ty suffix expected)))
        case (EBool value)
            return (ImmBool b: value)
        case (EChar cp)
            return (ImmChar cp: (as cp i64))
        case (EStr value)
            return (ImmStr s: value)
        case ENull
            do (panic "lower: null/handles not supported yet")
        case (EName ident)
            return (lower_name lx vs ts ident)
        case (EPath parts)
            return (lower_path lx ts parts)
        case (EOp op args)
            return (lower_op lx vs ts e op args expected)
        case (ECast ex ty)
            let inner = (lower_expr lx vs ts ex TNone)
            let toty = (checker::resolve lx.ctx ty)
            let dst = (ir::fresh_temp lx.b (irt toty))
            do (ir::emit lx.b (ICast dst: dst val: inner toty: (irt toty)))
            return dst
        case (ECall callee args)
            return (lower_call lx vs ts callee args)
        case (EField obj field)
            let base = (lower_expr lx vs ts obj TNone)
            let fty = (checker::check_expr lx.ctx e ts TNone)
            let dst = (ir::fresh_temp lx.b (irt fty))
            do (ir::emit lx.b (ILoadField dst: dst base: base field: field ty: (irt fty)))
            return dst
        case (EIndex obj index)
            let bt = (checker::check_expr lx.ctx obj ts TNone)
            if (t_is_map bt)
                # m[k]: index is the key; result is the value type.
                let mp = (lower_expr lx vs ts obj TNone)
                let kty = (t_map_key bt)
                let vty = (t_map_val bt)
                let kv = (lower_expr lx vs ts index kty)
                let dst = (ir::fresh_temp lx.b (irt vty))
                do (ir::emit lx.b (IMapGet dst: dst map: mp key: kv kty: (irt kty) vty: (irt vty)))
                return dst
            end
            let obv = (lower_expr lx vs ts obj TNone)
            let idx = (lower_expr lx vs ts index (u64_ty))
            let elem = (t_elem bt)
            let dst = (ir::fresh_temp lx.b (irt elem))
            if (t_is_vec bt)
                do (ir::emit lx.b (IVecGet dst: dst vec: obv idx: idx ty: (irt elem)))
            else
                do (ir::emit lx.b (IArrGet dst: dst arr: obv idx: idx ty: (irt elem)))
            end
            return dst
        case (EStruct typ fields)
            return (lower_struct_lit lx vs ts e fields)
        case (EArr elems)
            return (lower_array_lit lx vs ts e elems expected)
        case (EArrNew elem count)
            let cnt = (lower_expr lx vs ts count (u64_ty))
            let et = (checker::resolve lx.ctx elem)
            let dst = (ir::fresh_temp lx.b (irt (TArray elem: et)))
            do (ir::emit lx.b (IArrNew dst: dst elem: (irt et) count: cnt))
            return dst
        case (EVecNew elem)
            let et = (checker::resolve lx.ctx elem)
            let dst = (ir::fresh_temp lx.b (irt (TVec elem: et)))
            do (ir::emit lx.b (IVecNew dst: dst elem: (irt et)))
            return dst
        case (EVec elems)
            return (lower_vec_lit lx vs ts e elems expected)
        case (EMapNew key val)
            let kt = (checker::resolve lx.ctx key)
            let vt = (checker::resolve lx.ctx val)
            let dst = (ir::fresh_temp lx.b (irt (TMap key: kt val: vt)))
            do (ir::emit lx.b (IMapNew dst: dst key: (irt kt) val: (irt vt)))
            return dst
        case (ERef place)
            do (panic "lower: (ref ...) not supported yet")
        case (EFunc params ret has_ret body)
            return (lower_funclit lx vs ts e params ret has_ret body)
    end
    return ImmUnit
end

func lower_name (lx LX) (vs {str IVal}) (ts {str Binding}) (id str) -> IVal
    if (map_has vs id)
        let v = vs[id]
        if (iv_is_boxed v)
            let vty = (irt_ptr_inner (iv_irtype v))
            let dst = (ir::fresh_temp lx.b vty)
            do (ir::emit lx.b (ILoad dst: dst ptr: v ty: vty))
            return dst
        end
        return v
    end
    # a module-level const used as a value: inline its initializer expression. The
    # backends have no global-const storage; the interpreter evaluates consts
    # eagerly, so inlining at each use keeps the three paths in agreement.
    if (map_has lx.ctx.cur.consts id)
        for d in lx.ctx.cur.decls
            match d
                case (DConst cname cty chas cexpr cexp)
                    if (strings::eq cname id)
                        return (lower_expr lx vs ts cexpr lx.ctx.cur.consts[id])
                    end
                else
                    pass
            end
        end
    end
    let ft = (checker::check_expr lx.ctx (EName ident: id) ts TNone)
    # a nullary sum variant constructed bare (e.g. `Leaf`)
    if (t_is_sum ft)
        return (lower_sum_lit lx vs ts ft id (vec Field))
    end
    # a top-level function used as a value -> a closure wrapping a thunk
    if (t_is_func ft)
        return (func_value lx (callee_mangle lx (EName ident: id)) ft)
    end
    do (panic (strings::concat "lower: cannot use as a value: " id))
    return ImmUnit
end

# A top-level/imported function used as a value: a closure whose code pointer is
# a generated thunk (drops the env arg) and whose env is null.
func func_value (lx LX) (mname str) (ft Type) -> IVal
    set lx.irm.thunks[mname] = ft
    let dst = (ir::fresh_temp lx.b (irt ft))
    do (ir::emit lx.b (IMakeClosure dst: dst fn: (strings::concat mname "__thunk") env: (ImmNull ty: (env_ty))))
    return dst
end

func lower_path (lx LX) (ts {str Binding}) (parts {str}) -> IVal
    if (== (len parts) 2u64)
        let e0 = parts[0]
        let e1 = parts[1]
        # local enum  Enum::Variant
        if (map_has lx.ctx.cur.enums e0)
            let idx = (index_of lx.ctx.cur.enums[e0] e1)
            let dst = (ir::fresh_temp lx.b (irt (TEnum name: e0)))
            do (ir::emit lx.b (IEnumConst dst: dst enum_name: e0 variant: e1 intval: idx))
            return dst
        end
        # imported enum
        for alias in (map_keys lx.ctx.cur.imported)
            let mname = lx.ctx.cur.imported[alias]
            if (map_has lx.ctx.sigs mname)
                let osig = lx.ctx.sigs[mname]
                if (map_has osig.enums e0)
                    let idx = (index_of osig.enums[e0] e1)
                    let dst = (ir::fresh_temp lx.b (irt (TEnum name: e0)))
                    do (ir::emit lx.b (IEnumConst dst: dst enum_name: e0 variant: e1 intval: idx))
                    return dst
                end
            end
        end
    end
    # a module function used as a value -> a closure wrapping a thunk
    let ft = (checker::check_expr lx.ctx (EPath parts: parts) ts TNone)
    if (and (== (len parts) 2u64) (t_is_func ft))
        return (func_value lx (mangle parts[0] parts[1]) ft)
    end
    do (panic "lower: cannot lower path as a value")
    return ImmUnit
end

# The source Type carried by a TyOf IRType (closure box values are always TyOf).
func irt_source_ty (t IRType) -> Type
    match t
        case (TyOf st)
            return st
        else
            return (unit_ty)
    end
    return (unit_ty)
end

# Sort a vec of strings lexicographically (deterministic env layout, §11).
func sorted_strs (xs {str}) -> {str}
    let ks {str} = (vec str)
    for k in xs
        do (push ks k)
    end
    let i = 1u64
    while (< i (len ks))
        let j = i
        while (and (> j 0u64) (str_lt ks[j] ks[(- j 1u64)]))
            let tmp = ks[j]
            set ks[j] = ks[(- j 1u64)]
            set ks[(- j 1u64)] = tmp
            set j = (- j 1u64)
        end
        set i = (+ i 1)
    end
    return ks
end

# Lower an anonymous-function literal to a closure value (closure conversion):
# captured boxed locals go into a heap environment, the body is lifted to a
# top-level function taking that environment, and the value is a {fn, env} pair.
func lower_funclit (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (params {Param}) (ret Ty) (has_ret bool) (body {Stmt}) -> IVal
    # captures = the lambda's free vars that are bound in the enclosing scope,
    # in a deterministic (sorted) order so the env layout is stable.
    let fr = (lambda_free e)
    let rawcaps {str} = (vec str)
    for nm in (map_keys fr)
        if (map_has vs nm)
            do (push rawcaps nm)
        end
    end
    let caps = (sorted_strs rawcaps)
    # every captured local must be boxed (its vs entry is a Ptr). A non-boxed
    # capture is a for-loop variable, whose per-iteration binding closure
    # conversion can't share through a single cell.
    let cap_tys {IRType} = (vec IRType)
    let i = 0u64
    while (< i (len caps))
        let cv = vs[caps[i]]
        if (not (iv_is_boxed cv))
            do (panic (strings::concat "lower: cannot capture a for-loop variable in a closure: " caps[i]))
        end
        do (push cap_tys (irt_ptr_inner (iv_irtype cv)))
        set i = (+ i 1)
    end
    # build the environment (array of box handles), or null when there are none
    let env = (ImmNull ty: (env_ty))
    if (> (len caps) 0u64)
        let envt = (ir::fresh_temp lx.b (env_ty))
        do (ir::emit lx.b (IEnvNew dst: envt n: (as (len caps) i64)))
        set i = 0u64
        while (< i (len caps))
            do (ir::emit lx.b (IEnvStore env: envt idx: (as i i64) ptr: vs[caps[i]]))
            set i = (+ i 1)
        end
        set env = envt
    end
    # resolved closure function type
    let ptys {Type} = (vec Type)
    set i = 0u64
    while (< i (len params))
        do (push ptys (checker::resolve lx.ctx params[i].ty))
        set i = (+ i 1)
    end
    let rty = (unit_ty)
    if has_ret
        set rty = (checker::resolve lx.ctx ret)
    end
    let ft = (TFunc params: ptys ret: rty)
    set lx.lamn[0] = (+ lx.lamn[0] 1)
    # The "0lambda" component starts with a digit, which no user identifier can
    # (is_ident_start = letter or '_'), so the lifted symbol cl_<mod>__0lambdaN
    # can never collide with a user function named lambdaN.
    let lname = (mangle lx.ctx.cur.name (strings::concat "0lambda" (convert::int_to_str lx.lamn[0])))
    let dst = (ir::fresh_temp lx.b (irt ft))
    do (ir::emit lx.b (IMakeClosure dst: dst fn: lname env: env))
    do (lower_lambda_body lx lname params body caps cap_tys ptys rty)
    return dst
end

# Lower a lifted lambda body into its own IRFunc (first param = the env handle).
func lower_lambda_body (lx LX) (lname str) (params {Param}) (body {Stmt}) (caps {str}) (cap_tys {IRType}) (ptys {Type}) (rty Type) -> unit
    let saved_b = lx.b
    let saved_ret = lx.ret
    let saved_cap = lx.captured
    let saved_uq = lx.uq[0]
    let irparams {IRParam} = (vec IRParam)
    do (push irparams (IRParam name: "__env" ty: (env_ty)))
    let i = 0u64
    while (< i (len params))
        do (push irparams (IRParam name: params[i].name ty: (irt ptys[i])))
        set i = (+ i 1)
    end
    set lx.b = (ir::new_builder lname irparams (irt rty))
    set lx.ret = rty
    set lx.uq[0] = 0i64
    set lx.captured = (compute_captured body)
    let vscope {str IVal} = (map str IVal)
    let tscope {str Binding} = (map str Binding)
    # captured outer vars: load each box handle out of the env (stays boxed)
    set i = 0u64
    while (< i (len caps))
        let vty = cap_tys[i]
        let ptr = (ir::fresh_temp lx.b (Ptr p: vty))
        do (ir::emit lx.b (IEnvLoad dst: ptr env: (Local name: "__env" ty: (env_ty)) idx: (as i i64) ty: vty))
        set vscope[caps[i]] = ptr
        set tscope[caps[i]] = (Binding ty: (irt_source_ty vty) mutable: true)
        set i = (+ i 1)
    end
    # the lambda's own params (boxed if captured by a nested lambda)
    set i = 0u64
    while (< i (len params))
        let pname = params[i].name
        let pty = ptys[i]
        if (map_has lx.captured pname)
            let box = (make_box lx (irt pty) (Local name: pname ty: (irt pty)) true)
            set vscope[pname] = box
        else
            set vscope[pname] = (Local name: pname ty: (irt pty))
        end
        set tscope[pname] = (Binding ty: pty mutable: true)
        set i = (+ i 1)
    end
    do (lower_block lx vscope tscope body)
    if (not (ir::cur_terminated lx.b))
        if (t_is_unit rty)
            do (ir::emit lx.b (IRet has_val: false val: ImmUnit))
        else
            set lx.irm.externs["cl_panic"] = true
            do (ir::emit lx.b (IPanic msg: (ImmStr s: "fell off the end of a value-returning function")))
        end
    end
    do (push lx.irm.funcs lx.b.fn)
    set lx.b = saved_b
    set lx.ret = saved_ret
    set lx.captured = saved_cap
    set lx.uq[0] = saved_uq
end

func operand_ty (lx LX) (ts {str Binding}) (args {Expr}) -> Type
    let i = 0u64
    while (< i (len args))
        let t = (checker::check_expr lx.ctx args[i] ts TNone)
        if (not (or (t_is_uint t) (t_is_ufloat t)))
            return t
        end
        set i = (+ i 1)
    end
    # Every operand is a bare untyped numeric literal (e.g. `(== 4 4)`): per
    # DESIGN §7.2 there is NO fallback literal type — an uninferable literal is a
    # compile error, never an implicit i32/f64. The lowerer must not invent one.
    do (panic "lower: comparison operands are untyped literals with no inferable type — annotate one (e.g. 4i64). DESIGN §7.2: no fallback literal type")
    return TNone
end

func lower_op (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (op str) (args {Expr}) (expected Type) -> IVal
    if (strings::eq op "and")
        return (lower_andor lx vs ts args false)
    end
    if (strings::eq op "or")
        return (lower_andor lx vs ts args true)
    end
    if (strings::eq op "not")
        let v = (lower_expr lx vs ts args[0] (bool_ty))
        let dst = (ir::fresh_temp lx.b (irt (bool_ty)))
        do (ir::emit lx.b (IUn dst: dst op: "not" val: v ty: (irt (bool_ty)) chk: false))
        return dst
    end
    if (is_cmp op)
        let opty = (operand_ty lx ts args)
        let lv = (lower_expr lx vs ts args[0] opty)
        let rv = (lower_expr lx vs ts args[1] opty)
        if (t_is_str opty)
            # str ==/!= is CONTENT equality; a raw handle compare would test
            # object identity. Route through the runtime, negating for !=.
            let eqd = (ir::fresh_temp lx.b (irt (bool_ty)))
            let a2 {IVal} = (vec IVal)
            do (push a2 lv)
            do (push a2 rv)
            do (ir::emit lx.b (ICall has_dst: true dst: eqd callee: "cl_strings__eq" args: a2 ty: (irt (bool_ty))))
            if (strings::eq op "!=")
                let nd = (ir::fresh_temp lx.b (irt (bool_ty)))
                do (ir::emit lx.b (IUn dst: nd op: "not" val: eqd ty: (irt (bool_ty)) chk: false))
                return nd
            end
            return eqd
        end
        let dst = (ir::fresh_temp lx.b (irt (bool_ty)))
        do (ir::emit lx.b (IBin dst: dst op: op lhs: lv rhs: rv ty: (irt opty) chk: false))
        return dst
    end
    let rty = (result_ty lx ts e expected)
    if (strings::eq op "bnot")
        let v = (lower_expr lx vs ts args[0] rty)
        let dst = (ir::fresh_temp lx.b (irt rty))
        do (ir::emit lx.b (IUn dst: dst op: "bnot" val: v ty: (irt rty) chk: lx.chk[0]))
        return dst
    end
    if (and (strings::eq op "-") (== (len args) 1u64))
        let v = (lower_expr lx vs ts args[0] rty)
        let dst = (ir::fresh_temp lx.b (irt rty))
        do (ir::emit lx.b (IUn dst: dst op: "-" val: v ty: (irt rty) chk: lx.chk[0]))
        return dst
    end
    # n-ary arithmetic / bitwise: fold left
    let acc = (lower_expr lx vs ts args[0] rty)
    let i = 1u64
    while (< i (len args))
        let v = (lower_expr lx vs ts args[i] rty)
        let dst = (ir::fresh_temp lx.b (irt rty))
        do (ir::emit lx.b (IBin dst: dst op: op lhs: acc rhs: v ty: (irt rty) chk: lx.chk[0]))
        set acc = dst
        set i = (+ i 1)
    end
    return acc
end

func lower_andor (lx LX) (vs {str IVal}) (ts {str Binding}) (args {Expr}) (short_true bool) -> IVal
    let un = (uniq lx "sc")
    let res = (ir::add_local lx.b un (irt (bool_ty)))
    let endl = (ir::fresh_label lx.b "sc_end")
    let i = 0u64
    while (< i (len args))
        let av = (lower_expr lx vs ts args[i] (bool_ty))
        do (ir::emit lx.b (IAssign place: (PLocal name: un ty: (irt (bool_ty))) src: av))
        let nxt = (ir::fresh_label lx.b "sc_nx")
        if short_true
            do (ir::emit lx.b (ICondBr cond: av then_l: endl else_l: nxt))
        else
            do (ir::emit lx.b (ICondBr cond: av then_l: nxt else_l: endl))
        end
        do (ir::new_block lx.b nxt)
        set i = (+ i 1)
    end
    do (ir::emit lx.b (IBr target: endl))
    do (ir::new_block lx.b endl)
    return res
end

func lower_call (lx LX) (vs {str IVal}) (ts {str Binding}) (callee Expr) (args {Expr}) -> IVal
    match callee
        case (EName id)
            if (strings::eq id "panic")
                let msg = (lower_expr lx vs ts args[0] (str_ty))
                set lx.irm.externs["cl_panic"] = true
                do (ir::emit lx.b (IPanic msg: msg))
                return ImmUnit
            end
            if (strings::eq id "to_str")
                let at = (checker::check_expr lx.ctx args[0] ts TNone)
                let av = (lower_expr lx vs ts args[0] TNone)
                return (lower_to_str lx vs ts av at)
            end
            if (strings::eq id "len")
                let at = (checker::check_expr lx.ctx args[0] ts TNone)
                if (t_is_str at)
                    let sv = (lower_expr lx vs ts args[0] TNone)
                    let sd = (ir::fresh_temp lx.b (irt (u64_ty)))
                    let a1 {IVal} = (vec IVal)
                    do (push a1 sv)
                    do (ir::emit lx.b (ICall has_dst: true dst: sd callee: "cl_str_len" args: a1 ty: (irt (u64_ty))))
                    return sd
                end
                if (t_is_vec at)
                    let arg = (lower_expr lx vs ts args[0] TNone)
                    let dst = (ir::fresh_temp lx.b (irt (u64_ty)))
                    do (ir::emit lx.b (IVecLen dst: dst vec: arg))
                    return dst
                end
                if (t_is_map at)
                    let arg = (lower_expr lx vs ts args[0] TNone)
                    let dst = (ir::fresh_temp lx.b (irt (u64_ty)))
                    do (ir::emit lx.b (IMapLen dst: dst map: arg))
                    return dst
                end
                if (not (t_is_array at))
                    do (panic "lower: len of unsupported type")
                end
                let arg = (lower_expr lx vs ts args[0] TNone)
                let dst = (ir::fresh_temp lx.b (irt (u64_ty)))
                do (ir::emit lx.b (IArrLen dst: dst arr: arg))
                return dst
            end
            if (strings::eq id "push")
                let vt = (checker::check_expr lx.ctx args[0] ts TNone)
                let elem = (t_elem vt)
                let vv = (lower_expr lx vs ts args[0] TNone)
                let ev = (lower_expr lx vs ts args[1] elem)
                do (ir::emit lx.b (IVecPush vec: vv val: ev elem: (irt elem)))
                return ImmUnit
            end
            if (strings::eq id "pop")
                let vt = (checker::check_expr lx.ctx args[0] ts TNone)
                let elem = (t_elem vt)
                let vv = (lower_expr lx vs ts args[0] TNone)
                let dst = (ir::fresh_temp lx.b (irt elem))
                do (ir::emit lx.b (IVecPop dst: dst vec: vv elem: (irt elem)))
                return dst
            end
            if (strings::eq id "map_has")
                let mt = (checker::check_expr lx.ctx args[0] ts TNone)
                let kty = (t_map_key mt)
                let mv = (lower_expr lx vs ts args[0] TNone)
                let kv = (lower_expr lx vs ts args[1] kty)
                let dst = (ir::fresh_temp lx.b (irt (bool_ty)))
                do (ir::emit lx.b (IMapHas dst: dst map: mv key: kv kty: (irt kty)))
                return dst
            end
            if (strings::eq id "map_del")
                let mt = (checker::check_expr lx.ctx args[0] ts TNone)
                let kty = (t_map_key mt)
                let mv = (lower_expr lx vs ts args[0] TNone)
                let kv = (lower_expr lx vs ts args[1] kty)
                do (ir::emit lx.b (IMapDel map: mv key: kv kty: (irt kty)))
                return ImmUnit
            end
            if (strings::eq id "map_keys")
                let mt = (checker::check_expr lx.ctx args[0] ts TNone)
                let kty = (t_map_key mt)
                let mv = (lower_expr lx vs ts args[0] TNone)
                let dst = (ir::fresh_temp lx.b (irt (TVec elem: kty)))
                do (ir::emit lx.b (IMapKeys dst: dst map: mv))
                return dst
            end
        case (EPath parts)
            if (strings::eq parts[0] "io")
                return (lower_io lx vs ts parts[1] args)
            end
            if (strings::eq parts[0] "reflect")
                return (lower_reflect lx vs ts parts[1] args)
            end
        else
            pass
    end
    # Direct call to a named top-level function vs. indirect call through a
    # closure value. A bare name in scope (a local) or any computed expression is
    # a closure value; a top-level name or a module path is a direct call.
    let direct = false
    match callee
        case (EName id)
            if (not (map_has vs id))
                set direct = true
            end
        case (EPath parts)
            set direct = true
        else
            pass
    end
    let ft = (checker::check_expr lx.ctx callee ts TNone)
    if (not (t_is_func ft))
        do (panic "lower: call of a non-function value")
    end
    let params = (t_func_params ft)
    let rty = (t_func_ret ft)
    if direct
        let argvals {IVal} = (vec IVal)
        let i = 0u64
        while (< i (len args))
            let pexp = TNone
            if (< i (len params))
                set pexp = params[i]
            end
            do (push argvals (lower_expr lx vs ts args[i] pexp))
            set i = (+ i 1)
        end
        let mname = (callee_mangle lx callee)
        if (t_is_unit rty)
            do (ir::emit lx.b (ICall has_dst: false dst: ImmUnit callee: mname args: argvals ty: (irt rty)))
            return ImmUnit
        end
        let dst = (ir::fresh_temp lx.b (irt rty))
        do (ir::emit lx.b (ICall has_dst: true dst: dst callee: mname args: argvals ty: (irt rty)))
        return dst
    end
    # indirect: evaluate the callee to a closure value first (left-to-right), then
    # the args, then call through the closure's {fn, env} pair.
    let clos = (lower_expr lx vs ts callee TNone)
    let argvals {IVal} = (vec IVal)
    let irptys {IRType} = (vec IRType)
    let i = 0u64
    while (< i (len args))
        let pexp = TNone
        if (< i (len params))
            set pexp = params[i]
        end
        do (push argvals (lower_expr lx vs ts args[i] pexp))
        set i = (+ i 1)
    end
    set i = 0u64
    while (< i (len params))
        do (push irptys (irt params[i]))
        set i = (+ i 1)
    end
    if (t_is_unit rty)
        do (ir::emit lx.b (ICallClosure has_dst: false dst: ImmUnit clos: clos args: argvals ret: (irt rty) ptys: irptys))
        return ImmUnit
    end
    let cdst = (ir::fresh_temp lx.b (irt rty))
    do (ir::emit lx.b (ICallClosure has_dst: true dst: cdst clos: clos args: argvals ret: (irt rty) ptys: irptys))
    return cdst
end

func callee_mangle (lx LX) (callee Expr) -> str
    match callee
        case (EName id)
            if (map_has lx.callmap id)
                return lx.callmap[id]
            end
            return (mangle lx.ctx.cur.name id)
        case (EPath parts)
            return (mangle parts[0] parts[1])
        else
            do (panic "lower: unsupported call target")
    end
    return ""
end

func lower_io (lx LX) (vs {str IVal}) (ts {str Binding}) (fn str) (args {Expr}) -> IVal
    # io::print(x) == print(to_str(x)): one formatter (DESIGN §5.5).
    let i = 0u64
    while (< i (len args))
        let v = (lower_expr lx vs ts args[i] TNone)
        let t = (checker::check_expr lx.ctx args[i] ts TNone)
        let s = (lower_to_str lx vs ts v t)
        set lx.irm.externs["cl_print_str"] = true
        let a1 {IVal} = (vec IVal)
        do (push a1 s)
        do (ir::emit lx.b (ICall has_dst: false dst: ImmUnit callee: "cl_print_str" args: a1 ty: (irt (unit_ty))))
        set i = (+ i 1)
    end
    if (strings::eq fn "println")
        set lx.irm.externs["cl_print_nl"] = true
        do (ir::emit lx.b (ICall has_dst: false dst: ImmUnit callee: "cl_print_nl" args: (vec IVal) ty: (irt (unit_ty))))
    end
    return ImmUnit
end

# The bare name of a "mod::Name" qualified type identity (for struct display).
func bare_name (qn str) -> str
    let cs = (strings::chars qn)
    let i = 0u64
    while (< i (len cs))
        if (and (== cs[i] ':') (and (< (+ i 1u64) (len cs)) (== cs[(+ i 1u64)] ':')))
            return (strings::substr qn (+ i 2u64) (- (len cs) (+ i 2u64)))
        end
        set i = (+ i 1u64)
    end
    return qn
end

# The module prefix of a "mod::Name" qualified identity ("" if unqualified).
func qual_module (qn str) -> str
    let cs = (strings::chars qn)
    let i = 0u64
    while (< i (len cs))
        if (and (== cs[i] ':') (and (< (+ i 1u64) (len cs)) (== cs[(+ i 1u64)] ':')))
            return (strings::substr qn 0u64 i)
        end
        set i = (+ i 1u64)
    end
    return ""
end

# --------------------------------------------------------------------------- #
# Sum types (DESIGN §5.3): a sum value is a handle to a heap object laid out as
# { int32 tag; payload... }, one C struct per variant (cl_struct_<mod>__<Sum>__
# <Variant>) plus a tag-only header struct (cl_struct_<mod>__<Sum>). The tag is
# the variant's index in the sum's declared variant order.
# --------------------------------------------------------------------------- #

# The qualified name of a variant's heap-struct identity: "mod::Sum__Variant".
func variant_qual (sumq str) (variant str) -> str
    return (strings::concat sumq (strings::concat "__" variant))
end

# The variant's tag = its index in the sum's declared variant list.
func sum_tag (lx LX) (sumq str) (variant str) -> i64
    let m = (qual_module sumq)
    let b = (bare_name sumq)
    if (map_has lx.ctx.sigs m)
        let sig = lx.ctx.sigs[m]
        if (map_has sig.sum_variants b)
            return (index_of sig.sum_variants[b] variant)
        end
    end
    do (panic (strings::concat "lower: unknown sum variant " variant))
    return 0i64
end

# The variant's payload field defs (name + resolved type), in declaration order.
func variant_fields (lx LX) (sumq str) (variant str) -> {FieldDef}
    let m = (qual_module sumq)
    if (map_has lx.ctx.sigs m)
        let sig = lx.ctx.sigs[m]
        if (map_has sig.variants variant)
            return sig.variants[variant].fields
        end
    end
    do (panic (strings::concat "lower: unknown sum variant " variant))
    return (vec FieldDef)
end

# --------------------------------------------------------------------------- #
# Reflection (DESIGN §5.6 runtime type descriptors). reflect::typeof(x) builds a
# TypeInfo record from x's STATIC type (precise width, qualified user-type name);
# reflect::variant_of(x) yields the live variant of a sum/enum value. The
# descriptor strings/kinds are produced identically here and in the interpreter.
# --------------------------------------------------------------------------- #

# Canonical type name for a descriptor (matches the interpreter's _type_descr).
func ti_name (t Type) -> str
    match t
        case (TInt n)
            return n
        case (TFloat n)
            return n
        case (TPrim n)
            return n
        case (TStruct qn)
            return qn
        case (TEnum qn)
            return qn
        case (TSum qn)
            return qn
        case (TArray e)
            return "array"
        case (TVec e)
            return "vec"
        case (TMap k v)
            return "map"
        case (TFunc p r)
            return "func"
        else
            return "unknown"
    end
    return "unknown"
end

func ti_kind (t Type) -> str
    match t
        case (TInt n)
            return "int"
        case (TFloat n)
            return "float"
        case (TPrim n)
            return n
        case (TStruct qn)
            return "struct"
        case (TEnum qn)
            return "enum"
        case (TSum qn)
            return "sum"
        case (TArray e)
            return "array"
        case (TVec e)
            return "vec"
        case (TMap k v)
            return "map"
        case (TFunc p r)
            return "func"
        else
            return "unknown"
    end
    return "unknown"
end

# enum/sum variant names for the descriptor (declaration order); empty otherwise.
func type_variant_names (lx LX) (t Type) -> {str}
    match t
        case (TEnum qn)
            let m = (qual_module qn)
            let b = (bare_name qn)
            if (and (map_has lx.ctx.sigs m) (map_has lx.ctx.sigs[m].enums b))
                return lx.ctx.sigs[m].enums[b]
            end
        case (TSum qn)
            let m = (qual_module qn)
            let b = (bare_name qn)
            if (and (map_has lx.ctx.sigs m) (map_has lx.ctx.sigs[m].sum_variants b))
                return lx.ctx.sigs[m].sum_variants[b]
            end
        else
            pass
    end
    return (vec str)
end

# Build a reflect::TypeInfo value for the static type `t`.
func build_typeinfo (lx LX) (t Type) -> IVal
    let nm = (ti_name t)
    let kd = (ti_kind t)
    # struct field names (declaration order); empty for non-structs
    let fnames {IVal} = (vec IVal)
    if (t_is_struct t)
        let sl = (checker::struct_fields lx.ctx (t_struct_name t))
        let i = 0u64
        while (< i (len sl.fields))
            do (push fnames (ImmStr s: sl.fields[i].name))
            set i = (+ i 1)
        end
    end
    let fvec = (ir::fresh_temp lx.b (irt (TVec elem: (str_ty))))
    do (ir::emit lx.b (IVecLit dst: fvec elem: (irt (str_ty)) elems: fnames))
    # enum/sum variant names
    let vnames {IVal} = (vec IVal)
    let vs2 = (type_variant_names lx t)
    let j = 0u64
    while (< j (len vs2))
        do (push vnames (ImmStr s: vs2[j]))
        set j = (+ j 1)
    end
    let vvec = (ir::fresh_temp lx.b (irt (TVec elem: (str_ty))))
    do (ir::emit lx.b (IVecLit dst: vvec elem: (irt (str_ty)) elems: vnames))
    let dst = (ir::fresh_temp lx.b (irt (TStruct name: "reflect::TypeInfo")))
    let fld {str} = (vec str)
    do (push fld "name")
    do (push fld "kind")
    do (push fld "fields")
    do (push fld "variants")
    let fvals {IVal} = (vec IVal)
    do (push fvals (ImmStr s: nm))
    do (push fvals (ImmStr s: kd))
    do (push fvals fvec)
    do (push fvals vvec)
    do (ir::emit lx.b (IStructNew dst: dst struct_name: "reflect::TypeInfo" fnames: fld fvals: fvals))
    return dst
end

# reflect::variant_of(x): the live variant name for a sum/enum value, else "".
func lower_variant_of (lx LX) (t Type) (v IVal) -> IVal
    let resn = (uniq lx "vof")
    let res = (ir::add_local lx.b resn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: "")))
    if (t_is_sum t)
        let names = (type_variant_names lx t)
        let tagv = (ir::fresh_temp lx.b (irt (TInt name: "i32")))
        do (ir::emit lx.b (ISumTag dst: tagv sum: v sum_qual: (t_sum_name t)))
        let i = 0u64
        while (< i (len names))
            let c = (ir::fresh_temp lx.b (irt (bool_ty)))
            do (ir::emit lx.b (IBin dst: c op: "==" lhs: tagv rhs: (ImmInt val: (as i i64) ty: (irt (TInt name: "i32"))) ty: (irt (TInt name: "i32")) chk: false))
            let yes = (ir::fresh_label lx.b "vof_y")
            let no = (ir::fresh_label lx.b "vof_n")
            do (ir::emit lx.b (ICondBr cond: c then_l: yes else_l: no))
            do (ir::new_block lx.b yes)
            do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: names[i])))
            do (ir::emit lx.b (IBr target: no))
            do (ir::new_block lx.b no)
            set i = (+ i 1)
        end
        return res
    end
    match t
        case (TEnum qn)
            let names = (type_variant_names lx t)
            let i = 0u64
            while (< i (len names))
                let c = (ir::fresh_temp lx.b (irt (bool_ty)))
                do (ir::emit lx.b (IBin dst: c op: "==" lhs: v rhs: (ImmInt val: (as i i64) ty: (irt t)) ty: (irt t) chk: false))
                let yes = (ir::fresh_label lx.b "vof_y")
                let no = (ir::fresh_label lx.b "vof_n")
                do (ir::emit lx.b (ICondBr cond: c then_l: yes else_l: no))
                do (ir::new_block lx.b yes)
                do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: names[i])))
                do (ir::emit lx.b (IBr target: no))
                do (ir::new_block lx.b no)
                set i = (+ i 1)
            end
        else
            pass
    end
    return res
end

func lower_reflect (lx LX) (vs {str IVal}) (ts {str Binding}) (fn str) (args {Expr}) -> IVal
    if (strings::eq fn "typeof")
        let t = (checker::check_expr lx.ctx args[0] ts TNone)
        # evaluate the argument for side-effect parity with the interpreter, then
        # discard the value (typeof reflects the static type, not the value).
        let ign = (lower_expr lx vs ts args[0] t)
        return (build_typeinfo lx t)
    end
    if (strings::eq fn "variant_of")
        let t = (checker::check_expr lx.ctx args[0] ts TNone)
        let v = (lower_expr lx vs ts args[0] t)
        return (lower_variant_of lx t v)
    end
    do (panic (strings::concat "lower: unknown reflect intrinsic " fn))
    return ImmUnit
end

# --------------------------------------------------------------------------- #
# to_str (DESIGN §5.5) — the sole value formatter: io::print is print(to_str(x)).
# User types (struct/enum) dispatch to a synthesized (or user-overridden) per-type
# `<Type>_to_str` function; scalars/containers are inlined.
# --------------------------------------------------------------------------- #

# concat(a, b) -> fresh str temp
func ts_concat (lx LX) (a IVal) (b IVal) -> IVal
    let dst = (ir::fresh_temp lx.b (irt (str_ty)))
    let args {IVal} = (vec IVal)
    do (push args a)
    do (push args b)
    do (ir::emit lx.b (ICall has_dst: true dst: dst callee: "cl_strings__concat" args: args ty: (irt (str_ty))))
    return dst
end

# acc(local `accn`) = concat(acc, piece)
func ts_app (lx LX) (accn str) (acc IVal) (piece IVal) -> unit
    let n = (ts_concat lx acc piece)
    do (ir::emit lx.b (IAssign place: (PLocal name: accn ty: (irt (str_ty))) src: n))
end

# emit a single-arg ICall returning a str
func ts_call1 (lx LX) (sym str) (arg IVal) -> IVal
    let dst = (ir::fresh_temp lx.b (irt (str_ty)))
    let args {IVal} = (vec IVal)
    do (push args arg)
    do (ir::emit lx.b (ICall has_dst: true dst: dst callee: sym args: args ty: (irt (str_ty))))
    return dst
end

func lower_to_str (lx LX) (vs {str IVal}) (ts {str Binding}) (iv IVal) (t Type) -> IVal
    match t
        case (TInt n)
            if (== (strings::chars n)[0] 'i')
                let c = (ir::fresh_temp lx.b (irt (TInt name: "i64")))
                do (ir::emit lx.b (ICast dst: c val: iv toty: (irt (TInt name: "i64"))))
                return (ts_call1 lx "cl_convert__int_to_str" c)
            end
            let c = (ir::fresh_temp lx.b (irt (u64_ty)))
            do (ir::emit lx.b (ICast dst: c val: iv toty: (irt (u64_ty))))
            return (ts_call1 lx "cl_u64_to_str" c)
        case (TFloat n)
            let c = (ir::fresh_temp lx.b (irt (TFloat name: "f64")))
            do (ir::emit lx.b (ICast dst: c val: iv toty: (irt (TFloat name: "f64"))))
            return (ts_call1 lx "cl_f64_to_str" c)
        case (TPrim n)
            if (strings::eq n "bool")
                return (ts_call1 lx "cl_bool_to_str" iv)
            elsif (strings::eq n "str")
                return iv
            elsif (strings::eq n "char")
                return (ts_call1 lx "cl_strings__from_char" iv)
            elsif (strings::eq n "unit")
                return (ImmStr s: "unit")
            else
                do (panic "lower: to_str of this type unsupported")
            end
        case (TStruct nm)
            # call the type's (autogenerated or user-overridden) to_str function
            return (ts_call1 lx (to_str_sym nm) iv)
        case (TArray e)
            return (lts_seq lx vs ts iv t "[" "]")
        case (TVec e)
            return (lts_seq lx vs ts iv t "{" "}")
        case (TMap k v)
            return (lts_map lx vs ts iv t)
        case (TEnum nm)
            return (ts_call1 lx (to_str_sym nm) iv)
        case (TSum nm)
            return (ts_call1 lx (to_str_sym nm) iv)
        case (TFunc p r)
            # DESIGN §5.5: a closure renders as the opaque token "<closure>".
            return (ImmStr s: "<closure>")
        else
            do (panic "lower: to_str of this type unsupported")
    end
    return (ImmStr s: "")
end

# if (idx > 0) acc = concat(acc, " ")
func lts_sep (lx LX) (accn str) (acc IVal) (idx IVal) -> unit
    let c = (ir::fresh_temp lx.b (irt (bool_ty)))
    do (ir::emit lx.b (IBin dst: c op: ">" lhs: idx rhs: (ImmInt val: 0i64 ty: (irt (u64_ty))) ty: (irt (u64_ty)) chk: false))
    let yes = (ir::fresh_label lx.b "tsep_y")
    let no = (ir::fresh_label lx.b "tsep_n")
    do (ir::emit lx.b (ICondBr cond: c then_l: yes else_l: no))
    do (ir::new_block lx.b yes)
    do (ts_app lx accn acc (ImmStr s: " "))
    do (ir::emit lx.b (IBr target: no))
    do (ir::new_block lx.b no)
end

func lts_seq (lx LX) (vs {str IVal}) (ts {str Binding}) (iv IVal) (t Type) (openb str) (closeb str) -> IVal
    let is_v = (t_is_vec t)
    let elem = (t_elem t)
    let accn = (uniq lx "tsacc")
    let acc = (ir::add_local lx.b accn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: accn ty: (irt (str_ty))) src: (ImmStr s: openb)))
    let idxn = (uniq lx "tsi")
    let idx = (ir::add_local lx.b idxn (irt (u64_ty)))
    let n = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: (ImmInt val: 0i64 ty: (irt (u64_ty)))))
    if is_v
        do (ir::emit lx.b (IVecLen dst: n vec: iv))
    else
        do (ir::emit lx.b (IArrLen dst: n arr: iv))
    end
    let head = (ir::fresh_label lx.b "tsq_head")
    let bodyl = (ir::fresh_label lx.b "tsq_body")
    let post = (ir::fresh_label lx.b "tsq_post")
    let fin = (ir::fresh_label lx.b "tsq_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    let cond = (ir::fresh_temp lx.b (irt (bool_ty)))
    do (ir::emit lx.b (IBin dst: cond op: "<" lhs: idx rhs: n ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (ICondBr cond: cond then_l: bodyl else_l: fin))
    do (ir::new_block lx.b bodyl)
    do (lts_sep lx accn acc idx)
    let elemv = (ir::fresh_temp lx.b (irt elem))
    if is_v
        do (ir::emit lx.b (IVecGet dst: elemv vec: iv idx: idx ty: (irt elem)))
    else
        do (ir::emit lx.b (IArrGet dst: elemv arr: iv idx: idx ty: (irt elem)))
    end
    let es = (lower_to_str lx vs ts elemv elem)
    do (ts_app lx accn acc es)
    do (ir::emit lx.b (IBr target: post))
    do (ir::new_block lx.b post)
    let nxt = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IBin dst: nxt op: "+" lhs: idx rhs: (ImmInt val: 1i64 ty: (irt (u64_ty))) ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: nxt))
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b fin)
    do (ts_app lx accn acc (ImmStr s: closeb))
    return acc
end

func lts_map (lx LX) (vs {str IVal}) (ts {str Binding}) (iv IVal) (t Type) -> IVal
    let kty = (t_map_key t)
    let vty = (t_map_val t)
    let accn = (uniq lx "tsmacc")
    let acc = (ir::add_local lx.b accn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: accn ty: (irt (str_ty))) src: (ImmStr s: "{")))
    let keys = (ir::fresh_temp lx.b (irt (TVec elem: kty)))
    do (ir::emit lx.b (IMapKeys dst: keys map: iv))
    let idxn = (uniq lx "tsmi")
    let idx = (ir::add_local lx.b idxn (irt (u64_ty)))
    let n = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: (ImmInt val: 0i64 ty: (irt (u64_ty)))))
    do (ir::emit lx.b (IVecLen dst: n vec: keys))
    let head = (ir::fresh_label lx.b "tsm_head")
    let bodyl = (ir::fresh_label lx.b "tsm_body")
    let post = (ir::fresh_label lx.b "tsm_post")
    let fin = (ir::fresh_label lx.b "tsm_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    let cond = (ir::fresh_temp lx.b (irt (bool_ty)))
    do (ir::emit lx.b (IBin dst: cond op: "<" lhs: idx rhs: n ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (ICondBr cond: cond then_l: bodyl else_l: fin))
    do (ir::new_block lx.b bodyl)
    do (lts_sep lx accn acc idx)
    let kv = (ir::fresh_temp lx.b (irt kty))
    do (ir::emit lx.b (IVecGet dst: kv vec: keys idx: idx ty: (irt kty)))
    let ks = (lower_to_str lx vs ts kv kty)
    do (ts_app lx accn acc ks)
    do (ts_app lx accn acc (ImmStr s: ": "))
    let vv = (ir::fresh_temp lx.b (irt vty))
    do (ir::emit lx.b (IMapGet dst: vv map: iv key: kv kty: (irt kty) vty: (irt vty)))
    let vstr = (lower_to_str lx vs ts vv vty)
    do (ts_app lx accn acc vstr)
    do (ir::emit lx.b (IBr target: post))
    do (ir::new_block lx.b post)
    let nxt = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IBin dst: nxt op: "+" lhs: idx rhs: (ImmInt val: 1i64 ty: (irt (u64_ty))) ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: nxt))
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b fin)
    do (ts_app lx accn acc (ImmStr s: "}"))
    return acc
end

func lts_struct (lx LX) (vs {str IVal}) (ts {str Binding}) (iv IVal) (t Type) -> IVal
    let qn = (t_struct_name t)
    let sl = (checker::struct_fields lx.ctx qn)
    let accn = (uniq lx "tssacc")
    let acc = (ir::add_local lx.b accn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: accn ty: (irt (str_ty))) src: (ImmStr s: "(")))
    do (ts_app lx accn acc (ImmStr s: (bare_name qn)))
    do (ts_app lx accn acc (ImmStr s: " "))
    let i = 0u64
    while (< i (len sl.fields))
        if (> i 0u64)
            do (ts_app lx accn acc (ImmStr s: " "))
        end
        let fd = sl.fields[i]
        do (ts_app lx accn acc (ImmStr s: (strings::concat fd.name ": ")))
        let fv = (ir::fresh_temp lx.b (irt fd.ty))
        do (ir::emit lx.b (ILoadField dst: fv base: iv field: fd.name ty: (irt fd.ty)))
        let fs = (lower_to_str lx vs ts fv fd.ty)
        do (ts_app lx accn acc fs)
        set i = (+ i 1)
    end
    do (ts_app lx accn acc (ImmStr s: ")"))
    return acc
end

# Enum value -> "Name::Variant" (bare enum name + variant), built inline as the
# body of the synthesized to_str function.
func lts_enum (lx LX) (iv IVal) (t Type) (ename str) (variants {str}) -> IVal
    let resn = (uniq lx "tseres")
    let res = (ir::add_local lx.b resn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: (strings::concat ename "::?"))))
    let i = 0u64
    while (< i (len variants))
        let c = (ir::fresh_temp lx.b (irt (bool_ty)))
        do (ir::emit lx.b (IBin dst: c op: "==" lhs: iv rhs: (ImmInt val: (as i i64) ty: (irt t)) ty: (irt t) chk: false))
        let yes = (ir::fresh_label lx.b "ev_y")
        let no = (ir::fresh_label lx.b "ev_n")
        do (ir::emit lx.b (ICondBr cond: c then_l: yes else_l: no))
        do (ir::new_block lx.b yes)
        do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: (strings::concat ename (strings::concat "::" variants[i])))))
        do (ir::emit lx.b (IBr target: no))
        do (ir::new_block lx.b no)
        set i = (+ i 1)
    end
    return res
end

# "mod::Name" -> the mangled to_str symbol cl_<mod>__<Name>_to_str.
func to_str_sym (qn str) -> str
    let cs = (strings::chars qn)
    let i = 0u64
    while (< i (len cs))
        if (and (== cs[i] ':') (and (< (+ i 1u64) (len cs)) (== cs[(+ i 1u64)] ':')))
            let md = (strings::substr qn 0u64 i)
            let nm = (strings::substr qn (+ i 2u64) (- (len cs) (+ i 2u64)))
            return (mangle md (strings::concat nm "_to_str"))
        end
        set i = (+ i 1u64)
    end
    return (mangle "" (strings::concat qn "_to_str"))
end

# Synthesize `func <Name>_to_str (self T) -> str` for a struct (autogen body).
func synth_struct_to_str (lx LX) (modname str) (sname str) -> unit
    let pty = (TStruct name: (qual modname sname))
    let params {IRParam} = (vec IRParam)
    do (push params (IRParam name: "self" ty: (irt pty)))
    set lx.b = (ir::new_builder (mangle modname (strings::concat sname "_to_str")) params (irt (str_ty)))
    set lx.uq[0] = 0i64
    set lx.captured = (map str bool)
    let pv = (Local name: "self" ty: (irt pty))
    let evs {str IVal} = (map str IVal)
    let ets {str Binding} = (map str Binding)
    let s = (lts_struct lx evs ets pv pty)
    do (ir::emit lx.b (IRet has_val: true val: s))
    do (push lx.irm.funcs lx.b.fn)
end

# Synthesize `func <Name>_to_str (self E) -> str` for an enum (variant switch).
func synth_enum_to_str (lx LX) (modname str) (ename str) (variants {str}) -> unit
    let ety = (TEnum name: (qual modname ename))
    let params {IRParam} = (vec IRParam)
    do (push params (IRParam name: "self" ty: (irt ety)))
    set lx.b = (ir::new_builder (mangle modname (strings::concat ename "_to_str")) params (irt (str_ty)))
    set lx.uq[0] = 0i64
    set lx.captured = (map str bool)
    let pv = (Local name: "self" ty: (irt ety))
    let s = (lts_enum lx pv ety ename variants)
    do (ir::emit lx.b (IRet has_val: true val: s))
    do (push lx.irm.funcs lx.b.fn)
end

# Sum value -> "(Variant f: <to_str> ...)", nullary "(Variant)" — a tag switch
# matching the interpreter's SumV display (no sum-type name, just the variant).
func lts_sum (lx LX) (vs {str IVal}) (ts {str Binding}) (iv IVal) (sumq str) (variants {Variant}) -> IVal
    let resn = (uniq lx "tssres")
    let res = (ir::add_local lx.b resn (irt (str_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: (ImmStr s: "(?)")))
    let tagv = (ir::fresh_temp lx.b (irt (TInt name: "i32")))
    do (ir::emit lx.b (ISumTag dst: tagv sum: iv sum_qual: sumq))
    let i = 0u64
    while (< i (len variants))
        let vr = variants[i]
        let c = (ir::fresh_temp lx.b (irt (bool_ty)))
        do (ir::emit lx.b (IBin dst: c op: "==" lhs: tagv rhs: (ImmInt val: (as i i64) ty: (irt (TInt name: "i32"))) ty: (irt (TInt name: "i32")) chk: false))
        let yes = (ir::fresh_label lx.b "sv_y")
        let no = (ir::fresh_label lx.b "sv_n")
        do (ir::emit lx.b (ICondBr cond: c then_l: yes else_l: no))
        do (ir::new_block lx.b yes)
        let accn = (uniq lx "svacc")
        let acc = (ir::add_local lx.b accn (irt (str_ty)))
        do (ir::emit lx.b (IAssign place: (PLocal name: accn ty: (irt (str_ty))) src: (ImmStr s: (strings::concat "(" vr.name))))
        let vq = (variant_qual sumq vr.name)
        let defs = (variant_fields lx sumq vr.name)
        let j = 0u64
        while (< j (len defs))
            do (ts_app lx accn acc (ImmStr s: (strings::concat " " (strings::concat defs[j].name ": "))))
            let fv = (ir::fresh_temp lx.b (irt defs[j].ty))
            do (ir::emit lx.b (ISumField dst: fv sum: iv variant_qual: vq field: defs[j].name ty: (irt defs[j].ty)))
            let fs = (lower_to_str lx vs ts fv defs[j].ty)
            do (ts_app lx accn acc fs)
            set j = (+ j 1)
        end
        do (ts_app lx accn acc (ImmStr s: ")"))
        do (ir::emit lx.b (IAssign place: (PLocal name: resn ty: (irt (str_ty))) src: acc))
        do (ir::emit lx.b (IBr target: no))
        do (ir::new_block lx.b no)
        set i = (+ i 1)
    end
    return res
end

# Synthesize `func <Name>_to_str (self S) -> str` for a sum type (tag switch).
func synth_sum_to_str (lx LX) (modname str) (sname str) (variants {Variant}) -> unit
    let sty = (TSum name: (qual modname sname))
    let params {IRParam} = (vec IRParam)
    do (push params (IRParam name: "self" ty: (irt sty)))
    set lx.b = (ir::new_builder (mangle modname (strings::concat sname "_to_str")) params (irt (str_ty)))
    set lx.uq[0] = 0i64
    set lx.captured = (map str bool)
    let pv = (Local name: "self" ty: (irt sty))
    let evs {str IVal} = (map str IVal)
    let ets {str Binding} = (map str Binding)
    let s = (lts_sum lx evs ets pv (qual modname sname) variants)
    do (ir::emit lx.b (IRet has_val: true val: s))
    do (push lx.irm.funcs lx.b.fn)
end

# Lower a sum-variant constructor literal `(Variant f: v ...)` to a tagged heap
# object. Nullary variants are constructed via lower_name (bare name).
func lower_sum_lit (lx LX) (vs {str IVal}) (ts {str Binding}) (st Type) (vname str) (fields {Field}) -> IVal
    let sumq = (t_sum_name st)
    let tag = (sum_tag lx sumq vname)
    let defs = (variant_fields lx sumq vname)
    let vq = (variant_qual sumq vname)
    let fnames {str} = (vec str)
    let fvals {IVal} = (vec IVal)
    let i = 0u64
    while (< i (len defs))
        let fv = (find_and_lower lx vs ts fields defs[i].name defs[i].ty)
        do (push fnames defs[i].name)
        do (push fvals fv)
        set i = (+ i 1)
    end
    let dst = (ir::fresh_temp lx.b (irt st))
    do (ir::emit lx.b (ISumNew dst: dst variant_qual: vq tag: tag fnames: fnames fvals: fvals))
    return dst
end

# Lower the value for struct field `fname` (declared type `fty`) from the
# literal's provided fields. The checker has already validated presence/types.
func find_and_lower (lx LX) (vs {str IVal}) (ts {str Binding}) (fields {Field}) (fname str) (fty Type) -> IVal
    let i = 0u64
    while (< i (len fields))
        if (strings::eq fields[i].name fname)
            return (lower_expr lx vs ts fields[i].value fty)
        end
        set i = (+ i 1)
    end
    do (panic (strings::concat "lower: missing struct field " fname))
    return ImmUnit
end

func lower_struct_lit (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (fields {Field}) -> IVal
    let st = (checker::check_expr lx.ctx e ts TNone)
    if (t_is_sum st)
        # the head resolved to a sum variant, not a struct: build a tagged object.
        let vname = ""
        match e
            case (EStruct typ fs)
                set vname = (head_name typ)
            else
                pass
        end
        return (lower_sum_lit lx vs ts st vname fields)
    end
    if (not (t_is_struct st))
        do (panic "lower: construction literal of a non-aggregate type")
    end
    let qn = (t_struct_name st)
    let sl = (checker::struct_fields lx.ctx qn)
    if (not sl.found)
        do (panic (strings::concat "lower: unknown struct " qn))
    end
    let defs = sl.fields
    let fnames {str} = (vec str)
    let fvals {IVal} = (vec IVal)
    let i = 0u64
    while (< i (len defs))
        let v = (find_and_lower lx vs ts fields defs[i].name defs[i].ty)
        do (push fnames defs[i].name)
        do (push fvals v)
        set i = (+ i 1)
    end
    let dst = (ir::fresh_temp lx.b (irt st))
    do (ir::emit lx.b (IStructNew dst: dst struct_name: qn fnames: fnames fvals: fvals))
    return dst
end

func lower_array_lit (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (elems {Expr}) (expected Type) -> IVal
    let elem = (unit_ty)
    if (t_is_array expected)
        set elem = (t_elem expected)
    else
        let at = (checker::check_expr lx.ctx e ts expected)
        if (not (t_is_array at))
            do (panic "lower: cannot infer array element type — annotate it")
        end
        set elem = (t_elem at)
    end
    let vals {IVal} = (vec IVal)
    let i = 0u64
    while (< i (len elems))
        do (push vals (lower_expr lx vs ts elems[i] elem))
        set i = (+ i 1)
    end
    let dst = (ir::fresh_temp lx.b (irt (TArray elem: elem)))
    do (ir::emit lx.b (IArrLit dst: dst elem: (irt elem) elems: vals))
    return dst
end

func lower_vec_lit (lx LX) (vs {str IVal}) (ts {str Binding}) (e Expr) (elems {Expr}) (expected Type) -> IVal
    let elem = (unit_ty)
    if (t_is_vec expected)
        set elem = (t_elem expected)
    else
        let at = (checker::check_expr lx.ctx e ts expected)
        if (not (t_is_vec at))
            do (panic "lower: cannot infer vector element type — annotate it")
        end
        set elem = (t_elem at)
    end
    let vals {IVal} = (vec IVal)
    let i = 0u64
    while (< i (len elems))
        do (push vals (lower_expr lx vs ts elems[i] elem))
        set i = (+ i 1)
    end
    let dst = (ir::fresh_temp lx.b (irt (TVec elem: elem)))
    do (ir::emit lx.b (IVecLit dst: dst elem: (irt elem) elems: vals))
    return dst
end

# Resolve an assignable place (EName / EField) to an IPlace plus its checker type.
func lower_place (lx LX) (vs {str IVal}) (ts {str Binding}) (node Expr) -> PlaceR
    match node
        case (EName id)
            let loc = vs[id]
            let pty = ts[id].ty
            if (iv_is_boxed loc)
                return (PlaceR place: (PDeref ptr: loc ty: (irt pty)) ty: pty)
            end
            return (PlaceR place: (PLocal name: (ival_name loc) ty: (irt pty)) ty: pty)
        case (EField obj field)
            let base = (lower_place lx vs ts obj)
            let fty = (checker::check_expr lx.ctx node ts TNone)
            return (PlaceR place: (PField base: base.place field: field ty: (irt fty)) ty: fty)
        case (EIndex obj index)
            # An array/vector element used as an lvalue base (e.g. `set arr[i].x = v`).
            # Both are reference-semantic, so the element address is computed from
            # the collection value (cl_array_at / cl_vec_at), not from a place.
            let bt = (checker::check_expr lx.ctx obj ts TNone)
            if (t_is_vec bt)
                let vc = (lower_expr lx vs ts obj TNone)
                let idx = (lower_expr lx vs ts index (u64_ty))
                let elem = (t_elem bt)
                return (PlaceR place: (PVecElem vec: vc idx: idx ty: (irt elem)) ty: elem)
            end
            if (not (t_is_array bt))
                # `set m[k].field = v` on a map is not supported: maps store value
                # copies, so an in-place element mutation has no faithful semantics.
                do (panic "lower: composable element assignment on a map is unsupported")
            end
            let arr = (lower_expr lx vs ts obj TNone)
            let idx = (lower_expr lx vs ts index (u64_ty))
            let elem = (t_elem bt)
            return (PlaceR place: (PArrElem arr: arr idx: idx ty: (irt elem)) ty: elem)
        else
            do (panic "lower: invalid assignment target")
    end
    return (PlaceR place: (PLocal name: "" ty: (irt (unit_ty))) ty: (unit_ty))
end

# --------------------------------------------------------------------------- #
# Statements
# --------------------------------------------------------------------------- #

func lower_block (lx LX) (vscope {str IVal}) (tscope {str Binding}) (body {Stmt}) -> unit
    let vs = (copy_iv vscope)
    let ts = (copy_bind tscope)
    for s in body
        do (lower_stmt lx vs ts s)
    end
end

func lower_stmt (lx LX) (vs {str IVal}) (ts {str Binding}) (s Stmt) -> unit
    match s
        case (SLet name ty has_ty expr mutable)
            let vty = (unit_ty)
            if has_ty
                set vty = (checker::resolve lx.ctx ty)
            else
                set vty = (concrete_ty lx ts expr)
            end
            let val = (lower_expr lx vs ts expr vty)
            if (map_has lx.captured name)
                let box = (make_box lx (irt vty) val true)
                set vs[name] = box
            else
                let un = (uniq lx name)
                let loc = (ir::add_local lx.b un (irt vty))
                do (ir::emit lx.b (IAssign place: (PLocal name: un ty: (irt vty)) src: val))
                set vs[name] = loc
            end
            set ts[name] = (Binding ty: vty mutable: mutable)
        case (SSet target expr)
            do (lower_set lx vs ts target expr)
        case (SDo call)
            let ignore = (lower_expr lx vs ts call (unit_ty))
            pass
        case (SIf branches orelse has_else)
            do (lower_if lx vs ts branches orelse has_else)
        case (SWhile cond body)
            do (lower_while lx vs ts cond body)
        case (SForNum var start stop stride has_step body)
            do (lower_fornum lx vs ts var start stop stride has_step body)
        case (SForIn var iter body)
            do (lower_forin lx vs ts var iter body)
        case (SLoop body)
            do (lower_loop lx vs ts body)
        case SBreak
            do (ir::emit lx.b (IBr target: lx.brk[(- (len lx.brk) 1u64)]))
        case SContinue
            do (ir::emit lx.b (IBr target: lx.cont[(- (len lx.cont) 1u64)]))
        case SPass
            pass
        case (SReturn expr has_expr)
            if has_expr
                let v = (lower_expr lx vs ts expr lx.ret)
                do (ir::emit lx.b (IRet has_val: true val: v))
            else
                do (ir::emit lx.b (IRet has_val: false val: ImmUnit))
            end
        case (SChecked body)
            let old = lx.chk[0]
            set lx.chk[0] = true
            do (lower_block lx vs ts body)
            set lx.chk[0] = old
        case (SMatch scrut arms orelse has_else)
            do (lower_match lx vs ts scrut arms orelse has_else)
        case (SAsm template outs ins clobbers)
            # Bind each operand variable to its (non-boxed) Local IVal. Captured
            # variables (boxed cells) are not supported as asm operands.
            let oouts {IAsmOp} = (vec IAsmOp)
            for op in outs
                let loc = vs[op.var]
                if (iv_is_boxed loc)
                    do (panic "lower: asm operand on a captured variable is unsupported")
                end
                do (push oouts (IAsmOp val: loc constraint: op.constraint))
            end
            let oins {IAsmOp} = (vec IAsmOp)
            for op in ins
                let loc2 = vs[op.var]
                if (iv_is_boxed loc2)
                    do (panic "lower: asm operand on a captured variable is unsupported")
                end
                do (push oins (IAsmOp val: loc2 constraint: op.constraint))
            end
            do (ir::emit lx.b (IAsm template: template outs: oouts ins: oins clobbers: clobbers))
    end
end

func lower_set (lx LX) (vs {str IVal}) (ts {str Binding}) (target Expr) (expr Expr) -> unit
    match target
        case (EIndex obj index)
            let bt = (checker::check_expr lx.ctx obj ts TNone)
            if (t_is_map bt)
                # set m[k] = v : insert-or-update by key.
                let mp = (lower_expr lx vs ts obj TNone)
                let kty = (t_map_key bt)
                let vty = (t_map_val bt)
                let kv = (lower_expr lx vs ts index kty)
                let v = (lower_expr lx vs ts expr vty)
                do (ir::emit lx.b (IMapSet map: mp key: kv val: v kty: (irt kty) vty: (irt vty)))
            else
                let obv = (lower_expr lx vs ts obj TNone)
                let idx = (lower_expr lx vs ts index (u64_ty))
                let elem = (t_elem bt)
                let v = (lower_expr lx vs ts expr elem)
                if (t_is_vec bt)
                    do (ir::emit lx.b (IVecSet vec: obv idx: idx val: v elem: (irt elem)))
                else
                    do (ir::emit lx.b (IArrSet arr: obv idx: idx val: v elem: (irt elem)))
                end
            end
        else
            let pr = (lower_place lx vs ts target)
            let v = (lower_expr lx vs ts expr pr.ty)
            do (ir::emit lx.b (IAssign place: pr.place src: v))
    end
end

# Lower `match scrut ... end`: read the scrutinee's variant tag once, then an
# if-chain testing each arm's variant index, binding payload fields into the arm
# scope. The checker has already verified exhaustiveness + binding arity, so the
# fall-through after the last arm is unreachable for a non-`else` match (a trap
# guards it, matching the interpreter's no-match runtime error).
func lower_match (lx LX) (vs {str IVal}) (ts {str Binding}) (scrut Expr) (arms {Arm}) (orelse {Stmt}) (has_else bool) -> unit
    let st = (checker::check_expr lx.ctx scrut ts TNone)
    if (not (t_is_sum st))
        do (panic "lower: match scrutinee is not a sum type")
    end
    let sumq = (t_sum_name st)
    let sv = (lower_expr lx vs ts scrut TNone)
    let tagv = (ir::fresh_temp lx.b (irt (TInt name: "i32")))
    do (ir::emit lx.b (ISumTag dst: tagv sum: sv sum_qual: sumq))
    let endl = (ir::fresh_label lx.b "match_end")
    let i = 0u64
    while (< i (len arms))
        let arm = arms[i]
        let tag = (sum_tag lx sumq arm.variant)
        let c = (ir::fresh_temp lx.b (irt (bool_ty)))
        do (ir::emit lx.b (IBin dst: c op: "==" lhs: tagv rhs: (ImmInt val: tag ty: (irt (TInt name: "i32"))) ty: (irt (TInt name: "i32")) chk: false))
        let thenl = (ir::fresh_label lx.b "arm")
        let nextl = (ir::fresh_label lx.b "arm_n")
        do (ir::emit lx.b (ICondBr cond: c then_l: thenl else_l: nextl))
        do (ir::new_block lx.b thenl)
        let vs2 = (copy_iv vs)
        let ts2 = (copy_bind ts)
        let defs = (variant_fields lx sumq arm.variant)
        let vq = (variant_qual sumq arm.variant)
        let j = 0u64
        while (< j (len arm.bindings))
            let bname = arm.bindings[j]
            let fdef = defs[j]
            let fv = (ir::fresh_temp lx.b (irt fdef.ty))
            do (ir::emit lx.b (ISumField dst: fv sum: sv variant_qual: vq field: fdef.name ty: (irt fdef.ty)))
            # the binding may itself be captured by a closure in the arm body
            if (map_has lx.captured bname)
                let box = (make_box lx (irt fdef.ty) fv true)
                set vs2[bname] = box
            else
                let un = (uniq lx bname)
                let loc = (ir::add_local lx.b un (irt fdef.ty))
                do (ir::emit lx.b (IAssign place: (PLocal name: un ty: (irt fdef.ty)) src: fv))
                set vs2[bname] = loc
            end
            set ts2[bname] = (Binding ty: fdef.ty mutable: true)
            set j = (+ j 1)
        end
        do (lower_block lx vs2 ts2 arm.body)
        if (not (ir::cur_terminated lx.b))
            do (ir::emit lx.b (IBr target: endl))
        end
        do (ir::new_block lx.b nextl)
        set i = (+ i 1)
    end
    if has_else
        do (lower_block lx vs ts orelse)
    end
    if (not (ir::cur_terminated lx.b))
        if has_else
            do (ir::emit lx.b (IBr target: endl))
        else
            set lx.irm.externs["cl_panic"] = true
            do (ir::emit lx.b (IPanic msg: (ImmStr s: "no matching case in match")))
        end
    end
    do (ir::new_block lx.b endl)
end

func lower_if (lx LX) (vs {str IVal}) (ts {str Binding}) (branches {Branch}) (orelse {Stmt}) (has_else bool) -> unit
    let endl = (ir::fresh_label lx.b "if_end")
    let i = 0u64
    while (< i (len branches))
        let br = branches[i]
        let cv = (lower_expr lx vs ts br.cond (bool_ty))
        let thenl = (ir::fresh_label lx.b "then")
        let elsl = (ir::fresh_label lx.b "else")
        do (ir::emit lx.b (ICondBr cond: cv then_l: thenl else_l: elsl))
        do (ir::new_block lx.b thenl)
        do (lower_block lx vs ts br.body)
        if (not (ir::cur_terminated lx.b))
            do (ir::emit lx.b (IBr target: endl))
        end
        do (ir::new_block lx.b elsl)
        set i = (+ i 1)
    end
    if has_else
        do (lower_block lx vs ts orelse)
    end
    if (not (ir::cur_terminated lx.b))
        do (ir::emit lx.b (IBr target: endl))
    end
    do (ir::new_block lx.b endl)
end

func lower_while (lx LX) (vs {str IVal}) (ts {str Binding}) (cond Expr) (body {Stmt}) -> unit
    let head = (ir::fresh_label lx.b "while_head")
    let bodyl = (ir::fresh_label lx.b "while_body")
    let endl = (ir::fresh_label lx.b "while_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    let cv = (lower_expr lx vs ts cond (bool_ty))
    do (ir::emit lx.b (ICondBr cond: cv then_l: bodyl else_l: endl))
    do (ir::new_block lx.b bodyl)
    do (push lx.brk endl)
    do (push lx.cont head)
    do (lower_block lx vs ts body)
    do (pop lx.brk)
    do (pop lx.cont)
    if (not (ir::cur_terminated lx.b))
        do (ir::emit lx.b (IBr target: head))
    end
    do (ir::new_block lx.b endl)
end

func lower_loop (lx LX) (vs {str IVal}) (ts {str Binding}) (body {Stmt}) -> unit
    let head = (ir::fresh_label lx.b "loop_head")
    let endl = (ir::fresh_label lx.b "loop_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    do (push lx.brk endl)
    do (push lx.cont head)
    do (lower_block lx vs ts body)
    do (pop lx.brk)
    do (pop lx.cont)
    if (not (ir::cur_terminated lx.b))
        do (ir::emit lx.b (IBr target: head))
    end
    do (ir::new_block lx.b endl)
end

func lower_fornum (lx LX) (vs {str IVal}) (ts {str Binding}) (var str) (startE Expr) (stopE Expr) (strideE Expr) (has_step bool) (body {Stmt}) -> unit
    let cand {Type} = (vec Type)
    do (push cand (checker::check_expr lx.ctx startE ts TNone))
    do (push cand (checker::check_expr lx.ctx stopE ts TNone))
    if has_step
        do (push cand (checker::check_expr lx.ctx strideE ts TNone))
    end
    let ity = (pick_int cand)
    let un = (uniq lx var)
    let loc = (ir::add_local lx.b un (irt ity))
    # A hidden counter drives the loop; the user-visible index `un` is copied from
    # it at the top of each iteration. Mutating the index inside the body therefore
    # cannot change the trip count — the interpreter oracle iterates an independent
    # counter and rebinds the index each step (see son_checker for-loop tests).
    let cntn = (uniq lx (strings::concat var "__cnt"))
    let cntloc = (ir::add_local lx.b cntn (irt ity))
    let startv = (lower_expr lx vs ts startE ity)
    do (ir::emit lx.b (IAssign place: (PLocal name: cntn ty: (irt ity)) src: startv))
    # Snapshot the upper bound and the step into fresh temps at loop entry. The
    # range `for i = 0 to n` is i = 0,1,…,n-1 (DESIGN §"control flow"), a count
    # fixed when the loop begins — and the interpreter oracle evaluates the bound
    # once. Using the bound EXPR's IVal directly (a Local for `n`) would re-read
    # the live variable each iteration, so mutating `n`/the step inside the body
    # would change the trip count — a divergence from the oracle. `(+ x 0)`
    # copies the value into a temp the body cannot alias.
    let stopv0 = (lower_expr lx vs ts stopE ity)
    let stopv = (ir::fresh_temp lx.b (irt ity))
    do (ir::emit lx.b (IBin dst: stopv op: "+" lhs: stopv0 rhs: (ImmInt val: 0i64 ty: (irt ity)) ty: (irt ity) chk: false))
    let stepv0 = (ImmInt val: 1i64 ty: (irt ity))
    if has_step
        set stepv0 = (lower_expr lx vs ts strideE ity)
    end
    let stepv = (ir::fresh_temp lx.b (irt ity))
    do (ir::emit lx.b (IBin dst: stepv op: "+" lhs: stepv0 rhs: (ImmInt val: 0i64 ty: (irt ity)) ty: (irt ity) chk: false))
    let head = (ir::fresh_label lx.b "for_head")
    let bodyl = (ir::fresh_label lx.b "for_body")
    let post = (ir::fresh_label lx.b "for_post")
    let fin = (ir::fresh_label lx.b "for_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    let cond = (ir::fresh_temp lx.b (irt (bool_ty)))
    do (ir::emit lx.b (IBin dst: cond op: "<" lhs: cntloc rhs: stopv ty: (irt ity) chk: false))
    do (ir::emit lx.b (ICondBr cond: cond then_l: bodyl else_l: fin))
    do (ir::new_block lx.b bodyl)
    # publish the counter into the user-visible index at the top of the iteration
    do (ir::emit lx.b (IAssign place: (PLocal name: un ty: (irt ity)) src: cntloc))
    let vs2 = (copy_iv vs)
    let ts2 = (copy_bind ts)
    # A loop variable captured by a closure gets a FRESH per-iteration box (the
    # interpreter rebinds it each iteration), so each closure sees its own value.
    if (map_has lx.captured var)
        let box = (make_box lx (irt ity) loc true)
        set vs2[var] = box
    else
        set vs2[var] = loc
    end
    set ts2[var] = (Binding ty: ity mutable: true)
    do (push lx.brk fin)
    do (push lx.cont post)
    do (lower_block lx vs2 ts2 body)
    do (pop lx.brk)
    do (pop lx.cont)
    if (not (ir::cur_terminated lx.b))
        do (ir::emit lx.b (IBr target: post))
    end
    do (ir::new_block lx.b post)
    let nxt = (ir::fresh_temp lx.b (irt ity))
    do (ir::emit lx.b (IBin dst: nxt op: "+" lhs: cntloc rhs: stepv ty: (irt ity) chk: false))
    do (ir::emit lx.b (IAssign place: (PLocal name: cntn ty: (irt ity)) src: nxt))
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b fin)
end

func lower_forin (lx LX) (vs {str IVal}) (ts {str Binding}) (var str) (iter Expr) (body {Stmt}) -> unit
    let bt = (checker::check_expr lx.ctx iter ts TNone)
    let is_v = (t_is_vec bt)
    if (not (or (t_is_array bt) is_v))
        do (panic "lower: for-in expects an array or vector")
    end
    let elem = (t_elem bt)
    let arr = (lower_expr lx vs ts iter TNone)
    let idxn = (uniq lx "i")
    let idx = (ir::add_local lx.b idxn (irt (u64_ty)))
    let n = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: (ImmInt val: 0i64 ty: (irt (u64_ty)))))
    if is_v
        do (ir::emit lx.b (IVecLen dst: n vec: arr))
    else
        do (ir::emit lx.b (IArrLen dst: n arr: arr))
    end
    let head = (ir::fresh_label lx.b "fi_head")
    let bodyl = (ir::fresh_label lx.b "fi_body")
    let post = (ir::fresh_label lx.b "fi_post")
    let fin = (ir::fresh_label lx.b "fi_end")
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b head)
    let cond = (ir::fresh_temp lx.b (irt (bool_ty)))
    do (ir::emit lx.b (IBin dst: cond op: "<" lhs: idx rhs: n ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (ICondBr cond: cond then_l: bodyl else_l: fin))
    do (ir::new_block lx.b bodyl)
    let elemv = (ir::fresh_temp lx.b (irt elem))
    if is_v
        do (ir::emit lx.b (IVecGet dst: elemv vec: arr idx: idx ty: (irt elem)))
    else
        do (ir::emit lx.b (IArrGet dst: elemv arr: arr idx: idx ty: (irt elem)))
    end
    let varn = (uniq lx var)
    let varloc = (ir::add_local lx.b varn (irt elem))
    do (ir::emit lx.b (IAssign place: (PLocal name: varn ty: (irt elem)) src: elemv))
    let vs2 = (copy_iv vs)
    let ts2 = (copy_bind ts)
    # A captured loop variable gets a FRESH per-iteration box (interpreter parity).
    if (map_has lx.captured var)
        let box = (make_box lx (irt elem) varloc true)
        set vs2[var] = box
    else
        set vs2[var] = varloc
    end
    set ts2[var] = (Binding ty: elem mutable: true)
    do (push lx.brk fin)
    do (push lx.cont post)
    do (lower_block lx vs2 ts2 body)
    do (pop lx.brk)
    do (pop lx.cont)
    if (not (ir::cur_terminated lx.b))
        do (ir::emit lx.b (IBr target: post))
    end
    do (ir::new_block lx.b post)
    let nxt = (ir::fresh_temp lx.b (irt (u64_ty)))
    do (ir::emit lx.b (IBin dst: nxt op: "+" lhs: idx rhs: (ImmInt val: 1i64 ty: (irt (u64_ty))) ty: (irt (u64_ty)) chk: false))
    do (ir::emit lx.b (IAssign place: (PLocal name: idxn ty: (irt (u64_ty))) src: nxt))
    do (ir::emit lx.b (IBr target: head))
    do (ir::new_block lx.b fin)
end

# --------------------------------------------------------------------------- #
# Functions / driver
# --------------------------------------------------------------------------- #

func lower_func (lx LX) (name str) (params {Param}) (ret Ty) (has_ret bool) (body {Stmt}) -> unit
    let irparams {IRParam} = (vec IRParam)
    let ptys {Type} = (vec Type)
    for pf in params
        let pty = (checker::resolve lx.ctx pf.ty)
        do (push irparams (IRParam name: pf.name ty: (irt pty)))
        do (push ptys pty)
    end
    let rty = (unit_ty)
    if has_ret
        set rty = (checker::resolve lx.ctx ret)
    end
    set lx.b = (ir::new_builder (mangle lx.ctx.cur.name name) irparams (irt rty))
    set lx.ret = rty
    set lx.uq[0] = 0i64
    set lx.captured = (compute_captured body)
    # Bind params: a param captured by a nested lambda is boxed (so the closure
    # shares the cell); others are referenced directly as the C parameter.
    let vscope {str IVal} = (map str IVal)
    let tscope {str Binding} = (map str Binding)
    let pi = 0u64
    while (< pi (len params))
        let pname = params[pi].name
        let pty = ptys[pi]
        if (map_has lx.captured pname)
            let box = (make_box lx (irt pty) (Local name: pname ty: (irt pty)) true)
            set vscope[pname] = box
        else
            set vscope[pname] = (Local name: pname ty: (irt pty))
        end
        set tscope[pname] = (Binding ty: pty mutable: true)
        set pi = (+ pi 1)
    end
    do (lower_block lx vscope tscope body)
    # Synthetic tail terminator for a block that falls through. For a unit
    # function that is a bare `return;`. For a value-returning function the tail
    # is either unreachable (all paths already returned) or a checker-permitted
    # missing-return; the interpreter treats falling off a value-returning
    # function as a runtime error, so we emit a trap (valid C, faithful abort)
    # rather than an illegal bare `return;` in a non-void function.
    if (not (ir::cur_terminated lx.b))
        if (t_is_unit rty)
            do (ir::emit lx.b (IRet has_val: false val: ImmUnit))
        else
            set lx.irm.externs["cl_panic"] = true
            do (ir::emit lx.b (IPanic msg: (ImmStr s: "fell off the end of a value-returning function")))
        end
    end
    do (push lx.irm.funcs lx.b.fn)
end

func build_callmap (ctx Ctx) (sig Sig) -> {str str}
    let m {str str} = (map str str)
    for d in sig.decls
        match d
            case (DFunc name params ret has_ret body exported)
                set m[name] = (mangle sig.name name)
            else
                pass
        end
    end
    # Selectively-imported functions (`import mod (f)`) are callable / usable as a
    # value by bare name and must mangle to their DEFINING module, not the current
    # one (mirrors bootstrap/lower.py). The Sig keeps selective value names but not
    # their source module, so resolve each via the import registry's function sets.
    for nm in (map_keys sig.selective)
        for alias in (map_keys sig.imported)
            let mod = sig.imported[alias]
            if (map_has ctx.sigs mod)
                if (map_has ctx.sigs[mod].funcs nm)
                    set m[nm] = (mangle mod nm)
                end
            end
        end
    end
    return m
end

# Lexicographic string order (by codepoint), so emission order is independent of
# map iteration order — a prerequisite for the byte-identical self-host fixed
# point (DESIGN §11). map_keys order must NOT drive output.
func str_lt (a str) (b str) -> bool
    let ca = (strings::chars a)
    let cb = (strings::chars b)
    let n = (len ca)
    if (< (len cb) n)
        set n = (len cb)
    end
    let i = 0u64
    while (< i n)
        let xa = (convert::ord ca[i])
        let xb = (convert::ord cb[i])
        if (< xa xb)
            return true
        end
        if (> xa xb)
            return false
        end
        set i = (+ i 1)
    end
    return (< (len ca) (len cb))
end

func sorted_sig_names (m {str Sig}) -> {str}
    let ks {str} = (vec str)
    for k in (map_keys m)
        do (push ks k)
    end
    let i = 1u64
    while (< i (len ks))
        let j = i
        while (and (> j 0u64) (str_lt ks[j] ks[(- j 1u64)]))
            let tmp = ks[j]
            set ks[j] = ks[(- j 1u64)]
            set ks[(- j 1u64)] = tmp
            set j = (- j 1u64)
        end
        set i = (+ i 1)
    end
    return ks
end

export func lower_program (src str) (searchdirs {str}) -> IRModule
    let mainmod = (parser::parse src)
    let ctx = (checker::new_ctx searchdirs)
    let s0 = (checker::build_sig ctx mainmod)
    let m = (IRModule name: mainmod.name structs: (vec IRStruct) funcs: (vec IRFunc) externs: (map str bool) thunks: (map str Type))
    let chk {bool} = (vec bool)
    do (push chk false)
    let uq {i64} = (vec i64)
    do (push uq 0i64)
    let lamn {i64} = (vec i64)
    do (push lamn 0i64)
    let lx = (LX ctx: ctx irm: m b: (ir::new_builder "__init" (vec IRParam) (irt (unit_ty))) chk: chk brk: (vec str) cont: (vec str) uq: uq callmap: (map str str) ret: (unit_ty) captured: (map str bool) lamn: lamn)
    let names = (sorted_sig_names ctx.sigs)
    # Pass 1: collect value-struct typedefs (sorted module order = deterministic).
    # Struct identity is module-qualified ("mod::Name"); the C backend mangles it
    # to cl_struct_<mod>__<Name>, so same-named structs in different modules do
    # not collide (DESIGN §10 module-local types).
    let si = 0u64
    while (< si (len names))
        let ssig = ctx.sigs[names[si]]
        if ssig.has_module
            set lx.ctx.cur = ssig
            for d in ssig.decls
                match d
                    case (DStruct sname sfields is_packed exported)
                        let irfields {IRParam} = (vec IRParam)
                        for pf in sfields
                            do (push irfields (IRParam name: pf.name ty: (irt (checker::resolve lx.ctx pf.ty))))
                        end
                        do (push lx.irm.structs (IRStruct name: (qual ssig.name sname) fields: irfields))
                    case (DSum sname variants exported)
                        # A sum is a tag-only header struct plus one {tag; payload}
                        # struct per variant; a sum value is a handle to one of the
                        # variant objects (DESIGN §5.3).
                        let sumq = (qual ssig.name sname)
                        let hdr {IRParam} = (vec IRParam)
                        do (push hdr (IRParam name: "cl_tag" ty: (irt (TInt name: "i32"))))
                        do (push lx.irm.structs (IRStruct name: sumq fields: hdr))
                        for vr in variants
                            let vf {IRParam} = (vec IRParam)
                            do (push vf (IRParam name: "cl_tag" ty: (irt (TInt name: "i32"))))
                            for pf in vr.fields
                                # `cl_tag` is the discriminant field name; the `cl_`
                                # prefix is the compiler's reserved C-symbol prefix, so
                                # a user payload may freely be named `tag` (parity with
                                # the interpreter) and only `cl_tag` itself is reserved.
                                if (strings::eq pf.name "cl_tag")
                                    do (panic "lower: a sum variant payload field named 'cl_tag' is unsupported (reserved for the discriminant)")
                                end
                                do (push vf (IRParam name: pf.name ty: (irt (checker::resolve lx.ctx pf.ty))))
                            end
                            do (push lx.irm.structs (IRStruct name: (variant_qual sumq vr.name) fields: vf))
                        end
                    else
                        pass
                end
            end
        end
        set si = (+ si 1)
    end
    # reflect::TypeInfo is a builtin-module struct (no source decls); register its
    # typedef when the program imports reflect (DESIGN §5.6).
    if (map_has lx.ctx.sigs "reflect")
        let tif {IRParam} = (vec IRParam)
        do (push tif (IRParam name: "name" ty: (irt (str_ty))))
        do (push tif (IRParam name: "kind" ty: (irt (str_ty))))
        do (push tif (IRParam name: "fields" ty: (irt (TVec elem: (str_ty)))))
        do (push tif (IRParam name: "variants" ty: (irt (TVec elem: (str_ty)))))
        do (push lx.irm.structs (IRStruct name: "reflect::TypeInfo" fields: tif))
    end
    # Pass 2: lower functions.
    let ni = 0u64
    while (< ni (len names))
        let sig = ctx.sigs[names[ni]]
        if sig.has_module
            set lx.ctx.cur = sig
            set lx.callmap = (build_callmap lx.ctx sig)
            for d in sig.decls
                match d
                    case (DFunc fname params ret has_ret body exported)
                        do (lower_func lx fname params ret has_ret body)
                    else
                        pass
                end
            end
        end
        set ni = (+ ni 1)
    end
    # Pass 3: synthesize <Type>_to_str for every struct/enum (always-emit,
    # DESIGN §5.5/§5.6). User OVERRIDES are step 3 (they need interpreter-side
    # defining-module dispatch for parity); until then every hook is autogenerated.
    # A user OVERRIDE — a function named `<Type>_to_str` in the type's own module —
    # replaces the autogen (same mangled symbol, lowered in pass 2); skip synthesis
    # for it. The checker has already validated its signature is (T) -> str.
    let ti = 0u64
    while (< ti (len names))
        let tsig = ctx.sigs[names[ti]]
        if tsig.has_module
            set lx.ctx.cur = tsig
            let userfns {str bool} = (map str bool)
            for d in tsig.decls
                match d
                    case (DFunc fname params ret has_ret body exported)
                        set userfns[fname] = true
                    else
                        pass
                end
            end
            for d in tsig.decls
                match d
                    case (DStruct sname sfields is_packed exported)
                        if (not (map_has userfns (strings::concat sname "_to_str")))
                            do (synth_struct_to_str lx tsig.name sname)
                        end
                    case (DEnum ename variants exported)
                        if (not (map_has userfns (strings::concat ename "_to_str")))
                            do (synth_enum_to_str lx tsig.name ename variants)
                        end
                    case (DSum sname variants exported)
                        if (not (map_has userfns (strings::concat sname "_to_str")))
                            do (synth_sum_to_str lx tsig.name sname variants)
                        end
                    else
                        pass
                end
            end
        end
        set ti = (+ ti 1)
    end
    # autogen to_str for the builtin reflect::TypeInfo (so descriptors print).
    if (map_has lx.ctx.sigs "reflect")
        set lx.ctx.cur = lx.ctx.sigs["reflect"]
        do (synth_struct_to_str lx "reflect" "TypeInfo")
    end
    return m
end
