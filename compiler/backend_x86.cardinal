module backend_x86

# x86_64 direct-assembler backend: consumes the SAME IR (ir.cardinal) as the C
# backend and emits GNU `as` (AT&T) assembly, assembled + linked against the
# canonical runtime (cardinal_rt.c + cardinal_gc.c) — identical ABI to the C
# backend, so program behavior is byte-identical to the interpreter.
#
# Model: a stack-slot machine (no register allocation). Every IR temp/local/param
# gets an 8-byte frame slot at -N(%rbp); each instruction loads operand slots into
# scratch regs (%rax/%rcx/%rdx), computes, and stores the result back. Integers
# are computed in 64-bit and normalized (sign/zero-extended) to the declared
# width, so a slot always holds the value extended to 64 bits.
#
# MILESTONE 1: sized ints (i8..i64/u8..u64), bool, char, enums, full control flow,
# casts (int<->int), function calls + recursion, panic, io of scalars (via the
# lowerer's to_str calls), and precise GC shadow-stack rooting. Floats, strings
# literals, and aggregates (structs/arrays/vec/map/sum/closure) raise a clean
# panic until their milestone.

import strings
import convert
import checker
import ir

# --------------------------------------------------------------------------- #
# Small string helpers
# --------------------------------------------------------------------------- #

func i2s (v i64) -> str
    return (convert::int_to_str v)
end

func cat2 (a str) (b str) -> str
    return (strings::concat a b)
end

func cat3 (a str) (b str) (c str) -> str
    return (strings::concat a (strings::concat b c))
end

func line (s str) -> str
    return (strings::concat s "\n")
end

# Escape a string for a GNU `as` .asciz directive (control bytes -> C escapes).
func asm_escape (s str) -> str
    let cs = (strings::chars s)
    let out = ""
    let i = 0u64
    while (< i (len cs))
        let c = cs[i]
        if (== c '"')
            set out = (strings::concat out "\\\"")
        elsif (== c '\\')
            set out = (strings::concat out "\\\\")
        elsif (== c '\n')
            set out = (strings::concat out "\\n")
        elsif (== c '\t')
            set out = (strings::concat out "\\t")
        elsif (== c '\r')
            set out = (strings::concat out "\\r")
        elsif (== c '\0')
            # NUL: octal escape so the .ascii line stays a valid token (a raw NUL
            # byte would make `as` choke). The byte is preserved in rodata.
            set out = (strings::concat out "\\000")
        else
            set out = (strings::concat out (strings::from_char c))
        end
        set i = (+ i 1)
    end
    return out
end

# Intern a string literal into the rodata pool, returning its label.
func pool_add (strs {str str}) (s str) -> str
    if (map_has strs s)
        return strs[s]
    end
    let lab = (strings::concat ".Lstr" (i2s (as (len (map_keys strs)) i64)))
    set strs[s] = lab
    return lab
end

# Collect every string literal reachable in a module into the rodata pool.
func collect_iv (strs {str str}) (v IVal) -> unit
    match v
        case (ImmStr s)
            let ign = (pool_add strs s)
        else
            pass
    end
end

func collect_instr (strs {str str}) (ins Instr) -> unit
    match ins
        case (IConst dst v ty)
            do (collect_iv strs v)
        case (IAssign p src)
            do (collect_iv strs src)
        case (ICall has_dst dst callee args ty)
            let i = 0u64
            while (< i (len args))
                do (collect_iv strs args[i])
                set i = (+ i 1)
            end
        case (IPanic msg)
            do (collect_iv strs msg)
        case (IRet has_val v)
            do (collect_iv strs v)
        case (IStructNew dst struct_name fnames fvals)
            let i = 0u64
            while (< i (len fvals))
                do (collect_iv strs fvals[i])
                set i = (+ i 1)
            end
        case (IVecLit dst elem elems)
            let i = 0u64
            while (< i (len elems))
                do (collect_iv strs elems[i])
                set i = (+ i 1)
            end
        case (IArrLit dst elem elems)
            let i = 0u64
            while (< i (len elems))
                do (collect_iv strs elems[i])
                set i = (+ i 1)
            end
        case (ISumNew dst variant_qual tag fnames fvals)
            let i = 0u64
            while (< i (len fvals))
                do (collect_iv strs fvals[i])
                set i = (+ i 1)
            end
        case (IVecPush vc sval elem)
            do (collect_iv strs sval)
        case (IVecSet vc idx sval elem)
            do (collect_iv strs sval)
        case (IArrSet arr idx sval elem)
            do (collect_iv strs sval)
        case (IMapSet mp ky sval kty vty)
            do (collect_iv strs ky)
            do (collect_iv strs sval)
        case (IMapGet dst mp ky kty vty)
            do (collect_iv strs ky)
        case (IMapHas dst mp ky kty)
            do (collect_iv strs ky)
        case (IMapDel mp ky kty)
            do (collect_iv strs ky)
        case (IVecGet dst vc idx ty)
            do (collect_iv strs idx)
        case (ICallClosure has_dst dst clos args ret ptys)
            let i = 0u64
            while (< i (len args))
                do (collect_iv strs args[i])
                set i = (+ i 1)
            end
        else
            pass
    end
end

func collect_strs (m IRModule) -> {str str}
    let strs {str str} = (map str str)
    let fi = 0u64
    while (< fi (len m.funcs))
        let f = m.funcs[fi]
        let bi = 0u64
        while (< bi (len f.blocks))
            let blk = f.blocks[bi]
            let ii = 0u64
            while (< ii (len blk.instrs))
                do (collect_instr strs blk.instrs[ii])
                set ii = (+ ii 1)
            end
            set bi = (+ bi 1)
        end
        set fi = (+ fi 1)
    end
    return strs
end

# --------------------------------------------------------------------------- #
# Integer type info: width (bits) + signedness, from a type name.
# --------------------------------------------------------------------------- #

func int_bits (name str) -> i64
    if (or (strings::eq name "i8") (strings::eq name "u8"))
        return 8i64
    end
    if (or (strings::eq name "i16") (strings::eq name "u16"))
        return 16i64
    end
    if (or (strings::eq name "i32") (strings::eq name "u32"))
        return 32i64
    end
    return 64i64
end

func int_signed (name str) -> bool
    return (== (strings::chars name)[0] 'i')
end

# An IRType's integer (bits, signed) — char/enum/bool behave as fixed-width ints.
# Returns bits; signedness via irt_signed.
func irt_bits (t IRType) -> i64
    match t
        case (TyOf st)
            match st
                case (TInt n)
                    return (int_bits n)
                case (TEnum n)
                    return 32i64
                case (TPrim n)
                    if (strings::eq n "char")
                        return 32i64
                    end
                    if (strings::eq n "bool")
                        return 8i64
                    end
                    return 64i64
                else
                    return 64i64
            end
        else
            return 64i64
    end
    return 64i64
end

func irt_signed (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TInt n)
                    return (int_signed n)
                case (TEnum n)
                    return true
                case (TPrim n)
                    return false
                else
                    return false
            end
        else
            return false
    end
    return false
end

func irt_is_float (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TFloat n)
                    return true
                else
                    return false
            end
        else
            return false
    end
    return false
end

func irt_is_unit (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TPrim n)
                    return (strings::eq n "unit")
                else
                    return false
            end
        else
            return false
    end
    return false
end

func irt_is_int_class (t IRType) -> bool
    if (irt_is_float t)
        return false
    end
    if (irt_is_unit t)
        return false
    end
    return true
end

# Managed (GC-traced) types — must be shadow-stack-rooted. Mirrors backend_c.
func managed (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TStruct n)
                    return true
                case (TArray e)
                    return true
                case (TVec e)
                    return true
                case (TMap k v)
                    return true
                case (TFunc p r)
                    return true
                case (TSum n)
                    return true
                case (TPrim n)
                    return (strings::eq n "str")
                else
                    return false
            end
        case (Ptr p)
            return true
        case VoidPtr
            return false
    end
    return false
end

# A managed type is a single 8-byte handle EXCEPT value structs/arrays/closures,
# which are multi-word and unsupported in milestone 1 (raise a clean panic).
func is_simple_8byte (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TStruct n)
                    return false
                case (TArray e)
                    return false
                case (TFunc p r)
                    return false
                else
                    return true
            end
        case (Ptr p)
            return true
        case VoidPtr
            return true
    end
    return true
end

# --------------------------------------------------------------------------- #
# Frame: assign an 8-byte slot to every temp/local/param. Slot keys: "t<id>" for
# temps, "l<name>" for locals/params. Offsets are negative from %rbp.
# --------------------------------------------------------------------------- #

func tkey (id i64) -> str
    return (strings::concat "t" (i2s id))
end
func lkey (name str) -> str
    return (strings::concat "l" name)
end

# The slot key for an operand IVal (Temp/Local only).
func iv_key (v IVal) -> str
    match v
        case (Temp id ty)
            return (tkey id)
        case (Local name ty)
            return (lkey name)
        else
            return ""
    end
    return ""
end

func iv_ty (v IVal) -> IRType
    match v
        case (Temp id ty)
            return ty
        case (Local name ty)
            return ty
        case (ImmInt vv ty)
            return ty
        case (ImmFloat t ty)
            return ty
        case (ImmNull ty)
            return ty
        case (ImmBool b)
            return (TyOf t: (TPrim name: "bool"))
        case (ImmChar cp)
            return (TyOf t: (TPrim name: "char"))
        case (ImmStr s)
            return (TyOf t: (TPrim name: "str"))
        case ImmUnit
            return (TyOf t: (TPrim name: "unit"))
    end
    return (TyOf t: (TPrim name: "unit"))
end

# --------------------------------------------------------------------------- #
# Register naming for a width (the low sub-register of %rax/%rcx/%rdx).
# --------------------------------------------------------------------------- #

func reg_for (base str) (bits i64) -> str
    if (== bits 8i64)
        if (strings::eq base "a")
            return "%al"
        end
        if (strings::eq base "c")
            return "%cl"
        end
        return "%dl"
    end
    if (== bits 16i64)
        if (strings::eq base "a")
            return "%ax"
        end
        if (strings::eq base "c")
            return "%cx"
        end
        return "%dx"
    end
    if (== bits 32i64)
        if (strings::eq base "a")
            return "%eax"
        end
        if (strings::eq base "c")
            return "%ecx"
        end
        return "%edx"
    end
    if (strings::eq base "a")
        return "%rax"
    end
    if (strings::eq base "c")
        return "%rcx"
    end
    return "%rdx"
end

# Sign/zero-extend %rax (holding a `bits`-wide value) to a normalized 64-bit form.
func extend_rax (bits i64) (signed bool) -> str
    if (== bits 64i64)
        return ""
    end
    if (== bits 32i64)
        if signed
            return (line "    movslq %eax, %rax")
        end
        return (line "    movl %eax, %eax")
    end
    if (== bits 16i64)
        if signed
            return (line "    movswq %ax, %rax")
        end
        return (line "    movzwq %ax, %rax")
    end
    # 8-bit
    if signed
        return (line "    movsbq %al, %rax")
    end
    return (line "    movzbq %al, %rax")
end

# --------------------------------------------------------------------------- #
# Per-function state: slot offsets + the current function's label prefix.
# --------------------------------------------------------------------------- #

struct BX
    slots {str i64}     # slot key -> byte offset from %rbp (negative)
    fname str           # current function (label prefix, avoids cross-fn clashes)
    strs {str str}      # string-literal content -> rodata label
    floats {str str}    # float-literal key ("f64:TEXT"/"f32:TEXT") -> rodata label
    structs {str IRStruct}   # qualified struct/variant name -> its IRStruct (layout)
    scratch i64         # a spare frame slot offset (park a value across a call)
    ret_mem bool        # function returns a >16B struct via a hidden pointer
    hidden_ret i64      # frame slot holding that hidden return pointer
end

# True if an IRType is the 32-bit float type (else f64 / non-float).
func irt_f32 (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TFloat n)
                    return (strings::eq n "f32")
                else
                    return false
            end
        else
            return false
    end
    return false
end

# The scalar (ss) vs double (sd) SSE suffix for a float type.
func sse_sfx (t IRType) -> str
    if (irt_f32 t)
        return "ss"
    end
    return "sd"
end

# --------------------------------------------------------------------------- #
# C-ABI layout model (SysV x86_64): size/alignment of a type, and the byte offset
# of each field in a struct/variant heap object. Needed because — unlike the C
# backend, which defers to the C compiler — we compute offsets ourselves. Matches
# the layout `cc` produces for the emitted typedefs, so heap objects interop.
# --------------------------------------------------------------------------- #

func type_align (t IRType) (sm {str IRStruct}) -> i64
    match t
        case (TyOf st)
            match st
                case (TInt n)
                    return (/ (int_bits n) 8i64)
                case (TFloat n)
                    if (strings::eq n "f32")
                        return 4i64
                    end
                    return 8i64
                case (TPrim n)
                    if (strings::eq n "bool")
                        return 1i64
                    end
                    if (strings::eq n "char")
                        return 4i64
                    end
                    return 8i64
                case (TEnum n)
                    return 4i64
                case (TStruct n)
                    return (struct_align sm n)
                else
                    return 8i64
            end
        else
            return 8i64
    end
    return 8i64
end

func type_size (t IRType) (sm {str IRStruct}) -> i64
    match t
        case (TyOf st)
            match st
                case (TInt n)
                    return (/ (int_bits n) 8i64)
                case (TFloat n)
                    if (strings::eq n "f32")
                        return 4i64
                    end
                    return 8i64
                case (TPrim n)
                    if (strings::eq n "bool")
                        return 1i64
                    end
                    if (strings::eq n "char")
                        return 4i64
                    end
                    if (strings::eq n "unit")
                        return 0i64
                    end
                    return 8i64
                case (TEnum n)
                    return 4i64
                case (TArray e)
                    return 24i64
                case (TFunc p r)
                    return 16i64
                case (TStruct n)
                    return (struct_size sm n)
                else
                    return 8i64
            end
        else
            return 8i64
    end
    return 8i64
end

# A frame slot is type_size rounded up to 8 bytes; multi-word values (cl_closure
# 16B, cl_array 24B, value structs) occupy several consecutive 8-byte words.
func slot_size (t IRType) (sm {str IRStruct}) -> i64
    let s = (type_size t sm)
    if (< s 8i64)
        return 8i64
    end
    let r = (% s 8i64)
    if (== r 0i64)
        return s
    end
    return (+ s (- 8i64 r))
end

func nwords (t IRType) (sm {str IRStruct}) -> i64
    return (/ (slot_size t sm) 8i64)
end

# SysV: how many INTEGER registers a by-value argument of this type consumes.
# ≤8B -> 1; cl_closure (16B, {ptr,handle}) -> 2. Larger aggregates are MEMORY
# class (passed on the stack) — not yet supported here.
func int_regs_for (t IRType) (sm {str IRStruct}) -> i64
    match t
        case (TyOf st)
            match st
                case (TFunc p r)
                    return 2i64
                case (TStruct n)
                    # all-integer struct ≤16B -> 1-2 regs (eightbytes); >16B is SysV
                    # MEMORY class (stack) — not yet supported.
                    if (> (type_size t sm) 16i64)
                        do (panic "x86: by-value struct >16 bytes (MEMORY class, later milestone)")
                    end
                    return (nwords t sm)
                case (TArray e)
                    do (panic "x86: by-value array argument (later milestone)")
                else
                    return 1i64
            end
        else
            return 1i64
    end
    return 1i64
end

# The qualified struct name "mod::Name" of a TStruct IRType.
func irt_struct_qn (t IRType) -> str
    match t
        case (TyOf st)
            match st
                case (TStruct n)
                    return n
                else
                    do (panic "x86: expected a struct type")
            end
        else
            do (panic "x86: expected a struct type")
    end
    return ""
end

func align_up (off i64) (a i64) -> i64
    if (<= a 1i64)
        return off
    end
    let r = (% off a)
    if (== r 0i64)
        return off
    end
    return (+ off (- a r))
end

func max2 (a i64) (b i64) -> i64
    if (> a b)
        return a
    end
    return b
end

func struct_align (sm {str IRStruct}) (qn str) -> i64
    if (not (map_has sm qn))
        do (panic (strings::concat "x86: unknown struct layout " qn))
    end
    let fs = sm[qn].fields
    let m = 1i64
    let i = 0u64
    while (< i (len fs))
        set m = (max2 m (type_align fs[i].ty sm))
        set i = (+ i 1)
    end
    return m
end

func struct_size (sm {str IRStruct}) (qn str) -> i64
    if (not (map_has sm qn))
        do (panic (strings::concat "x86: unknown struct layout " qn))
    end
    let fs = sm[qn].fields
    let off = 0i64
    let i = 0u64
    while (< i (len fs))
        let a = (type_align fs[i].ty sm)
        set off = (align_up off a)
        set off = (+ off (type_size fs[i].ty sm))
        set i = (+ i 1)
    end
    return (align_up off (struct_align sm qn))
end

# Byte offset of field `fname` within struct/variant `qn`.
func field_offset (sm {str IRStruct}) (qn str) (fname str) -> i64
    if (not (map_has sm qn))
        do (panic (strings::concat "x86: unknown struct layout " qn))
    end
    let fs = sm[qn].fields
    let off = 0i64
    let i = 0u64
    while (< i (len fs))
        let a = (type_align fs[i].ty sm)
        set off = (align_up off a)
        if (strings::eq fs[i].name fname)
            return off
        end
        set off = (+ off (type_size fs[i].ty sm))
        set i = (+ i 1)
    end
    do (panic (strings::concat "x86: no field " (strings::concat fname (strings::concat " in " qn))))
    return 0i64
end

# The type of field `fname` in struct/variant `qn` (for sized loads/stores).
func field_type (sm {str IRStruct}) (qn str) (fname str) -> IRType
    let fs = sm[qn].fields
    let i = 0u64
    while (< i (len fs))
        if (strings::eq fs[i].name fname)
            return fs[i].ty
        end
        set i = (+ i 1)
    end
    do (panic (strings::concat "x86: no field " fname))
    return VoidPtr
end

func slot_off (bx BX) (key str) -> i64
    if (map_has bx.slots key)
        return bx.slots[key]
    end
    do (panic (strings::concat "x86: no slot for " key))
    return 0i64
end

func off_mem (off i64) -> str
    return (strings::concat (i2s off) "(%rbp)")
end

# Per-function label (IR labels repeat across functions; prefix to disambiguate).
func lbl (bx BX) (name str) -> str
    return (strings::concat ".L" (strings::concat bx.fname (strings::concat "_" name)))
end

# The SysV integer argument register for parameter index i (0..5).
func argreg (i i64) -> str
    if (== i 0i64)
        return "%rdi"
    end
    if (== i 1i64)
        return "%rsi"
    end
    if (== i 2i64)
        return "%rdx"
    end
    if (== i 3i64)
        return "%rcx"
    end
    if (== i 4i64)
        return "%r8"
    end
    return "%r9"
end

# --------------------------------------------------------------------------- #
# Operand load / result store
# --------------------------------------------------------------------------- #

# Load operand `v` into the 64-bit register named by base ("a"/"c"/"d" -> r*x) or
# a full register string starting with '%' (e.g. an arg reg). A slot already holds
# the value normalized to 64 bits, so a plain movq suffices.
func load_into (bx BX) (regfull str) (v IVal) -> str
    match v
        case (Temp id ty)
            return (line (cat3 "    movq " (cat3 (off_mem (slot_off bx (tkey id))) ", " regfull) ""))
        case (Local name ty)
            return (line (cat3 "    movq " (cat3 (off_mem (slot_off bx (lkey name))) ", " regfull) ""))
        case (ImmInt vv ty)
            return (line (cat3 "    movabsq $" (cat3 (i2s vv) ", " regfull) ""))
        case (ImmBool b)
            if b
                return (line (cat2 "    movq $1, " regfull))
            end
            return (line (cat2 "    movq $0, " regfull))
        case (ImmChar cp)
            return (line (cat3 "    movabsq $" (cat3 (i2s cp) ", " regfull) ""))
        case ImmUnit
            return (line (cat2 "    movq $0, " regfull))
        case (ImmNull ty)
            return (line (cat2 "    movq $0, " regfull))
        case (ImmFloat t ty)
            do (panic "x86: float literal (later milestone)")
        case (ImmStr s)
            do (panic "x86: string literal (later milestone)")
    end
    return ""
end

func reg_base (which str) -> str
    if (strings::eq which "a")
        return "%rax"
    end
    if (strings::eq which "c")
        return "%rcx"
    end
    return "%rdx"
end

# Store %rax into operand `dst`'s slot.
func store_rax (bx BX) (dst IVal) -> str
    return (line (cat3 "    movq %rax, " (off_mem (slot_off bx (iv_key dst))) ""))
end

# Store a 1-word CALL RESULT into dst, first normalizing %rax to dst's declared
# width. A C runtime function returning a narrow type (e.g. cl_strings__eq -> bool)
# may leave dirty upper bytes in %rax (SysV only guarantees the low bits); without
# this, a bool result reads as a garbage non-zero. No-op for 8-byte results.
func store_result_rax (bx BX) (dst IVal) -> str
    let t = (iv_ty dst)
    let out = (extend_rax (irt_bits t) (irt_signed t))
    return (strings::concat out (store_rax bx dst))
end

# Store the low `size` bytes of register base ("c"/"a"/"d") into a memory operand.
func store_sized (size i64) (base str) (mem str) -> str
    if (== size 1i64)
        return (line (cat2 "    movb " (cat3 (reg_for base 8i64) ", " mem)))
    end
    if (== size 2i64)
        return (line (cat2 "    movw " (cat3 (reg_for base 16i64) ", " mem)))
    end
    if (== size 4i64)
        return (line (cat2 "    movl " (cat3 (reg_for base 32i64) ", " mem)))
    end
    return (line (cat2 "    movq " (cat3 (reg_for base 64i64) ", " mem)))
end

# Load `size` bytes from memory into %rax, sign/zero-extended to 64 bits.
func load_sized (size i64) (signed bool) (mem str) -> str
    if (== size 8i64)
        return (line (cat2 "    movq " (cat2 mem ", %rax")))
    end
    if (== size 4i64)
        if signed
            return (line (cat2 "    movslq " (cat2 mem ", %rax")))
        end
        return (line (cat2 "    movl " (cat2 mem ", %eax")))
    end
    if (== size 2i64)
        if signed
            return (line (cat2 "    movswq " (cat2 mem ", %rax")))
        end
        return (line (cat2 "    movzwq " (cat2 mem ", %rax")))
    end
    if signed
        return (line (cat2 "    movsbq " (cat2 mem ", %rax")))
    end
    return (line (cat2 "    movzbq " (cat2 mem ", %rax")))
end

# Materialize operand `v` into %rax. Unlike load_into, this handles ImmStr (a
# string literal -> cl_strlit on the interned rodata pointer); it issues a CALL,
# so callers must not hold live values in caller-saved regs across it.
func load_to_rax (bx BX) (v IVal) -> str
    match v
        case (ImmStr s)
            # ptr in %rdi, byte length (end-label - start-label) in %rsi; build the
            # string from explicit bytes so embedded NULs survive (cl_strlit would
            # strlen-truncate). For NUL-free literals this matches the old behavior.
            let lab = bx.strs[s]
            let out = (line (cat2 "    leaq " (cat2 lab "(%rip), %rdi")))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 lab "_end(%rip), %rsi"))))
            set out = (strings::concat out (line "    subq %rdi, %rsi"))
            return (strings::concat out (line "    call cl_strlit_n"))
        else
            return (load_into bx "%rax" v)
    end
    return (load_into bx "%rax" v)
end

# --------------------------------------------------------------------------- #
# Floats (SSE/xmm). Float literals are interned in a rodata pool (lazily, during
# emission); values live in 8-byte slots (f64 bits, or f32 in the low 4 bytes).
# --------------------------------------------------------------------------- #

func float_pool_add (floats {str str}) (text str) (is_f32 bool) -> str
    let pre = "f64:"
    if is_f32
        set pre = "f32:"
    end
    let key = (strings::concat pre text)
    if (map_has floats key)
        return floats[key]
    end
    let lab = (strings::concat ".Lflt" (i2s (as (len (map_keys floats)) i64)))
    set floats[key] = lab
    return lab
end

# Load a float operand into the named xmm register (movsd/movss).
func load_xmm (bx BX) (xreg str) (v IVal) -> str
    let mov = (strings::concat "    mov" (sse_sfx (iv_ty v)))
    match v
        case (Temp id ty)
            return (line (cat3 mov " " (cat3 (off_mem (slot_off bx (tkey id))) ", " xreg)))
        case (Local name ty)
            return (line (cat3 mov " " (cat3 (off_mem (slot_off bx (lkey name))) ", " xreg)))
        case (ImmFloat text ty)
            let lab = (float_pool_add bx.floats text (irt_f32 ty))
            return (line (cat3 mov " " (cat3 lab "(%rip), " xreg)))
        else
            do (panic "x86: non-float operand in a float context")
    end
    return ""
end

# Store an xmm register into a float operand's slot.
func store_xmm (bx BX) (xreg str) (dst IVal) -> str
    let mov = (strings::concat "    mov" (sse_sfx (iv_ty dst)))
    return (line (cat3 mov " " (cat3 xreg ", " (off_mem (slot_off bx (iv_key dst))))))
end

# The SSE arithmetic mnemonic for a float op (addsd/subss/...).
func float_arith_op (op str) (sfx str) -> str
    if (strings::eq op "+")
        return (strings::concat "add" sfx)
    end
    if (strings::eq op "-")
        return (strings::concat "sub" sfx)
    end
    if (strings::eq op "*")
        return (strings::concat "mul" sfx)
    end
    if (strings::eq op "/")
        return (strings::concat "div" sfx)
    end
    do (panic (strings::concat "x86: unsupported float op " op))
    return ""
end

# Set %al to the C-semantics result of a float comparison after `ucomi`. NaN is
# UNORDERED: ucomi sets ZF=PF=CF=1, so a plain sete/setb/setbe would wrongly report
# NaN as equal/less. C says ==,<,<=,>,>= are all FALSE and != is TRUE when either
# operand is NaN. >,>= already use seta/setae (require CF=0, false on unordered);
# the rest fold in the parity flag. Clobbers %cl.
func float_cmp_seq (op str) -> str
    if (strings::eq op "==")
        return (strings::concat (line "    sete %al") (strings::concat (line "    setnp %cl") (line "    andb %cl, %al")))
    end
    if (strings::eq op "!=")
        return (strings::concat (line "    setne %al") (strings::concat (line "    setp %cl") (line "    orb %cl, %al")))
    end
    if (strings::eq op "<")
        return (strings::concat (line "    setb %al") (strings::concat (line "    setnp %cl") (line "    andb %cl, %al")))
    end
    if (strings::eq op "<=")
        return (strings::concat (line "    setbe %al") (strings::concat (line "    setnp %cl") (line "    andb %cl, %al")))
    end
    if (strings::eq op ">")
        return (line "    seta %al")
    end
    return (line "    setae %al")
end

# --------------------------------------------------------------------------- #
# Instruction emission
# --------------------------------------------------------------------------- #

func cmp_setcc (op str) (signed bool) -> str
    if (strings::eq op "==")
        return "sete"
    end
    if (strings::eq op "!=")
        return "setne"
    end
    if (strings::eq op "<")
        if signed
            return "setl"
        end
        return "setb"
    end
    if (strings::eq op "<=")
        if signed
            return "setle"
        end
        return "setbe"
    end
    if (strings::eq op ">")
        if signed
            return "setg"
        end
        return "seta"
    end
    if signed
        return "setge"
    end
    return "setae"
end

func is_cmp_op (op str) -> bool
    let v {str} = (vec str)
    do (push v "<")
    do (push v "<=")
    do (push v ">")
    do (push v ">=")
    do (push v "==")
    do (push v "!=")
    let i = 0u64
    while (< i (len v))
        if (strings::eq v[i] op)
            return true
        end
        set i = (+ i 1)
    end
    return false
end

func emit_bin (bx BX) (dst IVal) (op str) (lhs IVal) (rhs IVal) (ty IRType) (chk bool) -> str
    # float arithmetic / comparison via SSE (operand type `ty` drives ss vs sd).
    if (irt_is_float ty)
        let sfx = (sse_sfx ty)
        let fout = (load_xmm bx "%xmm0" lhs)
        set fout = (strings::concat fout (load_xmm bx "%xmm1" rhs))
        if (is_cmp_op op)
            set fout = (strings::concat fout (line (cat3 "    ucomi" sfx " %xmm1, %xmm0")))
            set fout = (strings::concat fout (float_cmp_seq op))
            set fout = (strings::concat fout (line "    movzbq %al, %rax"))
            return (strings::concat fout (store_rax bx dst))
        end
        if (or (strings::eq op "/") (strings::eq op "%"))
            # divide/modulo by zero panics (oracle parity) rather than IEEE inf/nan.
            # ucomi sets PF on an unordered (NaN) compare — skip the panic there
            # (x / NaN = NaN, not a divide-by-zero); panic only on an ordered ==0.
            let dok = (lbl bx (strings::concat "fdivok_" (iv_key dst)))
            set fout = (strings::concat fout (line "    xorps %xmm2, %xmm2"))
            set fout = (strings::concat fout (line (cat3 "    ucomi" sfx " %xmm2, %xmm1")))
            set fout = (strings::concat fout (line (cat2 "    jp " dok)))
            set fout = (strings::concat fout (line (cat2 "    jne " dok)))
            set fout = (strings::concat fout (line "    leaq .Lcl_fdivzero(%rip), %rdi"))
            set fout = (strings::concat fout (line "    call cl_panic_cstr"))
            set fout = (strings::concat fout (line (cat2 dok ":")))
        end
        set fout = (strings::concat fout (line (cat3 "    " (float_arith_op op sfx) " %xmm1, %xmm0")))
        return (strings::concat fout (store_xmm bx "%xmm0" dst))
    end
    let bits = (irt_bits ty)
    let signed = (irt_signed ty)
    let out = ""
    set out = (strings::concat out (load_into bx "%rax" lhs))
    set out = (strings::concat out (load_into bx "%rcx" rhs))
    if (is_cmp_op op)
        # comparison operands carry the operand type's width/signedness; the result
        # is a bool (0/1).
        set out = (strings::concat out (line "    cmpq %rcx, %rax"))
        set out = (strings::concat out (line (cat3 "    " (cmp_setcc op signed) " %al")))
        set out = (strings::concat out (line "    movzbq %al, %rax"))
        set out = (strings::concat out (store_rax bx dst))
        return out
    end
    if (or (strings::eq op "/") (strings::eq op "%"))
        let okl = (lbl bx (strings::concat "divok_" (iv_key dst)))
        set out = (strings::concat out (line "    testq %rcx, %rcx"))
        set out = (strings::concat out (line (cat2 "    jne " okl)))
        set out = (strings::concat out (line "    leaq .Lcl_divzero(%rip), %rdi"))
        set out = (strings::concat out (line "    call cl_panic_cstr"))
        set out = (strings::concat out (line (cat2 okl ":")))
        if signed
            # idivq raises #DE (SIGFPE) on INT_MIN / -1 (quotient doesn't fit).
            # interp + C (-fwrapv) instead WRAP: quotient = -dividend (== INT_MIN),
            # remainder = 0. Special-case divisor == -1 to avoid the hardware trap.
            let dvok = (lbl bx (strings::concat "dvn1_" (iv_key dst)))
            let dvaf = (lbl bx (strings::concat "dvaf_" (iv_key dst)))
            set out = (strings::concat out (line "    cmpq $-1, %rcx"))
            set out = (strings::concat out (line (cat2 "    jne " dvok)))
            set out = (strings::concat out (line "    negq %rax"))
            set out = (strings::concat out (line "    xorl %edx, %edx"))
            set out = (strings::concat out (line (cat2 "    jmp " dvaf)))
            set out = (strings::concat out (line (cat2 dvok ":")))
            set out = (strings::concat out (line "    cqto"))
            set out = (strings::concat out (line "    idivq %rcx"))
            set out = (strings::concat out (line (cat2 dvaf ":")))
        else
            set out = (strings::concat out (line "    xorl %edx, %edx"))
            set out = (strings::concat out (line "    divq %rcx"))
        end
        if (strings::eq op "%")
            set out = (strings::concat out (line "    movq %rdx, %rax"))
        end
        set out = (strings::concat out (extend_rax bits signed))
        set out = (strings::concat out (store_rax bx dst))
        return out
    end
    # arithmetic / bitwise (fold target)
    if (strings::eq op "+")
        set out = (strings::concat out (line "    addq %rcx, %rax"))
    elsif (strings::eq op "-")
        set out = (strings::concat out (line "    subq %rcx, %rax"))
    elsif (strings::eq op "*")
        set out = (strings::concat out (line "    imulq %rcx, %rax"))
    elsif (strings::eq op "band")
        set out = (strings::concat out (line "    andq %rcx, %rax"))
    elsif (strings::eq op "bor")
        set out = (strings::concat out (line "    orq %rcx, %rax"))
    elsif (strings::eq op "bxor")
        set out = (strings::concat out (line "    xorq %rcx, %rax"))
    elsif (strings::eq op "shl")
        # x86 shift masks the count to 6 bits (0..63), so a count >= width would
        # wrap (e.g. shl by 64 -> by 0 -> identity). interp + C shift in wider
        # precision then truncate, so a count >= width yields 0. Guard it.
        let sbig = (lbl bx (strings::concat "shb_" (iv_key dst)))
        let saf = (lbl bx (strings::concat "shaf_" (iv_key dst)))
        set out = (strings::concat out (line (cat2 "    cmpq $" (cat2 (i2s bits) ", %rcx"))))
        set out = (strings::concat out (line (cat2 "    jae " sbig)))
        set out = (strings::concat out (line "    shlq %cl, %rax"))
        set out = (strings::concat out (line (cat2 "    jmp " saf)))
        set out = (strings::concat out (line (cat2 sbig ":")))
        set out = (strings::concat out (line "    xorl %eax, %eax"))
        set out = (strings::concat out (line (cat2 saf ":")))
    elsif (strings::eq op "shr")
        let sbig = (lbl bx (strings::concat "shb_" (iv_key dst)))
        let saf = (lbl bx (strings::concat "shaf_" (iv_key dst)))
        set out = (strings::concat out (line (cat2 "    cmpq $" (cat2 (i2s bits) ", %rcx"))))
        set out = (strings::concat out (line (cat2 "    jae " sbig)))
        if signed
            set out = (strings::concat out (line "    sarq %cl, %rax"))
        else
            set out = (strings::concat out (line "    shrq %cl, %rax"))
        end
        set out = (strings::concat out (line (cat2 "    jmp " saf)))
        set out = (strings::concat out (line (cat2 sbig ":")))
        if signed
            # arithmetic shift by >= width = fill with the sign bit (0 or -1).
            set out = (strings::concat out (line "    sarq $63, %rax"))
        else
            set out = (strings::concat out (line "    xorl %eax, %eax"))
        end
        set out = (strings::concat out (line (cat2 saf ":")))
    else
        do (panic (strings::concat "x86: unsupported binary op " op))
    end
    if chk
        # width overflow: raw 64-bit result vs its normalized (truncated) form.
        set out = (strings::concat out (line "    movq %rax, %rdx"))
        set out = (strings::concat out (extend_rax bits signed))
        let okl = (lbl bx (strings::concat "ovok_" (iv_key dst)))
        set out = (strings::concat out (line "    cmpq %rax, %rdx"))
        set out = (strings::concat out (line (cat2 "    je " okl)))
        set out = (strings::concat out (line "    leaq .Lcl_overflow(%rip), %rdi"))
        set out = (strings::concat out (line "    call cl_panic_cstr"))
        set out = (strings::concat out (line (cat2 okl ":")))
    else
        set out = (strings::concat out (extend_rax bits signed))
    end
    set out = (strings::concat out (store_rax bx dst))
    return out
end

func emit_un (bx BX) (dst IVal) (op str) (v IVal) (ty IRType) (chk bool) -> str
    # float unary minus: flip the sign bit via xmm (reg-form xor, no alignment req).
    if (irt_is_float ty)
        let fout = (load_xmm bx "%xmm0" v)
        if (irt_f32 ty)
            set fout = (strings::concat fout (line "    movl $0x80000000, %eax"))
            set fout = (strings::concat fout (line "    movd %eax, %xmm1"))
            set fout = (strings::concat fout (line "    xorps %xmm1, %xmm0"))
        else
            set fout = (strings::concat fout (line "    movabsq $0x8000000000000000, %rax"))
            set fout = (strings::concat fout (line "    movq %rax, %xmm1"))
            set fout = (strings::concat fout (line "    xorpd %xmm1, %xmm0"))
        end
        return (strings::concat fout (store_xmm bx "%xmm0" dst))
    end
    let bits = (irt_bits ty)
    let signed = (irt_signed ty)
    let out = (load_into bx "%rax" v)
    if (strings::eq op "not")
        set out = (strings::concat out (line "    testq %rax, %rax"))
        set out = (strings::concat out (line "    sete %al"))
        set out = (strings::concat out (line "    movzbq %al, %rax"))
        set out = (strings::concat out (store_rax bx dst))
        return out
    end
    if (strings::eq op "bnot")
        set out = (strings::concat out (line "    notq %rax"))
        set out = (strings::concat out (extend_rax bits signed))
        set out = (strings::concat out (store_rax bx dst))
        return out
    end
    # unary minus
    set out = (strings::concat out (line "    negq %rax"))
    set out = (strings::concat out (extend_rax bits signed))
    set out = (strings::concat out (store_rax bx dst))
    return out
end

# Materialize one argument's words into consecutive scratch slots starting at word
# index `w0`; returns the asm and the next free word index. ≤8B args use one word
# (via load_to_rax, handling string literals); a cl_closure (16B) copies 2 words.
func emit_park_arg (bx BX) (a IVal) (w0 i64) -> str
    if (irt_is_float (iv_ty a))
        # park a float's bits into one scratch word (via xmm0)
        let out = (load_xmm bx "%xmm0" a)
        return (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx (iv_ty a))) " %xmm0, " (off_mem (+ bx.scratch (* w0 8i64))))))
    end
    let nw = (nwords (iv_ty a) bx.structs)
    if (== nw 1i64)
        let out = (load_to_rax bx a)
        return (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ bx.scratch (* w0 8i64))) "")))
    end
    # multi-word value (e.g. a closure) lives in a slot: copy word by word
    let out = ""
    let w = 0i64
    while (< w nw)
        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key a)) (* w 8i64))) ", %rax"))))
        set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ bx.scratch (* (+ w0 w) 8i64))) "")))
        set w = (+ w 1i64)
    end
    return out
end

# Copy a stack-passed argument's words to (off)(%rsp). A slot/MEMORY value is copied
# word by word; an immediate is materialized. (ImmStr stack args aren't needed yet.)
func emit_store_arg_to_stack (bx BX) (a IVal) (off i64) -> str
    if (irt_is_float (iv_ty a))
        let out = (load_xmm bx "%xmm0" a)
        return (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx (iv_ty a))) " %xmm0, " (cat2 (i2s off) "(%rsp)"))))
    end
    match a
        case (Temp id ty)
            let out = ""
            let nw = (nwords ty bx.structs)
            let w = 0i64
            while (< w nw)
                set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (tkey id)) (* w 8i64))) ", %rax"))))
                set out = (strings::concat out (line (cat2 "    movq %rax, " (cat2 (i2s (+ off (* w 8i64))) "(%rsp)"))))
                set w = (+ w 1i64)
            end
            return out
        case (Local name ty)
            let out = ""
            let nw = (nwords ty bx.structs)
            let w = 0i64
            while (< w nw)
                set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (lkey name)) (* w 8i64))) ", %rax"))))
                set out = (strings::concat out (line (cat2 "    movq %rax, " (cat2 (i2s (+ off (* w 8i64))) "(%rsp)"))))
                set w = (+ w 1i64)
            end
            return out
        else
            let out = (load_to_rax bx a)
            return (strings::concat out (line (cat2 "    movq %rax, " (cat2 (i2s off) "(%rsp)"))))
    end
    return ""
end

func emit_call (bx BX) (has_dst bool) (dst IVal) (callee str) (args {IVal}) -> str
    let out = ""
    # A result larger than 16 bytes is returned via a hidden pointer (SysV MEMORY):
    # &dst is passed in %rdi and the real args shift up one register.
    let hidden = false
    if has_dst
        if (> (nwords (iv_ty dst) bx.structs) 2i64)
            set hidden = true
        end
    end
    let base = 0i64
    if hidden
        set base = 1i64
    end
    # Classify each arg (SysV): floats -> xmm0..7; ≤16B integer aggregates -> GP regs
    # if they fit, else stack; >16B -> stack (MEMORY). Reg/xmm args are parked into
    # scratch now (before any %rsp change, so a strlit/movsd while parking stays
    # 16-aligned). argcat: 0=GP, 1=xmm, 2=stack.
    let argcat {i64} = (vec i64)
    let argscr {i64} = (vec i64)
    let argoff {i64} = (vec i64)
    let gpw = 0i64
    let xmmw = 0i64
    let pw = 0i64
    let stackbytes = 0i64
    let i = 0u64
    while (< i (len args))
        if (irt_is_float (iv_ty args[i]))
            if (< xmmw 8i64)
                set out = (strings::concat out (emit_park_arg bx args[i] pw))
                do (push argcat 1i64)
                do (push argscr pw)
                do (push argoff 0i64)
                set pw = (+ pw 1i64)
                set xmmw = (+ xmmw 1i64)
            else
                do (push argcat 2i64)
                do (push argscr 0i64)
                do (push argoff stackbytes)
                set stackbytes = (+ stackbytes 8i64)
            end
        else
            let k = (nwords (iv_ty args[i]) bx.structs)
            if (and (<= k 2i64) (<= (+ (+ base gpw) k) 6i64))
                set out = (strings::concat out (emit_park_arg bx args[i] pw))
                do (push argcat 0i64)
                do (push argscr pw)
                do (push argoff 0i64)
                set pw = (+ pw k)
                set gpw = (+ gpw k)
            else
                do (push argcat 2i64)
                do (push argscr 0i64)
                do (push argoff stackbytes)
                set stackbytes = (+ stackbytes (* k 8i64))
            end
        end
        set i = (+ i 1)
    end
    let memtotal = (round16 stackbytes)
    if (> memtotal 0i64)
        set out = (strings::concat out (line (cat2 "    subq $" (cat2 (i2s memtotal) ", %rsp"))))
    end
    # copy stack args to (off)(%rsp), in source order
    set i = 0u64
    while (< i (len args))
        if (== argcat[i] 2i64)
            set out = (strings::concat out (emit_store_arg_to_stack bx args[i] argoff[i]))
        end
        set i = (+ i 1)
    end
    if hidden
        set out = (strings::concat out (line (cat3 "    leaq " (off_mem (slot_off bx (iv_key dst))) ", %rdi")))
    end
    # load GP args into %rdi.. (after the hidden base), in source order
    let gpreg = base
    set i = 0u64
    while (< i (len args))
        if (== argcat[i] 0i64)
            let k = (nwords (iv_ty args[i]) bx.structs)
            let w = 0i64
            while (< w k)
                set out = (strings::concat out (line (cat3 "    movq " (cat2 (off_mem (+ bx.scratch (* (+ argscr[i] w) 8i64))) ", ") (argreg gpreg))))
                set gpreg = (+ gpreg 1i64)
                set w = (+ w 1i64)
            end
        end
        set i = (+ i 1)
    end
    # load float args into %xmm0.., in source order
    let xreg = 0i64
    set i = 0u64
    while (< i (len args))
        if (== argcat[i] 1i64)
            set out = (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx (iv_ty args[i]))) " " (cat3 (off_mem (+ bx.scratch (* argscr[i] 8i64))) ", %xmm" (i2s xreg)))))
            set xreg = (+ xreg 1i64)
        end
        set i = (+ i 1)
    end
    set out = (strings::concat out (line (cat2 "    call " callee)))
    if (> memtotal 0i64)
        set out = (strings::concat out (line (cat2 "    addq $" (cat2 (i2s memtotal) ", %rsp"))))
    end
    if has_dst
        if hidden
            pass
        elsif (irt_is_float (iv_ty dst))
            set out = (strings::concat out (store_xmm bx "%xmm0" dst))
        elsif (> (nwords (iv_ty dst) bx.structs) 1i64)
            # 9..16-byte result (e.g. cl_closure) returned in %rax:%rdx
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (slot_off bx (iv_key dst))) "")))
            set out = (strings::concat out (line (cat3 "    movq %rdx, " (off_mem (+ (slot_off bx (iv_key dst)) 8i64)) "")))
        else
            set out = (strings::concat out (store_result_rax bx dst))
        end
    end
    return out
end

# --- function-as-value thunks ---------------------------------------------- #

func tfn_params (t Type) -> {Type}
    match t
        case (TFunc p r)
            return p
        else
            return (vec Type)
    end
    return (vec Type)
end

# GP-register words a by-value argument consumes in the SysV integer class. A float
# travels in an xmm register (0 GP words); a closure value is 2 GP words. Struct and
# array by-value params in a function-VALUE thunk aren't supported yet — lambdas
# handle them, only the named-function adapter is partial.
func gp_words_src (t Type) -> i64
    match t
        case (TFloat n)
            return 0i64
        case (TFunc p r)
            return 2i64
        case (TStruct n)
            do (panic "x86: by-value struct thunk param (later milestone)")
        case (TArray e)
            do (panic "x86: by-value array thunk param (later milestone)")
        else
            return 1i64
    end
    return 1i64
end

# Does a function-value's return travel via a hidden pointer (SysV MEMORY, >16B)?
# Only a by-value struct return can; every other return type is <=16B.
func ret_is_mem (ft Type) (sm {str IRStruct}) -> bool
    match ft
        case (TFunc p r)
            match r
                case (TStruct n)
                    return (> (struct_size sm n) 16i64)
                else
                    return false
            end
        else
            return false
    end
    return false
end

func bc_str_lt (a str) (b str) -> bool
    let ca = (strings::chars a)
    let cb = (strings::chars b)
    let n = (len ca)
    if (< (len cb) n)
        set n = (len cb)
    end
    let i = 0u64
    while (< i n)
        let xa = (convert::ord ca[i])
        let xb = (convert::ord cb[i])
        if (< xa xb)
            return true
        end
        if (> xa xb)
            return false
        end
        set i = (+ i 1)
    end
    return (< (len ca) (len cb))
end

func sorted_keys (m {str Type}) -> {str}
    let ks {str} = (vec str)
    for k in (map_keys m)
        do (push ks k)
    end
    let i = 1u64
    while (< i (len ks))
        let j = i
        while (and (> j 0u64) (bc_str_lt ks[j] ks[(- j 1u64)]))
            let tmp = ks[j]
            set ks[j] = ks[(- j 1u64)]
            set ks[(- j 1u64)] = tmp
            set j = (- j 1u64)
        end
        set i = (+ i 1)
    end
    return ks
end

# Same insertion sort, for a {str str} map (the string/float-literal pools).
func sorted_str_keys (m {str str}) -> {str}
    let ks {str} = (vec str)
    for k in (map_keys m)
        do (push ks k)
    end
    let i = 1u64
    while (< i (len ks))
        let j = i
        while (and (> j 0u64) (bc_str_lt ks[j] ks[(- j 1u64)]))
            let tmp = ks[j]
            set ks[j] = ks[(- j 1u64)]
            set ks[(- j 1u64)] = tmp
            set j = (- j 1u64)
        end
        set i = (+ i 1)
    end
    return ks
end

# A function-as-value thunk: drops the env arg the closure ABI inserts and shifts
# the real GP args down one register, then tail-calls the real function. The env is
# the first GP arg normally, or the SECOND when the result returns via a hidden
# pointer (SysV MEMORY) — which must be preserved in %rdi.
func emit_thunk (name str) (ft Type) (sm {str IRStruct}) -> str
    let ps = (tfn_params ft)
    let k = 0i64
    let i = 0u64
    while (< i (len ps))
        set k = (+ k (gp_words_src ps[i]))
        set i = (+ i 1)
    end
    let base = 0i64
    if (ret_is_mem ft sm)
        set base = 1i64
    end
    # Incoming closure-ABI GP usage = [hidden ret ptr] + env + args. If that spills
    # past the 6 GP registers the leading args arrived on the stack, and a register
    # shift + tail-call cannot relocate them. Fail loudly rather than miscompile.
    if (> (+ (+ base 1i64) k) 6i64)
        do (panic "x86: function-value thunk with stack-spilled args (later milestone)")
    end
    let out = (line (cat3 name "__thunk" ":"))
    let w = base
    while (< w (+ base k))
        set out = (strings::concat out (line (cat2 "    movq " (cat3 (argreg (+ w 1i64)) ", " (argreg w)))))
        set w = (+ w 1i64)
    end
    set out = (strings::concat out (line (cat2 "    jmp " name)))
    return out
end

func irt_is_str (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TPrim n)
                    return (strings::eq n "str")
                else
                    return false
            end
        else
            return false
    end
    return false
end

func place_ty (p IPlace) -> IRType
    match p
        case (PLocal name ty)
            return ty
        case (PField base field ty)
            return ty
        case (PDeref ptr ty)
            return ty
        case (PArrElem arr idx ty)
            return ty
        case (PVecElem vc idx ty)
            return ty
    end
    return VoidPtr
end

# The absolute frame offset of a struct place (PLocal / nested PField).
func place_abs_off (bx BX) (p IPlace) -> i64
    match p
        case (PLocal name ty)
            return (slot_off bx (lkey name))
        case (PField base field ty)
            return (+ (place_abs_off bx base) (field_offset bx.structs (irt_struct_qn (place_ty base)) field))
        else
            do (panic "x86: place has no frame offset")
    end
    return 0i64
end

# Compute the byte ADDRESS of any place into %rax. Handles frame places (PLocal /
# PField over frame) and heap places (PField over a container element, PArrElem /
# PVecElem, PDeref) by computing element/box addresses dynamically. Used for
# assignment targets the static-offset path can't express (e.g. set arr[i].x = v).
func emit_place_addr (bx BX) (p IPlace) -> str
    match p
        case (PLocal name ty)
            return (line (cat3 "    leaq " (off_mem (slot_off bx (lkey name))) ", %rax"))
        case (PField base field ty)
            let out = (emit_place_addr bx base)
            let foff = (field_offset bx.structs (irt_struct_qn (place_ty base)) field)
            if (== foff 0i64)
                return out
            end
            return (strings::concat out (line (cat2 "    addq $" (cat2 (i2s foff) ", %rax"))))
        case (PArrElem arr idx ty)
            return (emit_array_at bx arr idx)
        case (PVecElem vc idx ty)
            let out = (load_into bx "%rdi" vc)
            set out = (strings::concat out (load_into bx "%rsi" idx))
            return (strings::concat out (line "    call cl_vec_at"))
        case (PDeref ptr ty)
            let out = (load_into bx "%rdi" ptr)
            return (strings::concat out (line "    call cl_gc_deref"))
    end
    return ""
end

# cl_array_at(cl_array a, u64 i) -> element ptr in %rax. cl_array is 24 bytes, a
# SysV MEMORY-class arg: copy it onto the stack (reserve 32 to keep %rsp 16-aligned)
# while the INTEGER arg `i` goes in %rdi.
func emit_array_at (bx BX) (arr IVal) (idx IVal) -> str
    let out = (line "    subq $32, %rsp")
    let w = 0i64
    while (< w 3i64)
        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key arr)) (* w 8i64))) ", %rax"))))
        set out = (strings::concat out (line (cat2 "    movq %rax, " (cat2 (i2s (* w 8i64)) "(%rsp)"))))
        set w = (+ w 1i64)
    end
    set out = (strings::concat out (load_into bx "%rdi" idx))
    set out = (strings::concat out (line "    call cl_array_at"))
    set out = (strings::concat out (line "    addq $32, %rsp"))
    return out
end

# Copy `sz` bytes from scratch[0..] to (off)(%rax), using full 8-byte words then a
# 4/2/1-byte tail. Container element stride is the element type's size, which may
# NOT be a multiple of 8 (e.g. a 12-byte {i32,i32,i32} struct), so copying
# nwords*8 would overrun the next packed element / the heap buffer end.
func copy_scratch_to_rax (bx BX) (sz i64) -> str
    let out = ""
    let off = 0i64
    while (<= (+ off 8i64) sz)
        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ bx.scratch off)) ", %rcx"))))
        set out = (strings::concat out (line (cat2 "    movq %rcx, " (cat2 (i2s off) "(%rax)"))))
        set off = (+ off 8i64)
    end
    while (< off sz)
        let rem = (- sz off)
        if (>= rem 4i64)
            set out = (strings::concat out (line (cat2 "    movl " (cat2 (off_mem (+ bx.scratch off)) ", %ecx"))))
            set out = (strings::concat out (line (cat2 "    movl %ecx, " (cat2 (i2s off) "(%rax)"))))
            set off = (+ off 4i64)
        elsif (>= rem 2i64)
            set out = (strings::concat out (line (cat2 "    movw " (cat2 (off_mem (+ bx.scratch off)) ", %cx"))))
            set out = (strings::concat out (line (cat2 "    movw %cx, " (cat2 (i2s off) "(%rax)"))))
            set off = (+ off 2i64)
        else
            set out = (strings::concat out (line (cat2 "    movb " (cat2 (off_mem (+ bx.scratch off)) ", %cl"))))
            set out = (strings::concat out (line (cat2 "    movb %cl, " (cat2 (i2s off) "(%rax)"))))
            set off = (+ off 1i64)
        end
    end
    return out
end

# Copy `sz` bytes from (off)(%rax) into dst's frame slot (full words then 4/2/1 tail).
func copy_rax_to_slot (bx BX) (dst IVal) (sz i64) -> str
    let base = (slot_off bx (iv_key dst))
    let out = ""
    let off = 0i64
    while (<= (+ off 8i64) sz)
        set out = (strings::concat out (line (cat2 "    movq " (cat2 (i2s off) "(%rax), %rcx"))))
        set out = (strings::concat out (line (cat3 "    movq %rcx, " (off_mem (+ base off)) "")))
        set off = (+ off 8i64)
    end
    while (< off sz)
        let rem = (- sz off)
        if (>= rem 4i64)
            set out = (strings::concat out (line (cat2 "    movl " (cat2 (i2s off) "(%rax), %ecx"))))
            set out = (strings::concat out (line (cat3 "    movl %ecx, " (off_mem (+ base off)) "")))
            set off = (+ off 4i64)
        elsif (>= rem 2i64)
            set out = (strings::concat out (line (cat2 "    movw " (cat2 (i2s off) "(%rax), %cx"))))
            set out = (strings::concat out (line (cat3 "    movw %cx, " (off_mem (+ base off)) "")))
            set off = (+ off 2i64)
        else
            set out = (strings::concat out (line (cat2 "    movb " (cat2 (i2s off) "(%rax), %cl"))))
            set out = (strings::concat out (line (cat3 "    movb %cl, " (off_mem (+ base off)) "")))
            set off = (+ off 1i64)
        end
    end
    return out
end

# A size that load_sized/store_sized handle exactly with one mov (1/2/4/8). Other
# sizes (3/5/6/7) only arise for packed value structs/arrays and must be copied
# byte-accurately: store_sized would write 8 bytes (overrunning the next packed
# element) and load_sized would read only the low byte (dropping fields at >0).
func clean_word_size (sz i64) -> bool
    return (or (== sz 1i64) (or (== sz 2i64) (or (== sz 4i64) (== sz 8i64))))
end

# Store a container element (parked in scratch[0..]) into the buffer slot whose
# address is in %rax. ≤8B clean size: exact sized store; otherwise byte-accurate.
func store_elem_at_rax (bx BX) (ety IRType) -> str
    let nw = (nwords ety bx.structs)
    let sz = (type_size ety bx.structs)
    if (and (== nw 1i64) (clean_word_size sz))
        let out = (line (cat2 "    movq " (cat2 (off_mem bx.scratch) ", %rcx")))
        return (strings::concat out (store_sized sz "c" "(%rax)"))
    end
    return (copy_scratch_to_rax bx sz)
end

# Load a container element (buffer address in %rax) into dst's slot.
func load_elem_from_rax (bx BX) (dst IVal) (ty IRType) -> str
    let nw = (nwords ty bx.structs)
    let sz = (type_size ty bx.structs)
    if (and (== nw 1i64) (clean_word_size sz))
        let out = (load_sized sz (irt_signed ty) "(%rax)")
        return (strings::concat out (store_rax bx dst))
    end
    return (copy_rax_to_slot bx dst sz)
end

# Load a container element parked in scratch[0..] into dst's slot (for cl_vec_pop,
# which writes the popped element to the address we passed).
func load_elem_from_scratch (bx BX) (dst IVal) (ty IRType) -> str
    let nw = (nwords ty bx.structs)
    if (== nw 1i64)
        let out = (load_sized (type_size ty bx.structs) (irt_signed ty) (off_mem bx.scratch))
        return (strings::concat out (store_rax bx dst))
    end
    let out = ""
    let w = 0i64
    while (< w nw)
        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ bx.scratch (* w 8i64))) ", %rcx"))))
        set out = (strings::concat out (line (cat3 "    movq %rcx, " (off_mem (+ (slot_off bx (iv_key dst)) (* w 8i64))) "")))
        set w = (+ w 1i64)
    end
    return out
end

# cl_vec_push(vc, &elem): park the element's words in scratch, pass its address.
func emit_vec_push (bx BX) (vc IVal) (sval IVal) (esz i64) -> str
    # park ALL of the element's words (emit_park_arg copies multi-word values),
    # then pass &scratch (cl_vec_push copies elemsz bytes from there).
    let out = (emit_park_arg bx sval 0i64)
    set out = (strings::concat out (load_into bx "%rdi" vc))
    set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
    set out = (strings::concat out (line "    call cl_vec_push"))
    return out
end

# --------------------------------------------------------------------------- #
# Inline assembly (GCC extended form). Operands are numbered outputs-first, then
# inputs (matching the C backend / GCC %0,%1). Each operand is placed in a fixed
# register (constraints a/b/c/d/S/D), an allocated general register (r), or its
# frame memory slot (m); inputs are loaded before the template, register outputs
# stored after.
#
# Semantic note vs. GCC: every operand here gets a DISTINCT register (outputs are
# always effectively early-clobber — an output register never aliases an input).
# GCC may reuse a non-'&' output register for an input, so asm that relies on such
# aliasing is non-portable. Authors should treat outputs as early-clobber (use the
# constraint '&' for documentation; it is accepted and stripped). Narrow-int slots
# keep the backend invariant of holding a full sign/zero-extended 64-bit word.
# --------------------------------------------------------------------------- #

func asm_is_digit (c char) -> bool
    return (and (>= c '0') (<= c '9'))
end

func asm_mov_sfx (bits i64) -> str
    if (== bits 8i64)
        return "b"
    end
    if (== bits 16i64)
        return "w"
    end
    if (== bits 32i64)
        return "l"
    end
    return "q"
end

# Width-specific name for a register family (a/b/c/d/si/di/r8..r11).
func asm_xreg (fam str) (bits i64) -> str
    if (or (strings::eq fam "r8") (or (strings::eq fam "r9") (or (strings::eq fam "r10") (strings::eq fam "r11"))))
        if (== bits 8i64)
            return (strings::concat "%" (strings::concat fam "b"))
        end
        if (== bits 16i64)
            return (strings::concat "%" (strings::concat fam "w"))
        end
        if (== bits 32i64)
            return (strings::concat "%" (strings::concat fam "d"))
        end
        return (strings::concat "%" fam)
    end
    if (strings::eq fam "a")
        if (== bits 8i64)
            return "%al"
        end
        if (== bits 16i64)
            return "%ax"
        end
        if (== bits 32i64)
            return "%eax"
        end
        return "%rax"
    end
    if (strings::eq fam "b")
        if (== bits 8i64)
            return "%bl"
        end
        if (== bits 16i64)
            return "%bx"
        end
        if (== bits 32i64)
            return "%ebx"
        end
        return "%rbx"
    end
    if (strings::eq fam "c")
        if (== bits 8i64)
            return "%cl"
        end
        if (== bits 16i64)
            return "%cx"
        end
        if (== bits 32i64)
            return "%ecx"
        end
        return "%rcx"
    end
    if (strings::eq fam "d")
        if (== bits 8i64)
            return "%dl"
        end
        if (== bits 16i64)
            return "%dx"
        end
        if (== bits 32i64)
            return "%edx"
        end
        return "%rdx"
    end
    if (strings::eq fam "si")
        if (== bits 8i64)
            return "%sil"
        end
        if (== bits 16i64)
            return "%si"
        end
        if (== bits 32i64)
            return "%esi"
        end
        return "%rsi"
    end
    if (strings::eq fam "di")
        if (== bits 8i64)
            return "%dil"
        end
        if (== bits 16i64)
            return "%di"
        end
        if (== bits 32i64)
            return "%edi"
        end
        return "%rdi"
    end
    do (panic (strings::concat "x86 asm: unknown register family " fam))
    return "%rax"
end

# Constraint class after stripping =/+/& modifiers: a/b/c/d/si/di/r/m.
func asm_class (c str) -> str
    let cs = (strings::chars c)
    let i = 0u64
    while (< i (len cs))
        let ch = cs[i]
        if (or (== ch '=') (or (== ch '+') (== ch '&')))
            set i = (+ i 1u64)
        else
            if (== ch 'a')
                return "a"
            end
            if (== ch 'b')
                return "b"
            end
            if (== ch 'c')
                return "c"
            end
            if (== ch 'd')
                return "d"
            end
            if (== ch 'S')
                return "si"
            end
            if (== ch 'D')
                return "di"
            end
            if (or (== ch 'r') (or (== ch 'q') (== ch 'Q')))
                return "r"
            end
            if (== ch 'm')
                return "m"
            end
            do (panic (strings::concat "x86 asm: unsupported constraint " c))
        end
    end
    do (panic (strings::concat "x86 asm: empty constraint " c))
    return "r"
end

func asm_is_inout (c str) -> bool
    let cs = (strings::chars c)
    let i = 0u64
    while (< i (len cs))
        if (== cs[i] '+')
            return true
        end
        set i = (+ i 1u64)
    end
    return false
end

# First free register family from the scratch pool (rbx excluded: callee-saved).
func asm_alloc_reg (used {str bool}) -> str
    let pool {str} = (vec str)
    do (push pool "r10")
    do (push pool "r11")
    do (push pool "r8")
    do (push pool "r9")
    do (push pool "a")
    do (push pool "c")
    do (push pool "d")
    do (push pool "si")
    do (push pool "di")
    let i = 0u64
    while (< i (len pool))
        if (not (map_has used pool[i]))
            return pool[i]
        end
        set i = (+ i 1u64)
    end
    do (panic "x86 asm: out of registers for 'r' operands")
    return "a"
end

# Map a clobber name (e.g. "rax", "r10") to a register family, "" if not a reg.
func asm_clobber_fam (n str) -> str
    if (or (strings::eq n "rax") (or (strings::eq n "eax") (or (strings::eq n "ax") (strings::eq n "al"))))
        return "a"
    end
    if (or (strings::eq n "rbx") (or (strings::eq n "ebx") (or (strings::eq n "bx") (strings::eq n "bl"))))
        return "b"
    end
    if (or (strings::eq n "rcx") (or (strings::eq n "ecx") (or (strings::eq n "cx") (strings::eq n "cl"))))
        return "c"
    end
    if (or (strings::eq n "rdx") (or (strings::eq n "edx") (or (strings::eq n "dx") (strings::eq n "dl"))))
        return "d"
    end
    if (or (strings::eq n "rsi") (or (strings::eq n "esi") (strings::eq n "si")))
        return "si"
    end
    if (or (strings::eq n "rdi") (or (strings::eq n "edi") (strings::eq n "di")))
        return "di"
    end
    if (strings::eq n "r8")
        return "r8"
    end
    if (strings::eq n "r9")
        return "r9"
    end
    if (strings::eq n "r10")
        return "r10"
    end
    if (strings::eq n "r11")
        return "r11"
    end
    return ""
end

# The numeric value of a run of digit chars starting at j; returns (value, next).
func asm_read_num (cs [char]) (j u64) (n u64) -> i64
    let num = 0i64
    let k = j
    while (and (< k n) (asm_is_digit cs[k]))
        set num = (+ (* num 10i64) (as (- (convert::ord cs[k]) (convert::ord '0')) i64))
        set k = (+ k 1u64)
    end
    return num
end

func asm_skip_num (cs [char]) (j u64) (n u64) -> u64
    let k = j
    while (and (< k n) (asm_is_digit cs[k]))
        set k = (+ k 1u64)
    end
    return k
end

# Substitute %N / %%/%b%w%k%qN operand references in the template.
func asm_subst (template str) (opfam {str}) (opbits {i64}) (opmem {bool}) (opref {str}) -> str
    let cs = (strings::chars template)
    let n = (len cs)
    let out = ""
    let i = 0u64
    while (< i n)
        if (not (== cs[i] '%'))
            set out = (strings::concat out (strings::from_char cs[i]))
            set i = (+ i 1u64)
        else
            if (>= (+ i 1u64) n)
                set out = (strings::concat out "%")
                set i = (+ i 1u64)
            else
                let d = cs[(+ i 1u64)]
                if (== d '%')
                    set out = (strings::concat out "%")
                    set i = (+ i 2u64)
                elsif (asm_is_digit d)
                    let num = (asm_read_num cs (+ i 1u64) n)
                    set out = (strings::concat out opref[(as num u64)])
                    set i = (asm_skip_num cs (+ i 1u64) n)
                else
                    let mb = 0i64
                    if (== d 'b')
                        set mb = 8i64
                    end
                    if (== d 'w')
                        set mb = 16i64
                    end
                    if (== d 'k')
                        set mb = 32i64
                    end
                    if (== d 'q')
                        set mb = 64i64
                    end
                    if (and (> mb 0i64) (and (< (+ i 2u64) n) (asm_is_digit cs[(+ i 2u64)])))
                        let num = (asm_read_num cs (+ i 2u64) n)
                        let idx = (as num u64)
                        if opmem[idx]
                            set out = (strings::concat out opref[idx])
                        else
                            set out = (strings::concat out (asm_xreg opfam[idx] mb))
                        end
                        set i = (asm_skip_num cs (+ i 2u64) n)
                    else
                        set out = (strings::concat out "%")
                        set i = (+ i 1u64)
                    end
                end
            end
        end
    end
    return out
end

# Sign/zero-extend a `bits`-wide result already in register family `fam` to the
# full 64-bit register, preserving the backend invariant that narrow-int slots
# hold a full extended word. No-op at 64 bits.
func asm_extend_reg (fam str) (bits i64) (signed bool) -> str
    if (== bits 64i64)
        return ""
    end
    let narrow = (asm_xreg fam bits)
    let full = (asm_xreg fam 64i64)
    if signed
        if (== bits 8i64)
            return (line (cat3 "    movsbq " narrow (cat2 ", " full)))
        end
        if (== bits 16i64)
            return (line (cat3 "    movswq " narrow (cat2 ", " full)))
        end
        return (line (cat3 "    movslq " narrow (cat2 ", " full)))
    end
    if (== bits 8i64)
        return (line (cat3 "    movzbq " narrow (cat2 ", " full)))
    end
    if (== bits 16i64)
        return (line (cat3 "    movzwq " narrow (cat2 ", " full)))
    end
    # 32-bit zero-extend: writing the 32-bit subreg clears the upper half
    return (line (cat3 "    movl " (asm_xreg fam 32i64) (cat2 ", " (asm_xreg fam 32i64))))
end

# Load a `bits`-wide value from memory operand `slot`, sign/zero-extended, into
# the full 64-bit register of family `fam`.
func asm_load_ext_slot (slot str) (fam str) (bits i64) (signed bool) -> str
    let full = (asm_xreg fam 64i64)
    if signed
        if (== bits 8i64)
            return (line (cat3 "    movsbq " slot (cat2 ", " full)))
        end
        if (== bits 16i64)
            return (line (cat3 "    movswq " slot (cat2 ", " full)))
        end
        return (line (cat3 "    movslq " slot (cat2 ", " full)))
    end
    if (== bits 8i64)
        return (line (cat3 "    movzbq " slot (cat2 ", " full)))
    end
    if (== bits 16i64)
        return (line (cat3 "    movzwq " slot (cat2 ", " full)))
    end
    return (line (cat3 "    movl " slot (cat2 ", " (asm_xreg fam 32i64))))
end

func emit_asm (bx BX) (template str) (outs {IAsmOp}) (ins {IAsmOp}) (clobbers {str}) -> str
    # combined operand list: outputs first (GCC numbering)
    let ops {IAsmOp} = (vec IAsmOp)
    let i = 0u64
    while (< i (len outs))
        do (push ops outs[i])
        set i = (+ i 1u64)
    end
    set i = 0u64
    while (< i (len ins))
        do (push ops ins[i])
        set i = (+ i 1u64)
    end
    let nout = (len outs)
    # mark clobbered registers as used so 'r' allocation avoids them
    let used {str bool} = (map str bool)
    for cb in clobbers
        let f = (asm_clobber_fam cb)
        if (not (strings::eq f ""))
            set used[f] = true
        end
    end
    # pass 1: classify; reserve fixed-register and memory operands
    let opfam {str} = (vec str)
    let opbits {i64} = (vec i64)
    let opmem {bool} = (vec bool)
    set i = 0u64
    while (< i (len ops))
        let cls = (asm_class ops[i].constraint)
        let bits = (* (type_size (iv_ty ops[i].val) bx.structs) 8i64)
        if (> bits 64i64)
            set bits = 64i64
        end
        do (push opbits bits)
        if (strings::eq cls "m")
            do (push opfam "")
            do (push opmem true)
        elsif (strings::eq cls "r")
            do (push opfam "")
            do (push opmem false)
        else
            set used[cls] = true
            do (push opfam cls)
            do (push opmem false)
        end
        set i = (+ i 1u64)
    end
    # pass 2: allocate 'r' operands (opmem false, opfam "")
    set i = 0u64
    while (< i (len ops))
        if (and (not opmem[i]) (strings::eq opfam[i] ""))
            let f = (asm_alloc_reg used)
            set opfam[i] = f
            set used[f] = true
        end
        set i = (+ i 1u64)
    end
    # build %N reference strings (register name or memory slot operand)
    let opref {str} = (vec str)
    set i = 0u64
    while (< i (len ops))
        if opmem[i]
            do (push opref (off_mem (slot_off bx (iv_key ops[i].val))))
        else
            do (push opref (asm_xreg opfam[i] opbits[i]))
        end
        set i = (+ i 1u64)
    end
    let out = ""
    # load inputs (and '+' inout outputs) into their registers. The slot holds a
    # full 64-bit extended word, so a movq gives the correctly-extended value (the
    # narrow %N view is just its low subreg; %q0 sees the full extended value).
    set i = 0u64
    while (< i (len ops))
        let isout = (< i nout)
        let load = (or (not isout) (asm_is_inout ops[i].constraint))
        if (and load (not opmem[i]))
            set out = (strings::concat out (line (cat3 "    movq " (off_mem (slot_off bx (iv_key ops[i].val))) (cat2 ", " (asm_xreg opfam[i] 64i64)))))
        end
        set i = (+ i 1u64)
    end
    # the verbatim template (operands substituted)
    set out = (strings::concat out (line (strings::concat "    " (asm_subst template opfam opbits opmem opref))))
    # store outputs back, re-establishing the full-word sign/zero-extended slot
    # invariant for narrow integers (the template wrote only the narrow subreg/slot).
    set i = 0u64
    while (< i nout)
        let oty = (iv_ty ops[i].val)
        let osg = (irt_signed oty)
        let oslot = (off_mem (slot_off bx (iv_key ops[i].val)))
        if (not opmem[i])
            set out = (strings::concat out (asm_extend_reg opfam[i] opbits[i] osg))
            set out = (strings::concat out (line (cat3 "    movq " (asm_xreg opfam[i] 64i64) (cat2 ", " oslot))))
        elsif (< opbits[i] 64i64)
            let scr = (asm_alloc_reg used)
            set out = (strings::concat out (asm_load_ext_slot oslot scr opbits[i] osg))
            set out = (strings::concat out (line (cat3 "    movq " (asm_xreg scr 64i64) (cat2 ", " oslot))))
        end
        set i = (+ i 1u64)
    end
    return out
end

func emit_instr (bx BX) (ins Instr) (nroots i64) -> str
    match ins
        case (IConst dst v ty)
            if (or (irt_is_float ty) (irt_is_float (iv_ty v)))
                let out = (load_xmm bx "%xmm0" v)
                return (strings::concat out (store_xmm bx "%xmm0" dst))
            end
            let out = (load_to_rax bx v)
            return (strings::concat out (store_rax bx dst))
        case (IBin dst op lhs rhs ty chk)
            return (emit_bin bx dst op lhs rhs ty chk)
        case (IUn dst op v ty chk)
            return (emit_un bx dst op v ty chk)
        case (ICast dst v toty)
            let fromf = (irt_is_float (iv_ty v))
            let tof = (irt_is_float toty)
            if (and fromf tof)
                # f32<->f64 (or same): convert via xmm, or just move if same width
                let out = (load_xmm bx "%xmm0" v)
                if (irt_f32 (iv_ty v))
                    if (not (irt_f32 toty))
                        set out = (strings::concat out (line "    cvtss2sd %xmm0, %xmm0"))
                    end
                else
                    if (irt_f32 toty)
                        set out = (strings::concat out (line "    cvtsd2ss %xmm0, %xmm0"))
                    end
                end
                return (strings::concat out (store_xmm bx "%xmm0" dst))
            end
            if tof
                # int -> float: cvtsi2sd/ss from a 64-bit GP reg (operand normalized)
                let out = (load_into bx "%rax" v)
                set out = (strings::concat out (extend_rax (irt_bits (iv_ty v)) (irt_signed (iv_ty v))))
                # u64 -> float: cvtsi2sd treats %rax as a SIGNED 64-bit int, so a
                # value >= 2^63 converts to a negative double. Use the standard
                # unsigned 64-bit conversion (matches C / the interpreter): for a
                # negative-as-signed value, halve with a sticky low bit, convert,
                # then double back.
                if (and (== (irt_bits (iv_ty v)) 64i64) (not (irt_signed (iv_ty v))))
                    let neg = (lbl bx (strings::concat "u2f_neg_" (iv_key dst)))
                    let done = (lbl bx (strings::concat "u2f_done_" (iv_key dst)))
                    set out = (strings::concat out (line "    testq %rax, %rax"))
                    set out = (strings::concat out (line (cat2 "    js " neg)))
                    set out = (strings::concat out (line (cat3 "    cvtsi2" (sse_sfx toty) "q %rax, %xmm0")))
                    set out = (strings::concat out (line (cat2 "    jmp " done)))
                    set out = (strings::concat out (line (cat2 neg ":")))
                    set out = (strings::concat out (line "    movq %rax, %rdx"))
                    set out = (strings::concat out (line "    shrq $1, %rdx"))
                    set out = (strings::concat out (line "    andq $1, %rax"))
                    set out = (strings::concat out (line "    orq %rax, %rdx"))
                    set out = (strings::concat out (line (cat3 "    cvtsi2" (sse_sfx toty) "q %rdx, %xmm0")))
                    set out = (strings::concat out (line (cat3 "    add" (sse_sfx toty) " %xmm0, %xmm0")))
                    set out = (strings::concat out (line (cat2 done ":")))
                    return (strings::concat out (store_xmm bx "%xmm0" dst))
                end
                set out = (strings::concat out (line (cat3 "    cvtsi2" (sse_sfx toty) "q %rax, %xmm0")))
                return (strings::concat out (store_xmm bx "%xmm0" dst))
            end
            if fromf
                # float -> int: truncate toward zero (matches C / the interpreter)
                let out = (load_xmm bx "%xmm0" v)
                let csfx = (sse_sfx (iv_ty v))
                # float -> u64: cvtt..2siq is a SIGNED truncation, so a value >= 2^63
                # overflows i64 and yields the integer-indefinite (0x8000…). Do the
                # unsigned conversion: below 2^63 convert directly; at/above, subtract
                # 2^63, convert, then set bit 63. (Mirror of the u64 -> float case.)
                if (and (== (irt_bits toty) 64i64) (not (irt_signed toty)))
                    let p63 = (float_pool_add bx.floats "9223372036854775808.0" (irt_f32 (iv_ty v)))
                    let big = (lbl bx (strings::concat "f2u_big_" (iv_key dst)))
                    let done = (lbl bx (strings::concat "f2u_done_" (iv_key dst)))
                    set out = (strings::concat out (line (cat3 (cat2 "    mov" csfx) (cat2 " " p63) "(%rip), %xmm1")))
                    set out = (strings::concat out (line (cat3 "    comi" csfx " %xmm1, %xmm0")))
                    set out = (strings::concat out (line (cat2 "    jae " big)))
                    set out = (strings::concat out (line (cat3 "    cvtt" csfx "2siq %xmm0, %rax")))
                    set out = (strings::concat out (line (cat2 "    jmp " done)))
                    set out = (strings::concat out (line (cat2 big ":")))
                    set out = (strings::concat out (line (cat3 "    sub" csfx " %xmm1, %xmm0")))
                    set out = (strings::concat out (line (cat3 "    cvtt" csfx "2siq %xmm0, %rax")))
                    set out = (strings::concat out (line "    movabsq $0x8000000000000000, %rdx"))
                    set out = (strings::concat out (line "    xorq %rdx, %rax"))
                    set out = (strings::concat out (line (cat2 done ":")))
                    return (strings::concat out (store_rax bx dst))
                end
                set out = (strings::concat out (line (cat3 "    cvtt" csfx "2siq %xmm0, %rax")))
                set out = (strings::concat out (extend_rax (irt_bits toty) (irt_signed toty)))
                return (strings::concat out (store_rax bx dst))
            end
            # int<->int: load, normalize to the target width, store.
            let out = (load_into bx "%rax" v)
            set out = (strings::concat out (extend_rax (irt_bits toty) (irt_signed toty)))
            return (strings::concat out (store_rax bx dst))
        case (IAssign p src)
            match p
                case (PLocal name ty)
                    # float: move via xmm (movss/movsd) into the slot
                    if (irt_is_float ty)
                        let out = (load_xmm bx "%xmm0" src)
                        return (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx ty)) " %xmm0, " (off_mem (slot_off bx (lkey name))))))
                    end
                    # multi-word value (e.g. a cl_closure): copy word by word
                    if (> (nwords ty bx.structs) 1i64)
                        let out = ""
                        let w = 0i64
                        let nw = (nwords ty bx.structs)
                        while (< w nw)
                            set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key src)) (* w 8i64))) ", %rax"))))
                            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ (slot_off bx (lkey name)) (* w 8i64))) "")))
                            set w = (+ w 1i64)
                        end
                        return out
                    end
                    let out = (load_to_rax bx src)
                    return (strings::concat out (line (cat3 "    movq %rax, " (off_mem (slot_off bx (lkey name))) "")))
                case (PDeref ptr ty)
                    # store through a boxed variable: *(ty*)cl_gc_deref(ptr) = src
                    # (park src bits via emit_park_arg, which handles floats via xmm)
                    let out = (emit_park_arg bx src 0i64)
                    set out = (strings::concat out (load_into bx "%rdi" ptr))
                    set out = (strings::concat out (line "    call cl_gc_deref"))
                    let nw = (nwords ty bx.structs)
                    if (> nw 1i64)
                        # multi-word value (e.g. a >8B value struct boxed by capture):
                        # copy every parked word into the box payload at %rax.
                        let w = 0i64
                        while (< w nw)
                            set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ bx.scratch (* w 8i64))) ", %rcx"))))
                            set out = (strings::concat out (line (cat3 "    movq %rcx, " (cat2 (i2s (* w 8i64)) "(%rax)") "")))
                            set w = (+ w 1i64)
                        end
                        return out
                    end
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem bx.scratch) ", %rcx"))))
                    set out = (strings::concat out (store_sized (type_size ty bx.structs) "c" "(%rax)"))
                    return out
                case (PField base field ty)
                    # store into a struct field. Compute the field's ADDRESS into
                    # %rax (works whether the base is a frame local or a heap element
                    # like arr[i]/vec[i]); park src first (may strlit), then store.
                    let out = (emit_park_arg bx src 0i64)
                    set out = (strings::concat out (emit_place_addr bx base))
                    let foff = (field_offset bx.structs (irt_struct_qn (place_ty base)) field)
                    if (not (== foff 0i64))
                        set out = (strings::concat out (line (cat2 "    addq $" (cat2 (i2s foff) ", %rax"))))
                    end
                    set out = (strings::concat out (store_elem_at_rax bx ty))
                    return out
                case (PArrElem arr idx ty)
                    # set arr[i] = src  (element address via cl_array_at)
                    let out = (emit_park_arg bx src 0i64)
                    set out = (strings::concat out (emit_array_at bx arr idx))
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem bx.scratch) ", %rcx"))))
                    set out = (strings::concat out (store_sized (type_size ty bx.structs) "c" "(%rax)"))
                    return out
                case (PVecElem vc idx ty)
                    # set vec[i] = src  (element address via cl_vec_at)
                    let out = (emit_park_arg bx src 0i64)
                    set out = (strings::concat out (load_into bx "%rdi" vc))
                    set out = (strings::concat out (load_into bx "%rsi" idx))
                    set out = (strings::concat out (line "    call cl_vec_at"))
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem bx.scratch) ", %rcx"))))
                    set out = (strings::concat out (store_sized (type_size ty bx.structs) "c" "(%rax)"))
                    return out
                else
                    do (panic "x86: unsupported assignment place")
            end
        case (ICall has_dst dst callee args ty)
            return (emit_call bx has_dst dst callee args)
        case (IEnumConst dst enum_name variant intval)
            let out = (line (cat2 "    movq $" (cat2 (i2s intval) ", %rax")))
            return (strings::concat out (store_rax bx dst))
        case (IBr target)
            return (line (cat2 "    jmp " (lbl bx target)))
        case (ICondBr cond then_l else_l)
            let out = (load_into bx "%rax" cond)
            set out = (strings::concat out (line "    testq %rax, %rax"))
            set out = (strings::concat out (line (cat2 "    jne " (lbl bx then_l))))
            set out = (strings::concat out (line (cat2 "    jmp " (lbl bx else_l))))
            return out
        case (IRet has_val v)
            let out = ""
            if (> nroots 0i64)
                set out = (strings::concat out (line (cat2 "    movl $" (cat2 (i2s nroots) ", %edi"))))
                set out = (strings::concat out (line "    call cl_gc_pop_roots"))
            end
            if has_val
                if (irt_is_float (iv_ty v))
                    # floats return in %xmm0
                    set out = (strings::concat out (load_xmm bx "%xmm0" v))
                    set out = (strings::concat out (line "    leave"))
                    set out = (strings::concat out (line "    ret"))
                    return out
                end
                if bx.ret_mem
                    # >16B struct: copy the value to the caller's buffer (hidden ptr),
                    # return that pointer in %rax.
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem bx.hidden_ret) ", %rdi"))))
                    let nwr = (nwords (iv_ty v) bx.structs)
                    let w = 0i64
                    while (< w nwr)
                        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key v)) (* w 8i64))) ", %rax"))))
                        set out = (strings::concat out (line (cat2 "    movq %rax, " (cat2 (i2s (* w 8i64)) "(%rdi)"))))
                        set w = (+ w 1i64)
                    end
                    set out = (strings::concat out (line "    movq %rdi, %rax"))
                elsif (> (nwords (iv_ty v) bx.structs) 1i64)
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (slot_off bx (iv_key v))) ", %rax"))))
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key v)) 8i64)) ", %rdx"))))
                else
                    # load_to_rax (not load_into) so a bare `return "literal"` works
                    set out = (strings::concat out (load_to_rax bx v))
                end
            end
            set out = (strings::concat out (line "    leave"))
            set out = (strings::concat out (line "    ret"))
            return out
        case (IPanic msg)
            let out = (load_to_rax bx msg)
            set out = (strings::concat out (line "    movq %rax, %rdi"))
            set out = (strings::concat out (line "    call cl_panic"))
            return out
        case (IAsm template outs ins clobbers)
            return (emit_asm bx template outs ins clobbers)
        case (ISumNew dst variant_qual tag fnames fvals)
            # allocate the variant heap object {int32 cl_tag; payload...}, then
            # write the tag + each payload field through cl_gc_deref.
            let sz = (struct_size bx.structs variant_qual)
            let out = (line (cat2 "    movq $" (cat2 (i2s sz) ", %rdi")))
            set out = (strings::concat out (line "    call cl_gc_alloc"))
            set out = (strings::concat out (store_rax bx dst))
            # cl_tag at offset 0 (i32)
            set out = (strings::concat out (load_into bx "%rdi" dst))
            set out = (strings::concat out (line "    call cl_gc_deref"))
            set out = (strings::concat out (line (cat2 "    movl $" (cat2 (i2s tag) ", 0(%rax)"))))
            let k = 0u64
            while (< k (len fnames))
                let foff = (field_offset bx.structs variant_qual fnames[k])
                let fty = (field_type bx.structs variant_qual fnames[k])
                if (> (nwords fty bx.structs) 1i64)
                    # multi-word payload field (e.g. a value struct): copy all words
                    # from its slot to (foff+8w)(obj). The field value is a slot, so
                    # no pre-materialization is needed; deref the (rooted) object.
                    set out = (strings::concat out (load_into bx "%rdi" dst))
                    set out = (strings::concat out (line "    call cl_gc_deref"))
                    let nwf = (nwords fty bx.structs)
                    let w = 0i64
                    while (< w nwf)
                        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key fvals[k])) (* w 8i64))) ", %rcx"))))
                        set out = (strings::concat out (line (cat2 "    movq %rcx, " (cat2 (i2s (+ foff (* w 8i64))) "(%rax)"))))
                        set w = (+ w 1i64)
                    end
                else
                    # materialize the field value FIRST (may call cl_strlit / be a float),
                    # park it in a frame slot (NOT a push — that would misalign %rsp across
                    # the cl_gc_deref call), then deref the (rooted) object and store.
                    set out = (strings::concat out (emit_park_arg bx fvals[k] 0i64))
                    set out = (strings::concat out (load_into bx "%rdi" dst))
                    set out = (strings::concat out (line "    call cl_gc_deref"))
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem bx.scratch) ", %rcx"))))
                    set out = (strings::concat out (store_sized (type_size fty bx.structs) "c" (cat3 (i2s foff) "(%rax)" "")))
                end
                set k = (+ k 1)
            end
            return out
        case (ISumTag dst sm sum_qual)
            let out = (load_into bx "%rdi" sm)
            set out = (strings::concat out (line "    call cl_gc_deref"))
            set out = (strings::concat out (line "    movl 0(%rax), %eax"))
            set out = (strings::concat out (store_rax bx dst))
            return out
        case (ISumField dst sm variant_qual field ty)
            let foff = (field_offset bx.structs variant_qual field)
            let out = (load_into bx "%rdi" sm)
            set out = (strings::concat out (line "    call cl_gc_deref"))
            if (> (nwords ty bx.structs) 1i64)
                # multi-word payload field (e.g. a value struct): copy all its words
                let nw = (nwords ty bx.structs)
                let w = 0i64
                while (< w nw)
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (cat2 (i2s (+ foff (* w 8i64))) "(%rax)") ", %rcx"))))
                    set out = (strings::concat out (line (cat3 "    movq %rcx, " (off_mem (+ (slot_off bx (iv_key dst)) (* w 8i64))) "")))
                    set w = (+ w 1i64)
                end
                return out
            end
            set out = (strings::concat out (load_sized (type_size ty bx.structs) (irt_signed ty) (cat3 (i2s foff) "(%rax)" "")))
            set out = (strings::concat out (store_rax bx dst))
            return out
        case (IVecNew dst elem)
            let out = (line (cat2 "    movq $" (cat2 (i2s (type_size elem bx.structs)) ", %rdi")))
            set out = (strings::concat out (line "    call cl_vec_new"))
            return (strings::concat out (store_rax bx dst))
        case (IVecLit dst elem elems)
            let esz = (type_size elem bx.structs)
            let out = (line (cat2 "    movq $" (cat2 (i2s esz) ", %rdi")))
            set out = (strings::concat out (line "    call cl_vec_new"))
            set out = (strings::concat out (store_rax bx dst))
            let k = 0u64
            while (< k (len elems))
                set out = (strings::concat out (emit_vec_push bx dst elems[k] esz))
                set k = (+ k 1)
            end
            return out
        case (IVecLen dst vc)
            let out = (load_into bx "%rdi" vc)
            set out = (strings::concat out (line "    call cl_vec_len"))
            return (strings::concat out (store_rax bx dst))
        case (IVecGet dst vc idx ty)
            let out = (load_into bx "%rdi" vc)
            set out = (strings::concat out (load_into bx "%rsi" idx))
            set out = (strings::concat out (line "    call cl_vec_at"))
            return (strings::concat out (load_elem_from_rax bx dst ty))
        case (IVecSet vc idx sval elem)
            let out = (emit_park_arg bx sval 0i64)
            set out = (strings::concat out (load_into bx "%rdi" vc))
            set out = (strings::concat out (load_into bx "%rsi" idx))
            set out = (strings::concat out (line "    call cl_vec_at"))
            set out = (strings::concat out (store_elem_at_rax bx elem))
            return out
        case (IVecPush vc sval elem)
            return (emit_vec_push bx vc sval (type_size elem bx.structs))
        case (IVecPop dst vc elem)
            let out = (load_into bx "%rdi" vc)
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
            set out = (strings::concat out (line "    call cl_vec_pop"))
            return (strings::concat out (load_elem_from_scratch bx dst elem))
        case (IMapNew dst kty vty)
            let kind = "0"
            if (irt_is_str kty)
                set kind = "1"
            end
            let out = (line (cat2 "    movq $" (cat2 (i2s (type_size kty bx.structs)) ", %rdi")))
            set out = (strings::concat out (line (cat2 "    movq $" (cat2 (i2s (type_size vty bx.structs)) ", %rsi"))))
            set out = (strings::concat out (line (cat2 "    movq $" (cat2 kind ", %rdx"))))
            set out = (strings::concat out (line "    call cl_map_new"))
            return (strings::concat out (store_rax bx dst))
        case (IMapLen dst mp)
            let out = (load_into bx "%rdi" mp)
            set out = (strings::concat out (line "    call cl_map_len"))
            return (strings::concat out (store_rax bx dst))
        case (IMapGet dst mp ky kty vty)
            let out = (emit_park_arg bx ky 0i64)
            set out = (strings::concat out (load_into bx "%rdi" mp))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
            set out = (strings::concat out (line "    call cl_map_get"))
            return (strings::concat out (load_elem_from_rax bx dst vty))
        case (IMapSet mp ky sval kty vty)
            # key parked in scratch[0], value words in scratch[1..] (cl_map_set copies
            # keysz/valsz bytes from &key / &val).
            let out = (emit_park_arg bx ky 0i64)
            set out = (strings::concat out (emit_park_arg bx sval 1i64))
            set out = (strings::concat out (load_into bx "%rdi" mp))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem (+ bx.scratch 8i64)) ", %rdx"))))
            set out = (strings::concat out (line "    call cl_map_set"))
            return out
        case (IMapHas dst mp ky kty)
            let out = (load_to_rax bx ky)
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem bx.scratch) "")))
            set out = (strings::concat out (load_into bx "%rdi" mp))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
            set out = (strings::concat out (line "    call cl_map_has"))
            return (strings::concat out (store_rax bx dst))
        case (IMapDel mp ky kty)
            let out = (load_to_rax bx ky)
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem bx.scratch) "")))
            set out = (strings::concat out (load_into bx "%rdi" mp))
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem bx.scratch) ", %rsi"))))
            set out = (strings::concat out (line "    call cl_map_del"))
            return out
        case (IMapKeys dst mp)
            let out = (load_into bx "%rdi" mp)
            set out = (strings::concat out (line "    call cl_map_keys"))
            return (strings::concat out (store_rax bx dst))
        case (IArrNew dst elem count)
            # cl_array (24B) returned via hidden pointer (&dst in %rdi)
            let out = (line (cat3 "    leaq " (off_mem (slot_off bx (iv_key dst))) ", %rdi"))
            set out = (strings::concat out (line (cat2 "    movl $" (cat2 (i2s (type_size elem bx.structs)) ", %esi"))))
            set out = (strings::concat out (load_into bx "%rdx" count))
            set out = (strings::concat out (line "    call cl_array_new"))
            return out
        case (IArrLen dst arr)
            let out = (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key arr)) 8i64)) ", %rax")))
            return (strings::concat out (store_rax bx dst))
        case (IArrGet dst arr idx ty)
            let out = (emit_array_at bx arr idx)
            return (strings::concat out (load_elem_from_rax bx dst ty))
        case (IArrSet arr idx sval elem)
            let out = (emit_park_arg bx sval 0i64)
            set out = (strings::concat out (emit_array_at bx arr idx))
            set out = (strings::concat out (store_elem_at_rax bx elem))
            return out
        case (IArrLit dst elem elems)
            let esz = (type_size elem bx.structs)
            let out = (line (cat3 "    leaq " (off_mem (slot_off bx (iv_key dst))) ", %rdi"))
            set out = (strings::concat out (line (cat2 "    movl $" (cat2 (i2s esz) ", %esi"))))
            set out = (strings::concat out (line (cat2 "    movq $" (cat2 (i2s (as (len elems) i64)) ", %rdx"))))
            set out = (strings::concat out (line "    call cl_array_new"))
            let k = 0u64
            while (< k (len elems))
                set out = (strings::concat out (emit_park_arg bx elems[k] 0i64))
                set out = (strings::concat out (emit_array_at bx dst (ImmInt val: (as k i64) ty: (TyOf t: (TInt name: "u64")))))
                set out = (strings::concat out (store_elem_at_rax bx elem))
                set k = (+ k 1)
            end
            return out
        case (IStructNew dst struct_name fnames fvals)
            # build the struct value in dst's slot: store each field at its offset.
            let out = ""
            let k = 0u64
            while (< k (len fnames))
                let foff = (field_offset bx.structs struct_name fnames[k])
                let fty = (field_type bx.structs struct_name fnames[k])
                let fsz = (type_size fty bx.structs)
                if (> (nwords fty bx.structs) 1i64)
                    # nested multi-word field: copy word by word from the value slot
                    let nw = (nwords fty bx.structs)
                    let w = 0i64
                    while (< w nw)
                        set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key fvals[k])) (* w 8i64))) ", %rax"))))
                        set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ (+ (slot_off bx (iv_key dst)) foff) (* w 8i64))) "")))
                        set w = (+ w 1i64)
                    end
                elsif (irt_is_float fty)
                    set out = (strings::concat out (load_xmm bx "%xmm0" fvals[k]))
                    set out = (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx fty)) " %xmm0, " (off_mem (+ (slot_off bx (iv_key dst)) foff)))))
                else
                    set out = (strings::concat out (load_to_rax bx fvals[k]))
                    set out = (strings::concat out (store_sized fsz "a" (off_mem (+ (slot_off bx (iv_key dst)) foff))))
                end
                set k = (+ k 1)
            end
            return out
        case (ILoadField dst base field ty)
            let bqn = (irt_struct_qn (iv_ty base))
            let foff = (field_offset bx.structs bqn field)
            let boff = (slot_off bx (iv_key base))
            if (> (nwords ty bx.structs) 1i64)
                let out = ""
                let nw = (nwords ty bx.structs)
                let w = 0i64
                while (< w nw)
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (+ (+ boff foff) (* w 8i64))) ", %rax"))))
                    set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ (slot_off bx (iv_key dst)) (* w 8i64))) "")))
                    set w = (+ w 1i64)
                end
                return out
            end
            let out = (load_sized (type_size ty bx.structs) (irt_signed ty) (off_mem (+ boff foff)))
            return (strings::concat out (store_rax bx dst))
        case (IAlloc dst ty)
            # a 1-slot heap box holding a value of `ty` (captured-var cell)
            let out = (line (cat2 "    movq $" (cat2 (i2s (type_size ty bx.structs)) ", %rdi")))
            set out = (strings::concat out (line "    call cl_gc_alloc"))
            return (strings::concat out (store_rax bx dst))
        case (ILoad dst ptr ty)
            let out = (load_into bx "%rdi" ptr)
            set out = (strings::concat out (line "    call cl_gc_deref"))
            let nw = (nwords ty bx.structs)
            if (> nw 1i64)
                # multi-word value (e.g. a boxed value struct): copy every word from
                # the box payload at %rax into dst's slot.
                let w = 0i64
                while (< w nw)
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (cat2 (i2s (* w 8i64)) "(%rax)") ", %rcx"))))
                    set out = (strings::concat out (line (cat3 "    movq %rcx, " (off_mem (+ (slot_off bx (iv_key dst)) (* w 8i64))) "")))
                    set w = (+ w 1i64)
                end
                return out
            end
            set out = (strings::concat out (load_sized (type_size ty bx.structs) (irt_signed ty) "(%rax)"))
            return (strings::concat out (store_rax bx dst))
        case (IEnvNew dst n)
            let out = (line (cat2 "    movq $" (cat2 (i2s (* n 8i64)) ", %rdi")))
            set out = (strings::concat out (line "    call cl_gc_alloc"))
            return (strings::concat out (store_rax bx dst))
        case (IEnvStore env idx ptr)
            let out = (load_into bx "%rdi" env)
            set out = (strings::concat out (line "    call cl_gc_deref"))
            set out = (strings::concat out (load_into bx "%rcx" ptr))
            set out = (strings::concat out (line (cat2 "    movq %rcx, " (cat2 (i2s (* idx 8i64)) "(%rax)"))))
            return out
        case (IEnvLoad dst env idx ty)
            let out = (load_into bx "%rdi" env)
            set out = (strings::concat out (line "    call cl_gc_deref"))
            set out = (strings::concat out (line (cat2 "    movq " (cat2 (i2s (* idx 8i64)) "(%rax), %rax"))))
            return (strings::concat out (store_rax bx dst))
        case (IMakeClosure dst fn env)
            # cl_closure {void* fn; cl_handle env} stored as two words in dst's slot
            let out = (line (cat2 "    leaq " (cat2 fn "(%rip), %rax")))
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (slot_off bx (iv_key dst))) "")))
            set out = (strings::concat out (load_into bx "%rax" env))
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ (slot_off bx (iv_key dst)) 8i64)) "")))
            return out
        case (ICallClosure has_dst dst clos args ret ptys)
            # env (clos+8) is the implicit first GP arg (%rdi); the actual args
            # follow under the FULL SysV classification (floats -> xmm0..7, ints/
            # ≤16B aggregates -> GP regs starting at %rsi, overflow -> stack).
            # Park reg/xmm args into scratch (word 0 reserved for env), then call
            # through the closure's fn pointer (clos+0). Mirrors emit_call; the bug
            # this fixes: floats were loaded into GP regs, so a closure taking a
            # float arg read garbage from an unset xmm register.
            let out = (line (cat2 "    movq " (cat2 (off_mem (+ (slot_off bx (iv_key clos)) 8i64)) ", %rax")))
            set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem bx.scratch) "")))
            # MEMORY-class return (>16B, e.g. a cl_array 24B): &dst is the hidden
            # first GP arg (%rdi); the env shifts to %rsi and the real args shift up
            # one register. Without this the callee's hidden-pointer ABI is unmet and
            # the call corrupts the stack (segfault).
            let hidden = false
            if has_dst
                if (> (nwords ret bx.structs) 2i64)
                    set hidden = true
                end
            end
            let hbase = 0i64
            if hidden
                set hbase = 1i64
            end
            let argcat {i64} = (vec i64)
            let argscr {i64} = (vec i64)
            let argoff {i64} = (vec i64)
            let gpw = (+ 1i64 hbase)
            let xmmw = 0i64
            let pw = 1i64
            let stackbytes = 0i64
            let i = 0u64
            while (< i (len args))
                if (irt_is_float (iv_ty args[i]))
                    if (< xmmw 8i64)
                        set out = (strings::concat out (emit_park_arg bx args[i] pw))
                        do (push argcat 1i64)
                        do (push argscr pw)
                        do (push argoff 0i64)
                        set pw = (+ pw 1i64)
                        set xmmw = (+ xmmw 1i64)
                    else
                        do (push argcat 2i64)
                        do (push argscr 0i64)
                        do (push argoff stackbytes)
                        set stackbytes = (+ stackbytes 8i64)
                    end
                else
                    let k = (nwords (iv_ty args[i]) bx.structs)
                    if (and (<= k 2i64) (<= (+ gpw k) 6i64))
                        set out = (strings::concat out (emit_park_arg bx args[i] pw))
                        do (push argcat 0i64)
                        do (push argscr pw)
                        do (push argoff 0i64)
                        set pw = (+ pw k)
                        set gpw = (+ gpw k)
                    else
                        do (push argcat 2i64)
                        do (push argscr 0i64)
                        do (push argoff stackbytes)
                        set stackbytes = (+ stackbytes (* k 8i64))
                    end
                end
                set i = (+ i 1)
            end
            let memtotal = (round16 stackbytes)
            if (> memtotal 0i64)
                set out = (strings::concat out (line (cat2 "    subq $" (cat2 (i2s memtotal) ", %rsp"))))
            end
            set i = 0u64
            while (< i (len args))
                if (== argcat[i] 2i64)
                    set out = (strings::concat out (emit_store_arg_to_stack bx args[i] argoff[i]))
                end
                set i = (+ i 1)
            end
            if hidden
                set out = (strings::concat out (line (cat3 "    leaq " (off_mem (slot_off bx (iv_key dst))) ", %rdi")))
            end
            set out = (strings::concat out (line (cat3 "    movq " (cat2 (off_mem bx.scratch) ", ") (argreg hbase))))
            let gpreg = (+ 1i64 hbase)
            set i = 0u64
            while (< i (len args))
                if (== argcat[i] 0i64)
                    let k = (nwords (iv_ty args[i]) bx.structs)
                    let w = 0i64
                    while (< w k)
                        set out = (strings::concat out (line (cat3 "    movq " (cat2 (off_mem (+ bx.scratch (* (+ argscr[i] w) 8i64))) ", ") (argreg gpreg))))
                        set gpreg = (+ gpreg 1i64)
                        set w = (+ w 1i64)
                    end
                end
                set i = (+ i 1)
            end
            let xreg = 0i64
            set i = 0u64
            while (< i (len args))
                if (== argcat[i] 1i64)
                    set out = (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx (iv_ty args[i]))) " " (cat3 (off_mem (+ bx.scratch (* argscr[i] 8i64))) ", %xmm" (i2s xreg)))))
                    set xreg = (+ xreg 1i64)
                end
                set i = (+ i 1)
            end
            set out = (strings::concat out (line (cat2 "    movq " (cat2 (off_mem (slot_off bx (iv_key clos))) ", %r11"))))
            set out = (strings::concat out (line "    call *%r11"))
            if (> memtotal 0i64)
                set out = (strings::concat out (line (cat2 "    addq $" (cat2 (i2s memtotal) ", %rsp"))))
            end
            if has_dst
                if hidden
                    pass
                elsif (irt_is_float ret)
                    set out = (strings::concat out (store_xmm bx "%xmm0" dst))
                elsif (> (nwords ret bx.structs) 1i64)
                    set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (slot_off bx (iv_key dst))) "")))
                    set out = (strings::concat out (line (cat3 "    movq %rdx, " (off_mem (+ (slot_off bx (iv_key dst)) 8i64)) "")))
                else
                    set out = (strings::concat out (store_result_rax bx dst))
                end
            end
            return out
        else
            do (panic "x86: unsupported instruction (later milestone)")
    end
    return ""
end

# --------------------------------------------------------------------------- #
# Function emission
# --------------------------------------------------------------------------- #

func round16 (n i64) -> i64
    let r = (% n 16i64)
    if (== r 0i64)
        return n
    end
    return (+ n (- 16i64 r))
end

func emit_func (f IRFunc) (strs {str str}) (floats {str str}) (sm {str IRStruct}) -> str
    # 1) assign a size-aware slot to every param, non-unit temp, and local. Build
    # parallel arrays (key, type, is-param) so rooting/zeroing know each size.
    let slots {str i64} = (map str i64)
    let allkeys {str} = (vec str)
    let alltys {IRType} = (vec IRType)
    let allparam {bool} = (vec bool)
    let off = 0i64
    let pi = 0u64
    while (< pi (len f.params))
        set off = (- off (slot_size f.params[pi].ty sm))
        set slots[(lkey f.params[pi].name)] = off
        do (push allkeys (lkey f.params[pi].name))
        do (push alltys f.params[pi].ty)
        do (push allparam true)
        set pi = (+ pi 1)
    end
    let ti = 0u64
    while (< ti (len f.temps))
        match f.temps[ti]
            case (Temp id ty)
                if (not (irt_is_unit ty))
                    set off = (- off (slot_size ty sm))
                    set slots[(tkey id)] = off
                    do (push allkeys (tkey id))
                    do (push alltys ty)
                    do (push allparam false)
                end
            else
                pass
        end
        set ti = (+ ti 1)
    end
    let li = 0u64
    while (< li (len f.locals))
        set off = (- off (slot_size f.locals[li].ty sm))
        set slots[(lkey f.locals[li].name)] = off
        do (push allkeys (lkey f.locals[li].name))
        do (push alltys f.locals[li].ty)
        do (push allparam false)
        set li = (+ li 1)
    end
    # Spare slots for parking register-bound call args / values across runtime calls
    # (so we never have an outstanding push misaligning the stack at an internal call).
    # A single call parks every register arg contiguously via one shared word cursor:
    # SysV allows up to 6 GP integer regs + 8 xmm float regs = 14 register args, so we
    # reserve 14 words. (Stack-passed overflow args go straight to (%rsp), not scratch.)
    set off = (- off 112i64)
    let scratch = off
    # a slot for the hidden return pointer when this function returns a >16B struct
    let ret_mem = (> (nwords f.ret sm) 2i64)
    let hidden_ret = 0i64
    if ret_mem
        set off = (- off 8i64)
        set hidden_ret = off
    end
    let frame = (round16 (- 0i64 off))
    let bx = (BX slots: slots fname: f.name strs: strs floats: floats structs: sm scratch: scratch ret_mem: ret_mem hidden_ret: hidden_ret)

    let nroots = 0i64
    let i = 0u64
    while (< i (len allkeys))
        if (managed alltys[i])
            set nroots = (+ nroots 1i64)
        end
        set i = (+ i 1)
    end

    # 2) prologue
    let out = ""
    set out = (strings::concat out (line (cat2 f.name ":")))
    set out = (strings::concat out (line "    pushq %rbp"))
    set out = (strings::concat out (line "    movq %rsp, %rbp"))
    if (> frame 0i64)
        set out = (strings::concat out (line (cat2 "    subq $" (cat2 (i2s frame) ", %rsp"))))
    end
    # store incoming params. A >16B struct param arrives on the stack (SysV MEMORY,
    # at %rbp+16+memoff); smaller ones in integer regs (a cl_closure / ≤16B struct
    # takes 2). When the result is a >16B struct, %rdi is the hidden return pointer.
    let rg = 0i64
    if ret_mem
        set out = (strings::concat out (line (cat3 "    movq %rdi, " (off_mem hidden_ret) "")))
        set rg = 1i64
    end
    # Same reg/stack classification as emit_call: a ≤16B param whose eightbytes fit
    # in the remaining integer regs is in registers; otherwise (or >16B) it was
    # passed on the stack at %rbp+16+memoff, in source order.
    let memoff = 16i64
    let xrg = 0i64
    set pi = 0u64
    while (< pi (len f.params))
        if (irt_is_float f.params[pi].ty)
            if (< xrg 8i64)
                set out = (strings::concat out (line (cat3 (strings::concat "    mov" (sse_sfx f.params[pi].ty)) (cat3 " %xmm" (i2s xrg) ", ") (off_mem (slot_off bx (lkey f.params[pi].name))))))
                set xrg = (+ xrg 1i64)
            else
                set out = (strings::concat out (line (cat2 "    movq " (cat2 (cat2 (i2s memoff) "(%rbp)") ", %rax"))))
                set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (slot_off bx (lkey f.params[pi].name))) "")))
                set memoff = (+ memoff 8i64)
            end
        else
            let k = (nwords f.params[pi].ty sm)
            if (and (<= k 2i64) (<= (+ rg k) 6i64))
                let w = 0i64
                while (< w k)
                    set out = (strings::concat out (line (cat2 "    movq " (cat3 (argreg (+ rg w)) ", " (off_mem (+ (slot_off bx (lkey f.params[pi].name)) (* w 8i64)))))))
                    set w = (+ w 1i64)
                end
                set rg = (+ rg k)
            else
                let w = 0i64
                while (< w k)
                    set out = (strings::concat out (line (cat2 "    movq " (cat2 (cat2 (i2s (+ memoff (* w 8i64))) "(%rbp)") ", %rax"))))
                    set out = (strings::concat out (line (cat3 "    movq %rax, " (off_mem (+ (slot_off bx (lkey f.params[pi].name)) (* w 8i64))) "")))
                    set w = (+ w 1i64)
                end
                set memoff = (+ memoff (* k 8i64))
            end
        end
        set pi = (+ pi 1)
    end
    # zero managed non-param slots word-by-word (params already hold valid bytes)
    set i = 0u64
    while (< i (len allkeys))
        if (and (managed alltys[i]) (not allparam[i]))
            let nw = (nwords alltys[i] sm)
            let w = 0i64
            while (< w nw)
                set out = (strings::concat out (line (cat3 "    movq $0, " (off_mem (+ (slot_off bx allkeys[i]) (* w 8i64))) "")))
                set w = (+ w 1i64)
            end
        end
        set i = (+ i 1)
    end
    # root every managed slot on the shadow stack (size = type_size; the conservative
    # scan finds embedded handles within multi-word values)
    set i = 0u64
    while (< i (len allkeys))
        if (managed alltys[i])
            set out = (strings::concat out (line (cat2 "    leaq " (cat2 (off_mem (slot_off bx allkeys[i])) ", %rdi"))))
            set out = (strings::concat out (line (cat2 "    movl $" (cat2 (i2s (type_size alltys[i] sm)) ", %esi"))))
            set out = (strings::concat out (line "    call cl_gc_push_root"))
        end
        set i = (+ i 1)
    end

    # 4) body
    let bi = 0u64
    while (< bi (len f.blocks))
        let blk = f.blocks[bi]
        set out = (strings::concat out (line (cat2 (lbl bx blk.label) ":")))
        let ii = 0u64
        while (< ii (len blk.instrs))
            set out = (strings::concat out (emit_instr bx blk.instrs[ii] nroots))
            set ii = (+ ii 1)
        end
        set bi = (+ bi 1)
    end
    return out
end

# --------------------------------------------------------------------------- #
# main wrapper + module driver
# --------------------------------------------------------------------------- #

func ends_with_main (s str) -> bool
    let cs = (strings::chars s)
    let suf = (strings::chars "__main")
    if (< (len cs) (len suf))
        return false
    end
    let off = (- (len cs) (len suf))
    let i = 0u64
    while (< i (len suf))
        if (not (== cs[(+ off i)] suf[i]))
            return false
        end
        set i = (+ i 1)
    end
    return true
end

func irt_is_int_ret (t IRType) -> bool
    match t
        case (TyOf st)
            match st
                case (TInt n)
                    return true
                else
                    return false
            end
        else
            return false
    end
    return false
end

func main_wrapper (m IRModule) -> str
    let found = false
    let tname = ""
    let tret = (TyOf t: (TPrim name: "unit"))
    let i = 0u64
    while (< i (len m.funcs))
        if (and (not found) (ends_with_main m.funcs[i].name))
            set found = true
            set tname = m.funcs[i].name
            set tret = m.funcs[i].ret
        end
        set i = (+ i 1)
    end
    let out = ""
    set out = (strings::concat out (line ".globl main"))
    set out = (strings::concat out (line "main:"))
    set out = (strings::concat out (line "    pushq %rbp"))
    set out = (strings::concat out (line "    movq %rsp, %rbp"))
    set out = (strings::concat out (line "    subq $16, %rsp"))
    # argc/argv arrive in %edi/%rsi — set program args before clobbering them.
    set out = (strings::concat out (line "    call cl_sys_set_args"))
    set out = (strings::concat out (line "    leaq -8(%rbp), %rdi"))
    set out = (strings::concat out (line "    call cl_gc_init"))
    if (not found)
        set out = (strings::concat out (line "    xorl %eax, %eax"))
        set out = (strings::concat out (line "    leave"))
        set out = (strings::concat out (line "    ret"))
        return out
    end
    set out = (strings::concat out (line (cat2 "    call " tname)))
    if (not (irt_is_int_ret tret))
        set out = (strings::concat out (line "    xorl %eax, %eax"))
    end
    set out = (strings::concat out (line "    leave"))
    set out = (strings::concat out (line "    ret"))
    return out
end

export func emit (m IRModule) -> str
    let strs = (collect_strs m)
    # struct/variant layout map (qualified name -> IRStruct), for sum/struct offsets
    let sm {str IRStruct} = (map str IRStruct)
    let si = 0u64
    while (< si (len m.structs))
        set sm[m.structs[si].name] = m.structs[si]
        set si = (+ si 1)
    end
    let out = ""
    set out = (strings::concat out (line "    .section .rodata"))
    set out = (strings::concat out (line ".Lcl_divzero:"))
    set out = (strings::concat out (line "    .asciz \"integer division by zero\""))
    set out = (strings::concat out (line ".Lcl_overflow:"))
    set out = (strings::concat out (line "    .asciz \"integer overflow\""))
    set out = (strings::concat out (line ".Lcl_fdivzero:"))
    set out = (strings::concat out (line "    .asciz \"float division by zero\""))
    # string-literal pool (one rodata entry per distinct literal; cl_strlit interns
    # by pointer, so identical literals share a label -> a single interned handle).
    # Emit each literal with a trailing end label and use .ascii (no implicit NUL
    # terminator): the byte length is end-label minus start-label, so embedded NULs
    # are preserved. cl_str_from_utf8 (see load_to_rax) takes an explicit length.
    # A separator byte after each end label keeps every entry at a DISTINCT address —
    # without it an EMPTY literal (.ascii "" -> 0 bytes) would share its start label's
    # address with the next entry, and cl_strlit_n interns by pointer, so the two
    # would collide (the first one evaluated wins for both).
    for s in (map_keys strs)
        set out = (strings::concat out (line (cat2 strs[s] ":")))
        set out = (strings::concat out (line (cat3 "    .ascii \"" (asm_escape s) "\"")))
        set out = (strings::concat out (line (cat2 strs[s] "_end:")))
        set out = (strings::concat out (line "    .byte 0"))
    end
    set out = (strings::concat out (line "    .text"))
    # float-literal pool (filled while emitting funcs; rodata emitted at the end).
    let floats {str str} = (map str str)
    let i = 0u64
    while (< i (len m.funcs))
        set out = (strings::concat out (emit_func m.funcs[i] strs floats sm))
        set out = (strings::concat out (line ""))
        set i = (+ i 1)
    end
    # function-as-value thunks (sorted = deterministic)
    let tnames = (sorted_keys m.thunks)
    let ti = 0u64
    while (< ti (len tnames))
        set out = (strings::concat out (emit_thunk tnames[ti] m.thunks[tnames[ti]] sm))
        set out = (strings::concat out (line ""))
        set ti = (+ ti 1)
    end
    set out = (strings::concat out (main_wrapper m))
    # float-literal rodata (8-byte aligned; .double for f64, .float for f32). Keys
    # are "f64:TEXT"/"f32:TEXT"; emit in label order for determinism.
    let fkeys = (sorted_str_keys floats)
    if (> (len fkeys) 0u64)
        set out = (strings::concat out (line "    .section .rodata"))
        let fi = 0u64
        while (< fi (len fkeys))
            let key = fkeys[fi]
            let is32 = (strings::eq (strings::substr key 0u64 4u64) "f32:")
            let text = (strings::substr key 4u64 (- (len key) 4u64))
            set out = (strings::concat out (line "    .align 8"))
            set out = (strings::concat out (line (cat2 floats[key] ":")))
            if is32
                set out = (strings::concat out (line (cat2 "    .float " text)))
            else
                set out = (strings::concat out (line (cat2 "    .double " text)))
            end
            set fi = (+ fi 1)
        end
    end
    return out
end
