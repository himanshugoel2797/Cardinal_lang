# Python bytecode (the bootstrap interpreter/checker)
__pycache__/
*.pyc

# Build artifacts
/build/
*.o
*.s

# Emitted C / assembly from compiling example programs
/examples/*.c
/examples/*.s

# Native binaries built by ccrun at the repo root (named after the program).
