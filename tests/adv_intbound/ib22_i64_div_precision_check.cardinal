module ib22_i64_div_precision_check

import io

func main () -> i32
    # i64 division with values that lose precision in float (53-bit mantissa)
    # Values with more than 53 significant bits will lose precision

    let i64max = 9223372036854775807i64

    # Divisions that might lose precision in interpreter's float division
    do (io::println (/ i64max 2i64))     # 4611686018427387903
    do (io::println (/ i64max 3i64))     # 3074457345618258602
    do (io::println (/ i64max 5i64))     # 1844674407370955161
    do (io::println (/ i64max 7i64))     # 1317534867122111829

    # Modulo operations
    do (io::println (% i64max 2i64))     # 1
    do (io::println (% i64max 3i64))     # 1
    do (io::println (% i64max 5i64))     # 2

    # With negative
    let i64min = (- 9223372036854775808i64)
    do (io::println (/ i64min 2i64))     # -4611686018427387904
    do (io::println (% i64min 2i64))     # 0

    # Large i64 values near boundaries
    let big = 9223372036854775806i64
    do (io::println (/ big 1i64))
    do (io::println (/ big 2i64))

    return 0i32
end
