module ib08_div_mod_by_one

import io

func main () -> i32
    # Division/modulo by 1 should always give specific results

    # / 1: any value / 1 = value
    do (io::println (/ 0i32 1i32))
    do (io::println (/ 42i32 1i32))
    do (io::println (/ (- 42i32) 1i32))
    do (io::println (/ 2147483647i32 1i32))
    do (io::println (/ (- 2147483648i32) 1i32))

    # % 1: any value % 1 = 0
    do (io::println (% 0i32 1i32))
    do (io::println (% 42i32 1i32))
    do (io::println (% (- 42i32) 1i32))
    do (io::println (% 2147483647i32 1i32))
    do (io::println (% (- 2147483648i32) 1i32))

    # u64 / 1 (tests interpreter float precision)
    let u64max = 18446744073709551615u64
    do (io::println (/ u64max 1u64))    # should be u64max
    do (io::println (% u64max 1u64))    # should be 0

    # i64 / 1
    let i64max = 9223372036854775807i64
    do (io::println (/ i64max 1i64))
    do (io::println (% i64max 1i64))

    return 0i32
end
