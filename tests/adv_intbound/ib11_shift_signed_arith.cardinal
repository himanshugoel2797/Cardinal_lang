module ib11_shift_signed_arith

import io

func main () -> i32
    # Signed arithmetic right-shift on all widths

    # i8 arithmetic right-shift (sign fill)
    do (io::println (shr (- 1i8) 1i8))   # -1 >> 1 = -1 (sign filled)
    do (io::println (shr (- 128i8) 1i8)) # -128 >> 1 = -64
    do (io::println (shr 127i8 1i8))     # 127 >> 1 = 63

    # i16 arithmetic right-shift
    do (io::println (shr (- 1i16) 8i16))  # -1 >> 8 = -1
    do (io::println (shr (- 32768i16) 1i16)) # -32768 >> 1 = -16384

    # i32 arithmetic right-shift
    do (io::println (shr (- 1i32) 16i32))  # -1 >> 16 = -1
    do (io::println (shr (- 2147483648i32) 1i32)) # INT_MIN >> 1

    # i64 arithmetic right-shift
    do (io::println (shr (- 1i64) 32i64))
    do (io::println (shr (- 9223372036854775808i64) 1i64))

    # Shift left on negative
    do (io::println (shl (- 1i8) 1i8))   # -1 << 1 = -2
    do (io::println (shl (- 128i8) 1i8)) # -128 << 1

    return 0i32
end
