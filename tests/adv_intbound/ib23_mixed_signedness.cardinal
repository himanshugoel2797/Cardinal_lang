module ib23_mixed_signedness

import io

func main () -> i32
    # Operations after casting between signed/unsigned at boundaries

    # i64_max cast to u64 and operated on
    let i64max = 9223372036854775807i64
    let as_u64 = (as i64max u64)
    do (io::println (/ as_u64 1u64))
    do (io::println (/ as_u64 2u64))

    # i64_min cast to u64 (becomes 2^63 as unsigned)
    let i64min = (- 9223372036854775808i64)
    let u64_min = (as i64min u64)
    do (io::println (/ u64_min 2u64))

    # Cast from u64 back to i64
    let u64val = 18446744073709551615u64
    let as_i64 = (as u64val i64)
    do (io::println (+ as_i64 1i64))
    do (io::println (- as_i64 1i64))

    return 0i32
end
