module ib04_intmin_edge

import io

func main () -> i32
    # i8 INT_MIN edge cases
    let i8min = (- 128i8)
    do (io::println (/ i8min (- 1i8)))   # INT_MIN / -1 should wrap to INT_MIN
    do (io::println (% i8min (- 1i8)))   # INT_MIN % -1 should be 0

    # i16 INT_MIN edge cases
    let i16min = (- 32768i16)
    do (io::println (/ i16min (- 1i16)))
    do (io::println (% i16min (- 1i16)))

    # i32 INT_MIN edge cases
    let i32min = (- 2147483648i32)
    do (io::println (/ i32min (- 1i32)))
    do (io::println (% i32min (- 1i32)))

    # i64 INT_MIN edge cases (already known bug in x86, but testing)
    let i64min = (- 9223372036854775808i64)
    do (io::println (/ i64min (- 1i64)))
    do (io::println (% i64min (- 1i64)))

    return 0i32
end
