module ib26_compare_extreme_values

import io

func main () -> i32
    # Comparisons with extreme values

    # i8 boundaries
    let i8max = 127i8
    let i8min = (- 128i8)
    do (io::println (if (< i8min i8max) 1i32 0i32))
    do (io::println (if (<= i8min i8min) 1i32 0i32))
    do (io::println (if (> i8max i8min) 1i32 0i32))
    do (io::println (if (== i8min i8min) 1i32 0i32))

    # u64 high values
    let u64max = 18446744073709551615u64
    do (io::println (if (== u64max u64max) 1i32 0i32))
    do (io::println (if (!= u64max 0u64) 1i32 0i32))

    # i64 max and min
    let i64max = 9223372036854775807i64
    let i64min = (- 9223372036854775808i64)
    do (io::println (if (< i64min i64max) 1i32 0i32))
    do (io::println (if (> i64max i64min) 1i32 0i32))

    return 0i32
end
