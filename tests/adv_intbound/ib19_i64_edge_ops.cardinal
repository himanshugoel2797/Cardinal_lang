module ib19_i64_edge_ops

import io

func main () -> i32
    # i64 edge operations focusing on precision and overflow

    let i64max = 9223372036854775807i64
    let i64min = (- 9223372036854775808i64)

    # i64_max arithmetic
    do (io::println (+ i64max 1i64))     # wraps to i64_min
    do (io::println (+ i64max (- 1i64))) # i64_max - 1

    # i64_min arithmetic
    do (io::println (- i64min 1i64))     # wraps to i64_max
    do (io::println (+ i64min 1i64))     # i64_min + 1

    # Multiplies involving i64 max/min
    do (io::println (* i64max 1i64))     # i64_max
    do (io::println (* i64max (- 1i64))) # -i64_max = i64_min + 1

    # i64 division with large values
    do (io::println (/ i64max 2i64))     # 4611686018427387903
    do (io::println (/ i64min 2i64))     # -4611686018427387904

    # i64 / 1 (precision test for interpreter)
    do (io::println (/ i64max 1i64))
    do (io::println (/ i64min 1i64))

    return 0i32
end
