module map_del_reinsert_order

import io

func main () -> i32
    # Test: insertion order after delete then re-insert of the same key
    # Does it keep the old position or move to end?
    let m {str i32} = (map str i32)
    set m["a"] = 1i32
    set m["b"] = 2i32
    set m["c"] = 3i32

    # Keys should be: [a, b, c]
    do (io::println "before delete:")
    for k in (map_keys m)
        do (io::print k)
        do (io::print " ")
    end
    do (io::println "")

    # Delete middle key
    do (map_del m "b")
    # Now keys should be: [a, c]

    # Re-insert b
    set m["b"] = 20i32
    # Where does b go? Old position or end?
    do (io::println "after delete then reinsert:")
    for k in (map_keys m)
        do (io::print k)
        do (io::print " ")
    end
    do (io::println "")

    # Verify values
    do (io::println m["a"])
    do (io::println m["b"])
    do (io::println m["c"])

    return 0i32
end
