module map_interleaved_ops

import io

func main () -> i32
    # Test: interleaved operations (insert, delete, overwrite) and verify order stability
    let m {i32 i32} = (map i32 i32)

    # Phase 1: insert 5 items
    let i = 0i32
    loop
        set m[i] = (+ i 100i32)
        set i = (+ i 1i32)
        if (== i 5i32)
            break
        end
    end

    # Phase 2: delete items at even indices
    do (map_del m 0i32)
    do (map_del m 2i32)
    do (map_del m 4i32)

    # Phase 3: overwrite remaining odd items
    set m[1i32] = 200i32
    set m[3i32] = 300i32

    # Phase 4: re-insert evens
    set m[0i32] = 400i32
    set m[2i32] = 500i32
    set m[4i32] = 600i32

    # Verify final state and order
    do (io::println "final keys in order:")
    for k in (map_keys m)
        do (io::print k)
        do (io::print " ")
    end
    do (io::println "")

    do (io::println "final values in order:")
    for k in (map_keys m)
        do (io::print m[k])
        do (io::print " ")
    end
    do (io::println "")

    return 0i32
end
