module map_hash_collision_probe

import io

func main () -> i32
    # Test: maps with i32 keys that might collide in hash
    # Using keys with patterns that could collide in simple hash functions
    let m {i32 i32} = (map i32 i32)

    # Insert keys with specific patterns
    set m[0i32] = 10i32
    set m[1i32] = 20i32
    set m[256i32] = 30i32
    set m[257i32] = 40i32
    set m[65536i32] = 50i32

    # Verify all exist
    do (io::println (len m))

    # Iterate and verify order (insertion order)
    let first = true
    for k in (map_keys m)
        if first
            set first = false
        else
            do (io::print " ")
        end
        do (io::print k)
    end
    do (io::println "")

    # Delete and re-insert middle
    do (map_del m 256i32)
    do (io::println (len m))

    set m[256i32] = 35i32
    do (io::println (len m))

    # Verify order changed (256 should be at end now)
    for k in (map_keys m)
        do (io::print k)
        do (io::print " ")
    end
    do (io::println "")

    return 0i32
end
