module map_struct_value

import io

struct Point
    x i32
    y i32
end

func main () -> i32
    # Test: map with struct values (copy semantics on retrieval)
    let m {str Point} = (map str Point)
    set m["origin"] = (Point x: 0i32 y: 0i32)
    set m["unit"] = (Point x: 1i32 y: 1i32)

    let p1 = m["origin"]
    do (io::println p1.x)
    do (io::println p1.y)

    let p2 = m["unit"]
    do (io::println p2.x)
    do (io::println p2.y)

    # Overwrite a value
    set m["origin"] = (Point x: 10i32 y: 20i32)
    let p3 = m["origin"]
    do (io::println p3.x)
    do (io::println p3.y)

    return 0i32
end
