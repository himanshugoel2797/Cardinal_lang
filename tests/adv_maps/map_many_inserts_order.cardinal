module map_many_inserts_order

import io

func main () -> i32
    # Test: map growth/rehash across many insertions (order stable through resize)
    # Insert 50+ keys, iterate, verify insertion order preserved through rehashes
    let m {i32 i32} = (map i32 i32)

    # Insert 60 keys in order
    let i = 0i32
    loop
        set m[i] = (+ i 100i32)
        set i = (+ i 1i32)
        if (== i 60i32)
            break
        end
    end

    # Verify iteration order matches insertion order
    let expected = 0i32
    for k in (map_keys m)
        if (!= k expected)
            do (io::println "order mismatch!")
            return 1i32
        end
        set expected = (+ expected 1i32)
    end

    do (io::println "all 60 keys in order")
    return 0i32
end
