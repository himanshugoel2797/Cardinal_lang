module map_empty_iteration

import io

func main () -> i32
    # Test: empty map iteration (should not crash, should iterate 0 times)
    let m {i32 i32} = (map i32 i32)

    let count = 0i32
    for k in (map_keys m)
        set count = (+ count 1i32)
    end

    do (io::println count)         # 0
    do (io::println (len m))       # 0
    do (io::println (map_has m 0i32))  # false

    return 0i32
end
