module map_len_after_ops

import io

func main () -> i32
    # Test: map len after various operations (insert, delete, overwrite, clear)
    let m {i32 i32} = (map i32 i32)

    # Start empty
    do (io::println (len m))    # 0

    # Insert 5
    let i = 0i32
    loop
        set m[i] = i
        set i = (+ i 1i32)
        if (== i 5i32)
            break
        end
    end
    do (io::println (len m))    # 5

    # Delete 2
    do (map_del m 0i32)
    do (map_del m 2i32)
    do (io::println (len m))    # 3

    # Overwrite existing
    set m[1i32] = 999i32
    do (io::println (len m))    # still 3

    # Delete non-existent (no-op)
    do (map_del m 999i32)
    do (io::println (len m))    # still 3

    # Re-insert deleted
    set m[0i32] = 0i32
    do (io::println (len m))    # 4

    return 0i32
end
