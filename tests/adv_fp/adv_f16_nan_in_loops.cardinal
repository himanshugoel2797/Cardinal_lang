module adv_f16_nan_in_loops
import io

func main () -> i32
    let nan = (/ 0.0 0.0)

    # Loop condition with NaN: NaN < x is false
    let count = 0i32
    let i = 0i32

    while (< i 5i32)
        let count = (+ count 1i32)
        let i = (+ i 1i32)
    end

    do (io::println count)   # expect 5

    # Loop that accumulates NaN
    let val = 5.0
    let j = 0i32

    while (< j 3i32)
        let val = (+ val nan)   # Adding NaN makes it NaN
        let j = (+ j 1i32)
    end

    do (io::println val)   # expect nan

    return 0i32
end
