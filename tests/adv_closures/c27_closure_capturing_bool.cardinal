module c27_closure_capturing_bool
import io

func main () -> i32
    let flag = true
    let get_flag = func () -> bool
        return flag
    end
    let negate = func () -> bool
        return (not (get_flag))
    end
    do (io::println (get_flag))
    do (io::println (negate))
    return 0i32
end
