module c13_mutate_vec_via_closure
import io

func main () -> i32
    let v = (vec i32)
    do (push v 100)
    do (push v 200)
    let increment_all = func () -> i32
        set v[0] = (+ v[0] 1)
        set v[1] = (+ v[1] 1)
        return (+ v[0] v[1])
    end
    do (io::println (increment_all))
    do (io::println (increment_all))
    do (io::println v[0])
    do (io::println v[1])
    return 0i32
end
