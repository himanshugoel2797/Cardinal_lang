module c16_many_captured_vars
import io

func main () -> i32
    let a = 1i32
    let b = 2i32
    let c = 3i32
    let d = 4i32
    let e = 5i32
    let f = 6i32
    let g = 7i32
    let h = 8i32
    let closure = func () -> i32
        return (+ a (+ b (+ c (+ d (+ e (+ f (+ g h)))))))
    end
    do (io::println (closure))
    return 0i32
end
