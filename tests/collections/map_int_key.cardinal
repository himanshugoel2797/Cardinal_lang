module map_int_key

import io

# Map with int keys
func main () -> i32
    let m {i32 str} = (map i32 str)
    set m[1] = "one"
    set m[2] = "two"
    set m[3] = "three"

    do (io::println (len m))         # 3
    do (io::println m[1])            # one
    do (io::println m[3])            # three
    do (io::println (map_has m 2))   # true
    do (io::println (map_has m 9))   # false

    do (map_del m 2)
    do (io::println (len m))         # 2
    do (io::println (map_has m 2))   # false

    # Insertion order
    for k in (map_keys m)
        do (io::println k)
    end
    # 1 3

    # Negative int key
    let m2 {i32 i32} = (map i32 i32)
    set m2[(- 1i32)] = 100
    set m2[0] = 200
    set m2[1] = 300
    do (io::println m2[(- 1i32)])    # 100
    do (io::println m2[0])           # 200
    do (io::println m2[1])           # 300

    return 0i32
end
