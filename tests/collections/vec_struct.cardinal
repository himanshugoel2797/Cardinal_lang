module vec_struct

import io

struct Point
    x i32
    y i32
end

# Vector of structs: push, index, update field
func main () -> i32
    let pts {Point} = (vec Point)
    do (push pts (Point x: 1 y: 2))
    do (push pts (Point x: 3 y: 4))
    do (push pts (Point x: 5 y: 6))

    do (io::println (len pts))       # 3
    do (io::println pts[0].x)        # 1
    do (io::println pts[0].y)        # 2
    do (io::println pts[2].x)        # 5

    # Update field via set
    set pts[1].x = 99
    do (io::println pts[1].x)        # 99
    do (io::println pts[1].y)        # 4 (unchanged)

    # Iterate and sum x fields
    let total = 0i32
    for p in pts
        set total = (+ total p.x)
    end
    do (io::println total)           # 1+99+5 = 105

    # Pop returns a copy
    let last = (pop pts)
    do (io::println last.x)          # 5
    do (io::println last.y)          # 6
    do (io::println (len pts))       # 2

    return 0i32
end
