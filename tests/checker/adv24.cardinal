module adv24
# ADVERSARIAL: using an uninitialized variable in a branch where it might not be set
# (both paths assign x, so this SHOULD be legal — testing branch analysis)
func f (cond bool) -> i32
    let x = 0i32
    if cond
        set x = 1i32
    else
        set x = 2i32
    end
    return x
end
