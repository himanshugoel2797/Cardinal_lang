module t17_sum_variant_with_array_payload

import io

# Sum type variant carrying an array payload
type Container
    Items (data [i32])
    Empty
end

func main () -> i32
    let items [i32] = [1 2 3 4 5]
    let c = (Container Items: items)

    match c
        case (Items d)
            do (io::println d[0])     # 1
            do (io::println d[2])     # 3
            do (io::println d[4])     # 5
        case Empty
            do (io::println 999)
    end

    let c2 = Container::Empty
    match c2
        case (Items d)
            do (io::println 888)
        case Empty
            do (io::println 77)       # 77
    end

    return 0i32
end
