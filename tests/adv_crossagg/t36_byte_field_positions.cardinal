module t36_byte_field_positions

import io

# Test accessing different byte field positions
struct TightBytes
    a u8
    b u8
    c u8
end

func main () -> i32
    let arr [TightBytes] = [
        (TightBytes a: 100 b: 101 c: 102)
        (TightBytes a: 200 b: 201 c: 202)
    ]

    # Test accessing first, middle, last byte fields
    do (io::println (as arr[0].a i32))    # 100
    do (io::println (as arr[0].b i32))    # 101
    do (io::println (as arr[0].c i32))    # 102

    do (io::println (as arr[1].a i32))    # 200
    do (io::println (as arr[1].b i32))    # 201
    do (io::println (as arr[1].c i32))    # 202

    return 0i32
end
