module t11_nested_struct_in_vec

import io

# Vec of nested structs: deep multi-level access
struct Inner
    val i32
end

struct Outer
    inner Inner
    flag i32
end

func main () -> i32
    let v {Outer} = (vec Outer)

    do (push v (Outer inner: (Inner val: 1) flag: 10))
    do (push v (Outer inner: (Inner val: 2) flag: 20))
    do (push v (Outer inner: (Inner val: 3) flag: 30))

    # Deep access
    do (io::println v[0].inner.val)   # 1
    do (io::println v[1].flag)        # 20
    do (io::println v[2].inner.val)   # 3

    # Deep mutation
    set v[0].inner.val = 111
    do (io::println v[0].inner.val)   # 111
    do (io::println v[0].flag)        # 10 (unchanged sibling)
    do (io::println v[1].inner.val)   # 2 (next struct untouched)

    return 0i32
end
