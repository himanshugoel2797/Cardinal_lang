module test_string_equality

import io

func main () -> i32
    let s1 = "test"
    let s2 = "test"
    let s3 = "other"
    if (== s1 s2)
        do (io::println "equal")
    else
        do (io::println "not equal")
    end
    if (== s1 s3)
        do (io::println "equal")
    else
        do (io::println "not equal")
    end
    if (!= s1 s3)
        do (io::println "not equal")
    else
        do (io::println "equal")
    end
    return 0i32
end
