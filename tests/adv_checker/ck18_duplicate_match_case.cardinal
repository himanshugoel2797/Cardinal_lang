module ck18_duplicate_match_case
# Could be ILLEGAL: duplicate match case (both checkers accept though per FINDINGS)
enum Color
    Red
    Green
    Blue
end

func f (c Color) -> i32
    match c
        case Red
            return 1i32
        case Red
            return 2i32
        case Green
            return 3i32
        case Blue
            return 4i32
    end
end
