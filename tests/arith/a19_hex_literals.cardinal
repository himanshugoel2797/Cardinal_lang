module a19_hex_literals

import io

func main () -> i32
    # Hex literals if supported — use decimal equivalents otherwise
    # Pattern: verify that arithmetic with large constants works correctly

    # 0x7FFFFFFF = 2147483647 (INT32_MAX)
    do (io::println (+ 2147483647i32 0i32))

    # 0x80000000 = 2147483648 as u32
    do (io::println 2147483648u32)

    # Verify 0xFF = 255
    do (io::println 255u8)

    # Verify 0xFFFF = 65535
    do (io::println 65535u16)

    # Alternating bit patterns
    # 0xAAAAAAAA = 2863311530 as u32
    do (io::println (band 2863311530u32 4294967295u32))

    # 0x55555555 = 1431655765 as u32
    do (io::println (bor 0u32 1431655765u32))

    # XOR of complementary patterns = all 1s
    do (io::println (bxor 2863311530u32 1431655765u32))

    # i32 with high bit pattern: -1431655766 = (i32)(0xAAAAAAAA)
    do (io::println (as 2863311530u32 i32))

    return 0i32
end
