module a03_div_mod_signed

import io

func main () -> i32
    # Truncated division toward zero (C-style)
    # -7 / 2 = -3 (truncate toward zero)
    do (io::println (/ (- 7i32) 2i32))

    # -7 % 2 = -1 (sign follows dividend in C truncation)
    do (io::println (% (- 7i32) 2i32))

    # 7 / -2 = -3
    do (io::println (/ 7i32 (- 2i32)))

    # 7 % -2 = 1 (sign follows dividend)
    do (io::println (% 7i32 (- 2i32)))

    # -7 / -2 = 3
    do (io::println (/ (- 7i32) (- 2i32)))

    # -7 % -2 = -1
    do (io::println (% (- 7i32) (- 2i32)))

    # i64 signed division
    do (io::println (/ (- 100i64) 7i64))

    # i64 signed modulo
    do (io::println (% (- 100i64) 7i64))

    # division exactly at boundary: INT32_MIN / -1 overflows — wrap
    let i32min = (- 2147483648i32)
    do (io::println (/ i32min (- 1i32)))

    # Even boundary: INT64_MIN / -1 overflows — wrap
    let i64min = (- 9223372036854775808i64)
    do (io::println (/ i64min (- 1i64)))

    return 0i32
end
