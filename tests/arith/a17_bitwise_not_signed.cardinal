module a17_bitwise_not_signed

import io

func main () -> i32
    # bnot on signed types — relationship: bnot x = -(x+1)
    do (io::println (bnot 0i8))
    do (io::println (bnot (- 1i8)))
    do (io::println (bnot 127i8))
    do (io::println (bnot (- 128i8)))

    do (io::println (bnot 0i16))
    do (io::println (bnot (- 1i16)))
    do (io::println (bnot 32767i16))
    do (io::println (bnot (- 32768i16)))

    do (io::println (bnot 0i32))
    do (io::println (bnot (- 1i32)))
    do (io::println (bnot 2147483647i32))
    do (io::println (bnot (- 2147483648i32)))

    do (io::println (bnot 0i64))
    do (io::println (bnot (- 1i64)))
    do (io::println (bnot 9223372036854775807i64))
    do (io::println (bnot (- 9223372036854775808i64)))

    return 0i32
end
