module a28_bug_x86_int64min_div

import io

func main () -> i32
    # INT64_MIN / -1: overflows (two's complement wrap)
    # Expected result: INT64_MIN = -9223372036854775808 (wraps)
    # All three should agree on wrap behavior, not panic
    let i64min = (- 9223372036854775808i64)
    do (io::println (/ i64min (- 1i64)))

    return 0i32
end
