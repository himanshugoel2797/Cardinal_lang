module a05_shifts_unsigned

import io

func main () -> i32
    # shl by 0: identity
    do (io::println (shl 1u32 0u32))

    # shl by 31: sets top bit
    do (io::println (shl 1u32 31u32))

    # shl overflow: shifts bit out entirely
    do (io::println (shl 1u32 32u32))

    # shr by 0: identity
    do (io::println (shr 128u32 0u32))

    # shr by width-1
    do (io::println (shr 2147483648u32 31u32))

    # shr by width: should be 0
    do (io::println (shr 1u32 32u32))

    # u64 shl
    do (io::println (shl 1u64 63u64))

    # u64 shr of max
    do (io::println (shr 18446744073709551615u64 63u64))

    # u8 shl by 7
    do (io::println (shl 1u8 7u8))

    # u8 shr by 7
    do (io::println (shr 128u8 7u8))

    return 0i32
end
