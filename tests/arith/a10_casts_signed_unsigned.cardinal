module a10_casts_signed_unsigned

import io

func main () -> i32
    # i32 negative reinterpreted as u32 (same width)
    do (io::println (as (- 1i32) u32))

    # u32 max reinterpreted as i32
    do (io::println (as 4294967295u32 i32))

    # i64 negative reinterpreted as u64
    do (io::println (as (- 1i64) u64))

    # u64 max reinterpreted as i64
    do (io::println (as 18446744073709551615u64 i64))

    # i8 negative reinterpreted as u8
    do (io::println (as (- 1i8) u8))

    # u8 max reinterpreted as i8
    do (io::println (as 255u8 i8))

    # i16 negative as u16
    do (io::println (as (- 1i16) u16))

    # u16 max as i16
    do (io::println (as 65535u16 i16))

    # chain: i8 -> u8 -> i32 (zero-extends u8 into i32)
    do (io::println (as (as (- 1i8) u8) i32))

    return 0i32
end
