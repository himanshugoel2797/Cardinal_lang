module a26_bug_i64max_ops

import io

func main () -> i32
    # i64 max = 9223372036854775807
    let i64max = 9223372036854775807i64

    # Division by 1 should return the value unchanged
    do (io::println (/ i64max 1i64))

    # Modulo 7
    # 9223372036854775807 % 7 = 9223372036854775807 - 7*(9223372036854775807/7)
    # = 9223372036854775807 - 7*1317624576693539686 = 9223372036854775807 - 9223372036854775802 = 5?
    # Actually: 9223372036854775807 mod 7: 9223372036854775807 = 7*1317624576693539829 + r
    # 7*1317624576693539829 = 9223372036854775803, so r=4? let's check via C
    do (io::println (% i64max 7i64))

    # Subtraction: i64max - i64min
    let i64min = (- 9223372036854775808i64)
    do (io::println (- i64max i64min))

    return 0i32
end
