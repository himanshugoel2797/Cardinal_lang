module a11_comparisons_boundary

import io

func main () -> i32
    # Signed vs unsigned boundary comparisons
    # u32: large value > small unsigned value
    let big = 4294967295u32
    let small = 0u32
    do (io::println (> big small))

    # i32: -1 < 0 (signed)
    do (io::println (< (- 1i32) 0i32))

    # u32: when cast, -1i32 = 4294967295u32 which is > 0
    do (io::println (> (as (- 1i32) u32) 0u32))

    # i8 min < i8 max
    do (io::println (< (- 128i8) 127i8))

    # equality at boundary
    do (io::println (== 127i8 127i8))
    do (io::println (== (- 128i8) (- 128i8)))

    # u64 max comparisons
    let u64max = 18446744073709551615u64
    do (io::println (> u64max 0u64))
    do (io::println (== u64max 18446744073709551615u64))

    # i64 min < 0
    do (io::println (< (- 9223372036854775808i64) 0i64))

    # != at boundary
    do (io::println (!= (- 1i32) 2147483647i32))

    # >= and <=
    do (io::println (>= 0u32 0u32))
    do (io::println (<= 0u32 0u32))

    return 0i32
end
