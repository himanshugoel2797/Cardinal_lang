module t25_leading_zeros_decimal

import io

func main () -> i32
    # Leading zeros in decimal numbers
    let a = 0i32
    let b = 00i32
    let c = 001i32
    let d = 010i32
    let e = 0100i32
    do (io::println a)
    do (io::println b)
    do (io::println c)
    do (io::println d)
    do (io::println e)
    return 0i32
end
