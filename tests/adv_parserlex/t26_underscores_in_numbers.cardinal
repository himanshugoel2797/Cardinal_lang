module t26_underscores_in_numbers

import io

func main () -> i32
    # Underscores in numbers for readability
    let a = 1_000i32
    let b = 1_000_000i32
    let c = 0xFF_FFu16
    let d = 0b1111_0000u8
    let e = 1.5_5
    do (io::println a)
    do (io::println b)
    do (io::println c)
    do (io::println d)
    do (io::println e)
    return 0i32
end
