module t17_deeply_nested_parens

import io

func main () -> i32
    # Deeply nested parenthesized expressions
    let a = (((((((1i32 + 1i32) + 1i32) + 1i32) + 1i32) + 1i32) + 1i32))
    let b = (+ (+ (+ (+ (+ (+ 1i32 1i32) 1i32) 1i32) 1i32) 1i32) 1i32)
    do (io::println a)
    do (io::println b)
    return 0i32
end
