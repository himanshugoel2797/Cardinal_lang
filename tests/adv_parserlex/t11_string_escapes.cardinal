module t11_string_escapes

import io

func main () -> i32
    # String escapes
    let a = "hello"
    let b = "with\nnewline"
    let c = "with\ttab"
    let d = "backslash \\ here"
    let e = "quote\" here"
    do (io::println a)
    do (io::println b)
    do (io::println c)
    do (io::println d)
    do (io::println e)
    return 0i32
end
