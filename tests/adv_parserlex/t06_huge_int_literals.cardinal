module t06_huge_int_literals

import io

func main () -> i32
    # Test literals near and over 2^64
    let a = 9223372036854775807i64
    let b = 18446744073709551615u64
    let c = 255u8
    let d = 65535u16
    let e = 4294967295u32
    do (io::println a)
    do (io::println b)
    do (io::println c)
    do (io::println d)
    do (io::println e)
    return 0i32
end
