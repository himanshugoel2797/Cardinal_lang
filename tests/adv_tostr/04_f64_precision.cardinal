module test_f64_precision

import io

func main () -> i32
    do (io::println (to_str 0.0))
    do (io::println (to_str 1.0))
    do (io::println (to_str -1.0))
    do (io::println (to_str 1.5))
    do (io::println (to_str 1.23456789))
    do (io::println (to_str 1e9))
    do (io::println (to_str 1e-9))
    do (io::println (to_str 123456789.123456789))
    return 0i32
end
