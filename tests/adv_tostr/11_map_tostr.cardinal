module test_map_tostr

import io

func main () -> i32
    let m (map str i32) = (map str i32)
    do (io::println (to_str m))

    set m["a"] = 1i32
    set m["b"] = 2i32
    do (io::println (to_str m))

    let mi (map i32 str) = (map i32 str)
    set mi[1i32] = "one"
    set mi[2i32] = "two"
    do (io::println (to_str mi))

    return 0i32
end
