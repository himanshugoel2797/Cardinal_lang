module test_struct_tostr

import io

struct Point
    x i32
    y i32
end

struct Mixed
    a i32
    b f64
    c str
end

func main () -> i32
    let p = (Point x: 5 y: 10)
    do (io::println (to_str p))

    let m = (Mixed a: 42 b: 3.14 c: "test")
    do (io::println (to_str m))

    return 0i32
end
