module test_u64_edge

import io

func main () -> i32
    do (io::println (to_str 0u64))
    do (io::println (to_str 1u64))
    do (io::println (to_str 9223372036854775807u64))
    do (io::println (to_str 9223372036854775808u64))
    do (io::println (to_str 18446744073709551615u64))
    return 0i32
end
