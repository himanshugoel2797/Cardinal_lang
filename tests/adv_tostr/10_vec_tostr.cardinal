module test_vec_tostr

import io

func main () -> i32
    let v (vec i32) = (vec i32)
    do (io::println (to_str v))

    do (push v 1i32)
    do (push v 2i32)
    do (push v 3i32)
    do (io::println (to_str v))

    let vf (vec f64) = (vec f64)
    do (push vf 1.1)
    do (push vf 2.2)
    do (io::println (to_str vf))

    return 0i32
end
