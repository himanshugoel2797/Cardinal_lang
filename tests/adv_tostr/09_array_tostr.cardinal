module test_array_tostr

import io

func main () -> i32
    let empty [i32] = []
    do (io::println (to_str empty))

    let ints [i32] = [1 2 3]
    do (io::println (to_str ints))

    let floats [f64] = [1.5 2.5 3.5]
    do (io::println (to_str floats))

    let strs [str] = ["a" "b" "c"]
    do (io::println (to_str strs))

    return 0i32
end
