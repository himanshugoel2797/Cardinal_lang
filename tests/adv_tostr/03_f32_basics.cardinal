module test_f32_basics

import io

func main () -> i32
    do (io::println (to_str (as 0.0 f32)))
    do (io::println (to_str (as 1.0 f32)))
    do (io::println (to_str (as -1.0 f32)))
    do (io::println (to_str (as 3.14159 f32)))
    do (io::println (to_str (as 1000000.0 f32)))
    do (io::println (to_str (as 0.000001 f32)))
    return 0i32
end
