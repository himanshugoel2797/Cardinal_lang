module rec_larger_struct

import io

# Larger struct (6+ fields) passed by value through recursion
# Target: ABI parameter passing for larger aggregates

struct Data
    x i64
    y i64
    z i64
    w i64
    a i64
    b i64
end

func process (d Data) -> i64
    return (+ d.x (+ d.y (+ d.z (+ d.w (+ d.a d.b)))))
end

func recurse_data (depth i64) (d Data) -> i64
    if (<= depth 0)
        return (process d)
    end
    let new_d = (Data x: (+ d.x 1) y: (+ d.y 1) z: (+ d.z 1) w: (+ d.w 1) a: (+ d.a 1) b: (+ d.b 1))
    return (recurse_data (- depth 1) new_d)
end

func main () -> i32
    let d = (Data x: 1 y: 2 z: 3 w: 4 a: 5 b: 6)
    let result = (recurse_data 800i64 d)
    do (io::println result)
    return 0i32
end
