module rec_ackermann_small

import io

# Ackermann function: many mutual call paths
# ackermann(3, 3) = 61; ackermann(3, 4) = 125
# Target: exponential call tree, complex recursion patterns

func ackermann (m i64) (n i64) -> i64
    if (<= m 0)
        return (+ n 1i64)
    end
    if (<= n 0)
        return (ackermann (- m 1) 1i64)
    end
    return (ackermann (- m 1) (ackermann m (- n 1)))
end

func main () -> i32
    let r1 = (ackermann 3i64 3i64)
    let r2 = (ackermann 3i64 2i64)
    do (io::println r1)
    do (io::println r2)
    return 0i32
end
