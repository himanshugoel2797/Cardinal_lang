module rec_closure_through_calls

import io

# Closures passed and called through deep recursion
# Target: closure capture and calling through deep stack

func apply_closure (f func(i64 -> i64)) (n i64) -> i64
    if (<= n 0)
        return 0i64
    end
    let val = (f n)
    return (+ val (apply_closure f (- n 1)))
end

func main () -> i32
    let base = 10i64
    let closure = func (x i64) -> i64
        return (+ x base)
    end
    let result = (apply_closure closure 500i64)
    do (io::println result)
    return 0i32
end
