module rec_alternating_types

import io

# Recursion alternating between returning different numeric types
# Target: type handling in call chain

func recurse_alt (depth i64) (last_was_int bool) -> f64
    if (<= depth 0)
        return 0.0
    end
    if last_was_int
        let int_val = (as (recurse_alt (- depth 1) false) i64)
        return (+ 1.5 (as int_val f64))
    end
    let flt_val = (recurse_alt (- depth 1) true)
    return (+ flt_val 0.5)
end

func main () -> i32
    let result = (recurse_alt 600i64 true)
    do (io::println result)
    return 0i32
end
