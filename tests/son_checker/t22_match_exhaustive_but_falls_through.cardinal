module t22_match_exhaustive_but_falls_through
# ATTACK: a non-void function with a match on a sum type that is exhaustive
# (all variants covered), but NO return after the match.
# The checker has no return-flow analysis, so it accepts any function that doesn't
# have explicit coverage of all paths. When all arms return, the function is
# implicitly done - but the checker doesn't know this.
# Let's use a sum type (not enum) with match:

import io

type Color
    Red
    Green
    Blue
end

func color_val (c Color) -> i32
    match c
        case Red
            return 1i32
        case Green
            return 2i32
        case Blue
            return 3i32
    end
    # NO return here after the exhaustive match
    # The checker should reject this (non-void with possible fall-through)
    # but it actually ACCEPTS it (no return-flow analysis)
end

func main () -> i32
    let v = (color_val Red)
    do (io::println v)
    return 0i32
end
