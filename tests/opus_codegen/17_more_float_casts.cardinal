module main
import io

# f32 -> u64 above 2^63 (same signed-truncation bug surface as f64), and f32 -> u32
# boundary. Also negative-float -> signed int truncation toward zero.

func main () -> i32
    let f f32 = 1.0e19
    do (io::println (to_str (as f u64)))
    let g f64 = 4.0e9
    do (io::println (to_str (as g u32)))
    let n f64 = (- 7.8)
    do (io::println (to_str (as n i64)))
    let m f64 = (- 7.8)
    do (io::println (to_str (as m i32)))
    return 0i32
end
