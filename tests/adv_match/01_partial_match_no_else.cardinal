module test01

import io

type Shape
    Circle (radius i32)
    Square (side i32)
    Triangle (base i32) (height i32)
end

func describe (s Shape) -> i32
    match s
        case (Circle r)
            return r
        case (Square side)
            return side
    end
    return 999
end

func main () -> i32
    let c = (Circle radius: 5)
    do (io::println (describe c))
    return 0i32
end
