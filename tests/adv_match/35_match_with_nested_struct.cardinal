module test35

import io

struct Point
    x i32
    y i32
end

struct Rect
    p1 Point
    p2 Point
end

type Shape
    Rectangle (rect Rect)
    Dot (pt Point)
end

func extract_x (s Shape) -> i32
    match s
        case (Rectangle rect)
            return rect.p1.x
        case (Dot pt)
            return pt.x
    end
    return 0
end

func main () -> i32
    let r = (Rectangle rect: (Rect p1: (Point x: 1 y: 2) p2: (Point x: 3 y: 4)))
    let p = (Dot pt: (Point x: 5 y: 6))
    do (io::println (extract_x r))
    do (io::println (extract_x p))
    return 0i32
end
