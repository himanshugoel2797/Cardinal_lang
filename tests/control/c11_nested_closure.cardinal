module c11_nested_closure

import io

# Nested closures: closure returning a closure capturing outer scope
func outer (a i32) -> func(i32 -> func(-> i32))
    return func (b i32) -> func(-> i32)
        return func () -> i32
            return (+ a b)
        end
    end
end

# Three-level nesting
func make_adder3 (x i32) -> func(i32 -> func(i32 -> i32))
    return func (y i32) -> func(i32 -> i32)
        return func (z i32) -> i32
            return (+ (+ x y) z)
        end
    end
end

func main () -> i32
    let mid = (outer 10)
    let inner = (mid 5)
    do (io::println (inner))   # 15

    let inner2 = (mid 20)
    do (io::println (inner2))  # 30

    # Three levels
    let f = (make_adder3 1)
    let g = (f 2)
    do (io::println (g 3))     # 6 (1+2+3)

    let h = (f 10)
    do (io::println (h 100))   # 111 (1+10+100)

    return 0i32
end
