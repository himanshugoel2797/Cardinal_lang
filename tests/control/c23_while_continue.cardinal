module c23_while_continue

import io

func main () -> i32
    # continue in while loop
    let i = 0i32
    let sum = 0i32
    while (< i 10)
        set i = (+ i 1)
        if (== (% i 2) 0)
            continue
        end
        set sum = (+ sum i)
    end
    # Sum of odd numbers 1+3+5+7+9 = 25
    do (io::println sum)   # 25

    # continue in loop (infinite with break)
    let count = 0i32
    let skipped = 0i32
    let n = 0i32
    loop
        set n = (+ n 1)
        if (> n 10)
            break
        end
        if (== (% n 3) 0)
            set skipped = (+ skipped 1)
            continue
        end
        set count = (+ count 1)
    end
    do (io::println count)    # 7 (10 - 3 multiples of 3: 3,6,9)
    do (io::println skipped)  # 3

    return 0i32
end
