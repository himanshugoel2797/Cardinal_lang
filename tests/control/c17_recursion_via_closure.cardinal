module c17_recursion_via_closure

import io

# Recursion via a captured higher-order function passed as arg
func apply_n (f func(i32 -> i32)) (x i32) (n i32) -> i32
    if (<= n 0)
        return x
    end
    return (apply_n f (f x) (- n 1))
end

# Closure that calls a known recursive function
func make_fib_caller () -> func(i32 -> i32)
    return func (n i32) -> i32
        # Use the iterative approach inside the closure
        if (< n 2)
            return n
        end
        let a = 0i32
        let b = 1i32
        let i = 2i32
        while (<= i n)
            let tmp = (+ a b)
            set a = b
            set b = tmp
            set i = (+ i 1)
        end
        return b
    end
end

func main () -> i32
    # apply_n with a closure
    let add2 = func (x i32) -> i32
        return (+ x 2)
    end
    do (io::println (apply_n add2 0 5))   # 10 (0+2+2+2+2+2)
    do (io::println (apply_n add2 1 3))   # 7 (1+2+2+2)

    # Fib via closure (iterative)
    let fib = (make_fib_caller)
    do (io::println (fib 0))   # 0
    do (io::println (fib 1))   # 1
    do (io::println (fib 7))   # 13
    do (io::println (fib 10))  # 55

    return 0i32
end
