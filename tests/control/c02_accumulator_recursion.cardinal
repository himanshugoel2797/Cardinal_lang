module c02_accumulator_recursion

import io

# Accumulator-style tail recursion: sum 1..n with accumulator
func sum_acc (n i32) (acc i32) -> i32
    if (<= n 0)
        return acc
    end
    return (sum_acc (- n 1) (+ acc n))
end

# Non-tail factorial to stress the stack
func fact (n i64) -> i64
    if (<= n 1)
        return 1i64
    end
    return (* n (fact (- n 1)))
end

func main () -> i32
    do (io::println (sum_acc 100 0i32))  # 5050
    do (io::println (sum_acc 0 42i32))   # 42
    do (io::println (fact 12i64))        # 479001600
    do (io::println (fact 1i64))         # 1
    do (io::println (fact 0i64))         # 1
    return 0i32
end
