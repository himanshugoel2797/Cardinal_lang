module c26_closure_escape

import io

# Closure escaping its defining function: the captured cell must outlive the frame

func make_adder (n i32) -> func(i32 -> i32)
    # n is captured in a box; when make_adder returns, the box lives on
    return func (x i32) -> i32
        return (+ x n)
    end
end

func chain () -> func(-> i32)
    # Chained escaping closures
    let a = 1i32
    let inner = func () -> i32
        let b = 2i32
        let innermost = func () -> i32
            return (+ a b)
        end
        return (innermost)
    end
    return inner
end

func main () -> i32
    let add5 = (make_adder 5)
    let add100 = (make_adder 100)

    # Both closures must have independent captured values
    do (io::println (add5 3))    # 8
    do (io::println (add100 3))  # 103
    do (io::println (add5 10))   # 15

    # The chain test: inner escapes, innermost is re-created each call
    let f = (chain)
    do (io::println (f))   # 3
    do (io::println (f))   # 3 (innermost re-created with fresh b=2 each time)

    return 0i32
end
