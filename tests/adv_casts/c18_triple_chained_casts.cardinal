module c18_triple_chained_casts

import io

func main () -> i32
    # Three-way cast chains to test intermediate path correctness
    # i8 -> u8 -> i16 -> i32
    do (io::println (as (as (as (- 1i8) u8) i16) i32))

    # u32 -> i32 -> i64 -> u64
    do (io::println (as (as (as 4294967295u32 i32) i64) u64))

    # i32 -> u16 -> i32 -> i64
    do (io::println (as (as (as (- 1i32) u16) i32) i64))

    # f64 -> i64 -> u64 -> f64
    let fval = 999999999.5
    do (io::println (as (as (as fval i64) u64) f64))

    return 0i32
end
