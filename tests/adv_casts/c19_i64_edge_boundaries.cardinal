module c19_i64_edge_boundaries

import io

func main () -> i32
    # Test exact i64 min/max behavior in casts
    # i64 max = 9223372036854775807
    let i64_max = 9223372036854775807i64
    do (io::println (as i64_max u64))

    # i64 min = -9223372036854775808 (tricky: can't write as literal)
    do (io::println (as (- 9223372036854775807i64) i16))

    # 2^32 boundary
    do (io::println (as 4294967296i64 i32))

    do (io::println (as 4294967296i64 u32))

    # 2^31 boundary
    do (io::println (as 2147483648i64 i32))

    do (io::println (as 2147483648i64 u32))

    return 0i32
end
