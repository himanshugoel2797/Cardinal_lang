module c07_f64_to_i64_boundaries

import io

func main () -> i32
    # f64 to i64: large value boundaries
    let f0 = 0.0
    let f1 = 1.0
    let fm1 = (- 1.0)
    let flarge = 9000000000000000000.0
    let fminus_large = (- 9000000000000000000.0)
    let frac = 123.456
    let fneg_frac = (- 123.456)

    # Small values
    do (io::println (as f0 i64))

    do (io::println (as f1 i64))

    do (io::println (as fm1 i64))

    # i64 max = 9223372036854775807
    # Close to max (f64 can't represent exact i64 boundaries)
    do (io::println (as flarge i64))

    # i64 min = -9223372036854775808
    do (io::println (as fminus_large i64))

    # Fractional part truncates toward zero
    do (io::println (as frac i64))

    do (io::println (as fneg_frac i64))

    return 0i32
end
