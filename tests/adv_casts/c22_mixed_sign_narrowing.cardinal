module c22_mixed_sign_narrowing

import io

func main () -> i32
    # Mixed signed/unsigned narrowing edge cases
    # u32 with high bit -> i16
    do (io::println (as 32768u32 i16))

    # u16 with high bit -> i8
    do (io::println (as 128u16 i8))

    # i32 negative to u16
    do (io::println (as (- 100i32) u16))

    # u64 to i16
    do (io::println (as 32768u64 i16))

    # i64 large negative to u16
    do (io::println (as (- 1i64) u16))

    return 0i32
end
