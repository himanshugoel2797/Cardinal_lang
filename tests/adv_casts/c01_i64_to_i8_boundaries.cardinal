module c01_i64_to_i8_boundaries

import io

func main () -> i32
    # i64 to i8: test exact boundaries
    # 127 = max i8
    do (io::println (as 127i64 i8))

    # 128 = overflow, wraps to -128 in i8
    do (io::println (as 128i64 i8))

    # -128 = min i8
    do (io::println (as (- 128i64) i8))

    # -129 = underflow, wraps to 127 in i8
    do (io::println (as (- 129i64) i8))

    # Large positive i64 -> i8
    do (io::println (as 300i64 i8))

    # Large negative i64 -> i8
    do (io::println (as (- 300i64) i8))

    # 2^16 = 65536 -> i8 = 0
    do (io::println (as 65536i64 i8))

    # 2^32 -> i8
    do (io::println (as 4294967296i64 i8))

    return 0i32
end
