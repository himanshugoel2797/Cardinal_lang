module c09_f64_to_u64_boundaries

import io

func main () -> i32
    # f64 to u64: large unsigned boundaries
    let f0 = 0.0
    let f1 = 1.0
    let flarge = 18000000000000000000.0
    let fm1 = (- 1.0)
    let fmneg = (- 1000.5)
    let ffrac = 999.999

    do (io::println (as f0 u64))

    do (io::println (as f1 u64))

    # u64 max = 18446744073709551615
    # f64 can't represent this exactly, but test large value
    do (io::println (as flarge u64))

    # Negative (undefined behavior)
    do (io::println (as fm1 u64))

    do (io::println (as fmneg u64))

    # Fractional truncation
    do (io::println (as ffrac u64))

    return 0i32
end
