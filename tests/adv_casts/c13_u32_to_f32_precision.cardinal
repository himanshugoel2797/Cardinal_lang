module c13_u32_to_f32_precision

import io

func main () -> i32
    # u32 to f32
    do (io::println (as 0u32 f32))

    do (io::println (as 1u32 f32))

    # u32 max = 4294967295
    do (io::println (as 4294967295u32 f32))

    # Large values
    do (io::println (as 1000000000u32 f32))

    return 0i32
end
