module c20_u64_max_casts

import io

func main () -> i32
    # u64 max = 18446744073709551615 casts to various types
    let u64_max = 18446744073709551615u64

    # to i64 (reinterpret bits as -1)
    do (io::println (as u64_max i64))

    # to u32 (truncate to 0xffffffff = 4294967295u32)
    do (io::println (as u64_max u32))

    # to i32 (truncate to 0xffffffff, reinterpret as -1i32)
    do (io::println (as u64_max i32))

    # to u8 (truncate to 255)
    do (io::println (as u64_max u8))

    # to f64 (large precision loss)
    do (io::println (as u64_max f64))

    return 0i32
end
