module t37_sum_in_closure_capture

import io

# A sum value captured by a closure and modified via the closure's return
type Counter
    Zero
    Count (n i32)
end

func make_counter_sum () -> func(-> i32)
    let state = Zero
    let inc = func () -> i32
        match state
            case Zero
                set state = (Count n: 1)
                return 1
            case (Count n)
                set state = (Count n: (+ n 1))
                return (+ n 1)
        end
        return 0
    end
    return inc
end

func main () -> i32
    let counter = (make_counter_sum)
    do (io::println (counter))   # 1
    do (io::println (counter))   # 2
    do (io::println (counter))   # 3
    do (io::println (counter))   # 4
    return 0i32
end
