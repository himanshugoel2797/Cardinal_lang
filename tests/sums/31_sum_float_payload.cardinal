module t31_sum_float_payload

import io

# Sum type with float payload field
type Measure
    Celsius (temp f64)
    Fahrenheit (temp f64)
    Unknown
end

func to_celsius (m Measure) -> f64
    match m
        case (Celsius t)
            return t
        case (Fahrenheit t)
            return (/ (* (- t 32.0) 5.0) 9.0)
        case Unknown
            return 0.0
    end
    return 0.0
end

func main () -> i32
    let c = (Celsius temp: 100.0)
    let f = (Fahrenheit temp: 32.0)
    let u = Unknown

    do (io::println (to_celsius c))   # 100
    do (io::println (to_celsius f))   # 0
    do (io::println (to_celsius u))   # 0
    return 0i32
end
