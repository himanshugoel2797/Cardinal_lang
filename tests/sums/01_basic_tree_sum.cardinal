module t01_basic_tree_sum

import io

# Basic recursive sum type: binary tree with sum/count/depth
type Tree
    Leaf
    Node (value i32) (left Tree) (right Tree)
end

func sum_tree (t Tree) -> i32
    match t
        case Leaf
            return 0
        case (Node v l r)
            return (+ v (+ (sum_tree l) (sum_tree r)))
    end
    return 0
end

func count_tree (t Tree) -> i32
    match t
        case Leaf
            return 0
        case (Node v l r)
            return (+ 1 (+ (count_tree l) (count_tree r)))
    end
    return 0
end

func depth_tree (t Tree) -> i32
    match t
        case Leaf
            return 0
        case (Node v l r)
            let ld = (depth_tree l)
            let rd = (depth_tree r)
            if (>= ld rd)
                return (+ 1 ld)
            else
                return (+ 1 rd)
            end
    end
    return 0
end

func main () -> i32
    #       10
    #      /  \
    #     5    20
    #    / \
    #   2   3
    let t = (Node value: 10
                  left: (Node value: 5
                              left: (Node value: 2 left: Leaf right: Leaf)
                              right: (Node value: 3 left: Leaf right: Leaf))
                  right: (Node value: 20 left: Leaf right: Leaf))
    do (io::println (sum_tree t))    # 40
    do (io::println (count_tree t))  # 5
    do (io::println (depth_tree t))  # 3
    return 0i32
end
