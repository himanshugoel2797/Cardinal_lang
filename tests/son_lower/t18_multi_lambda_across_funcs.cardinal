module t18_multi_lambda_across_funcs

# STRATEGY 18: Lambda counter is global. Test that lambdas across different
# functions in the same module don't collide with each other.
# Also test: a function named "lambda5" with 5 lambdas in earlier functions.

import io

func lambda5 () -> i32
    return 500i32
end

func gen_lambdas_1 () -> func(-> i32)
    let f = func () -> i32  # lambda1
        return 1i32
    end
    return f
end

func gen_lambdas_2 () -> func(-> i32)
    let f = func () -> i32  # lambda2
        return 2i32
    end
    return f
end

func gen_lambdas_3 () -> func(-> i32)
    let f = func () -> i32  # lambda3
        return 3i32
    end
    return f
end

func gen_lambdas_4 () -> func(-> i32)
    let f = func () -> i32  # lambda4
        return 4i32
    end
    return f
end

func gen_lambdas_5 () -> func(-> i32)
    let f = func () -> i32  # lambda5 -- COLLIDES with user func lambda5!
        return 5i32
    end
    return f
end

func main () -> i32
    let f1 = (gen_lambdas_1)
    let f2 = (gen_lambdas_2)
    let f3 = (gen_lambdas_3)
    let f4 = (gen_lambdas_4)
    let f5 = (gen_lambdas_5)
    do (io::println (f1))
    do (io::println (f2))
    do (io::println (f3))
    do (io::println (f4))
    do (io::println (f5))
    do (io::println (lambda5))
    return 0i32
end
