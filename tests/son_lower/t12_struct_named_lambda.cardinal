module t12_struct_named_lambda

# STRATEGY 12: Struct name "lambda1" collides with auto-generated lambda name.
# The lowerer generates lambda names: mangle(mod, "lambda" + N)
# A struct named "lambda1" generates C struct: cl_struct_<mod>__lambda1
# The auto-generated lambda body is named: cl_<mod>__lambda1
# These are DIFFERENT C symbols (one is a struct typedef, other is a function).
# So this may NOT actually collide, but let's test to verify.
# More interesting: if user defines func "lambda2" and generates 2 lambdas in
# another function, the second lambda would be cl_<mod>__lambda2 which collides
# with the user's func.

import io

func lambda2 () -> i32
    return 200i32
end

# This function generates two lambdas: lambda1 and lambda2 from the module counter
func make_two_fns () -> i32
    let f1 = func () -> i32
        return 1i32
    end
    let f2 = func () -> i32
        return 2i32
    end
    return (+ (f1) (f2))
end

func main () -> i32
    do (io::println (make_two_fns))   # 3
    do (io::println (lambda2))         # 200
    return 0i32
end
