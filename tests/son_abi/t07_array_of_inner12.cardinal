module t07_array_of_inner12

import io

# Array of 12-byte structs. Element size 12, but copies happen word-wise.
# Reading an element (IArrGet -> load_elem) then its fields. Packed 12-byte
# elements: element i at base + 12*i. A 16-byte word-copy read of element 0
# would bleed into element 1; and the LAST element's 16B read overruns the buffer.
struct Inner
    a i32
    b i32
    c i32
end

func main () -> i32
    let xs = [(Inner a: 10i32 b: 11i32 c: 12i32) (Inner a: 20i32 b: 21i32 c: 22i32) (Inner a: 30i32 b: 31i32 c: 32i32)]
    let e0 = xs[0]
    let e1 = xs[1]
    let e2 = xs[2]
    do (io::println e0.a)  # 10
    do (io::println e0.c)  # 12
    do (io::println e1.a)  # 20
    do (io::println e1.c)  # 22
    do (io::println e2.a)  # 30
    do (io::println e2.c)  # 32
    return 0i32
end
