module t09_thunk_struct_param

import io

# A named top-level function that takes a STRUCT by value, used as a function
# VALUE (assigned to a func-typed variable / passed to apply). That forces the
# x86 backend to emit a thunk for it, and int_regs_for_src panics on a by-value
# struct thunk param: "x86: by-value struct thunk param (later milestone)".
# Interpreter + C backend handle it fine -> divergence (x86 compile panic).
struct P
    x i64
    y i64
end

func sum_p (p P) -> i64
    return (+ p.x p.y)
end

func apply (f func(P -> i64)) (p P) -> i64
    return (f p)
end

func main () -> i32
    let g = sum_p          # take sum_p as a function value -> thunk
    let p = (P x: 11i64 y: 22i64)
    do (io::println (apply g p))   # 33
    return 0i32
end
