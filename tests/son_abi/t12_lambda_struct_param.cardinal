module t12_lambda_struct_param

import io

# CONTRAST to t09: a LAMBDA (closure literal) taking a struct by value is called
# via ICallClosure (its own env), NOT via a thunk -> should work. If THIS also
# breaks, the struct-by-value-to-closure path itself is broken.
struct P
    x i64
    y i64
end

func main () -> i32
    let g = func (p P) -> i64
        return (+ p.x p.y)
    end
    let p = (P x: 11i64 y: 22i64)
    do (io::println (g p))   # 33
    return 0i32
end
