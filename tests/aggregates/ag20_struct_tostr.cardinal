module ag20_struct_tostr

import io

# to_str of structs — field order must match declaration order
struct Color
    r i32
    g i32
    b i32
end

struct Named
    label str
    code i32
end

func main () -> i32
    let col = (Color r: 255i32 g: 128i32 b: 0i32)
    do (io::println (to_str col))   # {r: 255, g: 128, b: 0}

    let n = (Named label: "red" code: 1i32)
    do (io::println (to_str n))     # {label: red, code: 1}

    return 0i32
end
