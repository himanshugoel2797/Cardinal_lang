module ag22_struct_in_array_mutation

import io

# set arr[i] = struct value; set arr[i].field = v
struct Pixel
    r i32
    g i32
    b i32
end

func black () -> Pixel
    return (Pixel r: 0i32 g: 0i32 b: 0i32)
end

func main () -> i32
    let pixels = [(Pixel r: 10i32 g: 20i32 b: 30i32) (Pixel r: 40i32 g: 50i32 b: 60i32) (Pixel r: 70i32 g: 80i32 b: 90i32)]

    # set whole element
    set pixels[0] = (black)
    do (io::println pixels[0].r)    # 0
    do (io::println pixels[0].g)    # 0
    do (io::println pixels[0].b)    # 0

    # set individual field
    set pixels[1].r = 255i32
    do (io::println pixels[1].r)    # 255
    do (io::println pixels[1].g)    # 50  (unchanged)
    do (io::println pixels[1].b)    # 60  (unchanged)

    # original [2] untouched
    do (io::println pixels[2].r)    # 70
    do (io::println pixels[2].g)    # 80
    do (io::println pixels[2].b)    # 90

    return 0i32
end
