module t09_map_str_value_resize

import io
import strings
import convert

# map<int, str>: insert freshly-allocated str values while the map rehashes.
# cl_map_set copies the value into a C local `_v` (a str handle) and may then
# rehash (allocate, possibly collect). The original value temp is rooted, but
# this stresses the rehash-with-managed-values path heavily.
func main () -> i32
    let m = (map i32 str)
    for i = 0 to 2000
        set m[i] = (strings::concat "v" (convert::int_to_str (as i i64)))
    end
    let total = 0i32
    for i = 0 to 2000
        set total = (+ total (as (len m[i]) i32))
    end
    do (io::println total)
    do (io::println (as (len (map_keys m)) i32))
    return 0i32
end
