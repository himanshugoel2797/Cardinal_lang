module f02_basic_arith_f32

import io

func main () -> i32
    # Basic f32 arithmetic — f32 has less precision than f64
    let a = 1.0f32
    let b = 3.0f32
    do (io::println (+ a b))
    do (io::println (- a b))
    do (io::println (* a b))
    do (io::println (/ a b))

    # 1/3 in f32 — should differ from f64 due to rounding
    do (io::println (/ 1.0f32 3.0f32))

    # 0.1 + 0.2 in f32
    let x = 0.1f32
    let y = 0.2f32
    do (io::println (+ x y))

    return 0i32
end
